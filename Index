    state.wins++;
    addNews(`🎉 ${state.name} ${matchCtx.myGoals} gol attı!`);
    SFX.levelup();
    setTimeout(() => showConfetti(40), 200);
  } else if (matchCtx.myGoals === matchCtx.oppGoals) {

// ============================================================
// Günlük ödül kontrolü, sadece oyuncu seçilmişse çalışır.
// Eski kodda init() içinde load()'dan sonra koşulsuz çağrılıyordu;
// ilk açılışta intro ekranı gözükmeden önce daily modal arkada açılabiliyordu.
function checkDailyReward() {
  if (state.selected === null) return; // oyuncu yoksa atla
  const today = new Date().toDateString();
  if (state.lastLogin === today) return;

  const yesterday = new Date(); yesterday.setDate(yesterday.getDate() - 1);
  if (state.lastLogin === yesterday.toDateString()) {
    state.streak++;
  } else {
    state.streak = 1;
  }
  if (state.streak > state.maxStreak) state.maxStreak = state.streak;
  state.lastLogin = today;
  showDailyReward();
}

function showDailyReward() {
  const dayIdx = Math.min(state.streak - 1, 6);
  document.getElementById('daily-streak-text').textContent = `${state.streak}. Gün Streak 🔥`;

  const row = document.getElementById('daily-rewards-row');
  row.innerHTML = '';
  DAILY_REWARDS.forEach((r, i) => {
    let cls = 'daily-reward-cell';
    if (i < dayIdx) cls += ' claimed';
    if (i === dayIdx) cls += ' today';
    row.innerHTML += `
      <div class="${cls}">
        <div style="font-size:10px;color:var(--text-dim);">G${r.day}</div>
        <div>$${r.money}</div>
        ${r.coins ? `<div style="color:var(--gold);">💎${r.coins}</div>` : ''}
      </div>
    `;
  });

  document.getElementById('daily-modal').classList.add('active');

  document.getElementById('daily-claim-btn').onclick = () => {
    const r = DAILY_REWARDS[dayIdx];
    state.money += r.money;
    state.coins += r.coins;
    showFloat(`+$${r.money}`, false, true);
    document.getElementById('daily-modal').classList.remove('active');
    flashCurrency('money');
    if (r.coins) flashCurrency('coin');
    SFX.coin();
    showSparkles(8);
    updateUI();
    checkAchievements();
  };
}


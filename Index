function processDefendResult(technique) {
  const eventEl = document.getElementById('match-event');
  const decisionDiv = document.getElementById('match-decisions');

  const defansStat = state.defans || state.skill;
  const hizStat = state.hiz || state.skill;

  let success, foul = false, message;

  if (technique === 'tackle') {
    // Müdahale: yüksek başarı şansı ama faul riski
    const skill = defansStat / 100;
    success = Math.random() < skill * 0.85;
    if (Math.random() < 0.18) foul = true;
    message = success
      ? (foul ? `Topu aldın ama faul! Sarı kart riski.` : `🦵 Müthiş müdahale! Top sende.`)
      : `Yetişemedin, rakip içeri...`;
  } else if (technique === 'block') {
    // Blok: orta başarı, faul riski yok
    const skill = (defansStat * 0.7 + hizStat * 0.3) / 100;
    success = Math.random() < skill * 0.7;
    message = success ? `🛡️ Mükemmel blok!` : `Top yanından geçti...`;
  } else if (technique === 'press') {
    // Baskı: hız ağırlıklı
    const skill = hizStat / 100;
    success = Math.random() < skill * 0.8;
    message = success ? `⚡ Hızla yetiştin, top kapıldı!` : `Çok hızlıydı...`;
  }

  if (success) {
    matchCtx.oppPressure = Math.max(0.2, matchCtx.oppPressure - 0.15);
    if (foul) {
      state.publicImage = clamp(state.publicImage - 2);
      // Faul rakibe frikik fırsatı verir
      setTimeout(() => simulateOppMove(0.3), 1500);
    }
  } else {
    matchCtx.oppPressure = Math.min(1.0, matchCtx.oppPressure + 0.1);
    setTimeout(() => simulateOppMove(0.5), 1500);
  }

  setTimeout(() => {
    eventEl.className = success ? 'match-event' : 'match-event fail';
    eventEl.textContent = message;
  }, 600);

  setTimeout(() => {
    decisionDiv.style.display = 'none';
    triggerNextEvent();
  }, 2400);
}


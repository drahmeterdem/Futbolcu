function processFreeKickResult(technique, distance) {
  const eventEl = document.getElementById('match-event');
  const decisionDiv = document.getElementById('match-decisions');

  // Mesafe etkisi: yakın daha yüksek şans
  const distanceMod = 1.0 - (distance - 18) * 0.04; // 18m = 1.0, 30m = 0.52

  let result, message;

  if (technique === 'curl') {
    // Falso — şut+pas karışımı, orta mesafede en iyi
    const sutStat = state.sut || state.skill;
    const pasStat = state.pas || state.skill;
    const technique_skill = (sutStat * 0.6 + pasStat * 0.4) / 100;
    const goalChance = technique_skill * distanceMod * 0.45 * matchCtx.luckyMod;
    if (Math.random() < goalChance) {
      result = 'goal';
      message = `🌀 FİLELERİ HAVALANDIRDIN! Müthiş bir falso!`;
    } else if (Math.random() < 0.3) {
      result = 'save';
      message = `🧤 Kaleci ucundan çevirdi, korner!`;
    } else {
      result = 'miss';
      message = `Direğin yanından geçti...`;
    }
  } else if (technique === 'power') {
    // Sert şut — yakın mesafede çok güçlü
    const sutStat = state.sut || state.skill;
    const technique_skill = sutStat / 100;
    const goalChance = technique_skill * distanceMod * 0.4 * matchCtx.luckyMod;
    if (Math.random() < goalChance) {
      result = 'goal';
      message = `💥 ROKETI BIRAKTIN! Filelerden duvara!`;
    } else if (Math.random() < 0.25) {
      result = 'save';
      message = `🧤 Kaleci yumrukladı`;
    } else if (Math.random() < 0.4) {
      result = 'wall';
      message = `Duvara çarptı, geri döndü`;
    } else {
      result = 'miss';
      message = `Tribüne...`;
    }
  } else if (technique === 'chip') {
    // Pas — kafa golü için arkadaşa
    const pasStat = state.pas || state.skill;
    const technique_skill = pasStat / 100;
    const passSuccess = Math.random() < technique_skill * 0.85;
    if (!passSuccess) {
      result = 'miss';
      message = `Pas kesildi, fırsat tükendi`;
    } else {
      // Arkadaş kafa vuruyor
      const headerChance = 0.35 * matchCtx.luckyMod;
      if (Math.random() < headerChance) {
        result = 'goal';
        message = `🎯 KAFAYA İNDİ, GOOOL! Asist senden!`;
        state.fame = clamp(state.fame + 2);
      } else {
        result = 'wall';
        message = `Kafa şutu kalecide kaldı`;
      }
    }
  }

  setTimeout(() => {
    if (result === 'goal') {
      matchCtx.myGoals++;
      showGoalFlash();
      setTimeout(() => {
        const scoreEl = document.getElementById('match-my-score');
        scoreEl.textContent = matchCtx.myGoals;
        scoreEl.classList.remove('scored');
        void scoreEl.offsetWidth;
        scoreEl.classList.add('scored');
        eventEl.className = 'match-event gol';
        eventEl.textContent = message;
      }, 400);
    } else {
      eventEl.className = result === 'miss' ? 'match-event fail' : 'match-event';
      eventEl.textContent = message;
    }
  }, 1100);

  setTimeout(() => {
    decisionDiv.style.display = 'none';
    triggerNextEvent();
  }, 2800);
}


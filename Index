function updateWeather() {
  const stage = document.getElementById('stage-card');
  const fx = document.getElementById('weather-fx');
  fx.innerHTML = '';
  stage.classList.remove('weather-rain', 'weather-snow', 'weather-cloud');

  if (state.weather === 'rain') {
    stage.classList.add('weather-rain');
    for (let i = 0; i < 16; i++) {
      const d = document.createElement('div');
      d.className = 'raindrop';
      d.style.left = Math.random() * 100 + '%';
      d.style.animationDelay = Math.random() * 0.55 + 's';
      d.style.animationDuration = (0.4 + Math.random() * 0.3) + 's';
      fx.appendChild(d);
    }
  } else if (state.weather === 'snow') {
    stage.classList.add('weather-snow');
    for (let i = 0; i < 14; i++) {
      const d = document.createElement('div');
      d.className = 'snowflake';
      d.textContent = ['❄', '❅', '❆'][Math.floor(Math.random()*3)];
      d.style.left = Math.random() * 100 + '%';
      d.style.animationDelay = Math.random() * 4 + 's';
      d.style.animationDuration = (3 + Math.random() * 2) + 's';
      fx.appendChild(d);
    }
  } else if (state.weather === 'sun') {
    const sun = document.createElement('div');
    sun.className = 'sun';
    fx.appendChild(sun);
  } else if (state.weather === 'cloud') {
    stage.classList.add('weather-cloud');
    for (let i = 0; i < 2; i++) {
      const c = document.createElement('div');
      c.className = 'cloud';
      c.style.top = (10 + i * 30) + 'px';
      c.style.animationDelay = (i * -10) + 's';
      fx.appendChild(c);
    }
  }
}

function rollWeather() {
  const r = Math.random();
  if (r < 0.45) state.weather = 'sun';
  else if (r < 0.7) state.weather = 'cloud';
  else if (r < 0.9) state.weather = 'rain';
  else state.weather = 'snow';
  updateWeather();
}


function buyBoost(type) {
  const costs = { train2x: 30, instant_heal: 50, lucky: 20 };
  const cost = costs[type];
  if (state.coins < cost) { showMessage('Coin yetersiz!', 'warn'); return; }

  if (type === 'instant_heal' && !state.injured) {
    showMessage('Sakatlık yok, gerek yok', 'warn');
    return;
  }

  state.coins -= cost;
  flashCurrency('coin');

  if (type === 'train2x') {
    state.trainBoostDays = 3;
    showMessage('⚡ 2x Antrenman 3 gün aktif!', 'event');
  }
  else if (type === 'instant_heal') {
    state.injured = false;
    state.injuryDaysLeft = 0;
    showMessage('💉 Anında iyileştin!', 'event');
  }
  else if (type === 'lucky') {
    state.luckyDays = 3;
    showMessage('🍀 Şans 3 gün aktif!', 'event');
    showSparkles(10);
  }

  SFX.coin();
  updateUI();
}


})();


// ============================================================
// INIT
// ============================================================
function init() {
  // v9: legacy save varsa slot 1'e taşı
  migrateLegacySave();

  // ── V13 ENTEGRASYON ───────────────────────────────────────
  // V13 yüklenmemişse atla — temel oyun yine çalışır
  if (typeof V13 !== 'undefined' && V13 && V13.ALL_TEAMS) {
    try {
      // 1) Eski TEAMS string array'ini v13 takım NESNELERİnin name'leriyle değiştir
      TEAMS.length = 0;
      V13.ALL_TEAMS.forEach(t => TEAMS.push(t.name));

      // 2) state.teamIndex sınır kontrolü
      if (state.teamIndex >= TEAMS.length) state.teamIndex = 0;

      // 3) initLeague'i tier-aware yap (mevcut fonksiyonu sarmala)
      if (!initLeague.__v13) {
        const origInitLeague = initLeague;
        window.initLeague = function() {
          try {
            const indices = V13.getCurrentLeagueIndices();
            if (!indices || indices.length === 0) {
              return origInitLeague.apply(this, arguments);
            }
            state.leagueStats = indices.map(i => ({
              name: TEAMS[i] || '—',
              idx: i,
              p: 0, w: 0, d: 0, l: 0, gf: 0, ga: 0, pts: 0,
              isMe: i === state.teamIndex,
            }));
          } catch(e) {
            console.warn('initLeague v13 err, fallback:', e);
            return origInitLeague.apply(this, arguments);
          }
        };
        window.initLeague.__v13 = true;
      }
    } catch(e) {
      console.error('v13 entegrasyon hatası — temel oyun devam ediyor:', e);
    }
  } else {
    console.warn('V13 modülü yüklü değil, temel oyun modu');
  }
  // ──────────────────────────────────────────────────────────

  // v9 final: test modu kontrolü — URL'de ?test=1 varsa karşılama göster
  const urlParams = new URLSearchParams(window.location.search);
  const isTestMode = urlParams.get('test') === '1';
  if (isTestMode && !localStorage.getItem('futbolcum_test_welcomed')) {
    setTimeout(() => {
      showCinematicNews({
        tag: 'TEST SÜRÜMÜ',
        icon: '🧪',
        title: `<span>TEST</span> AŞAMASINA HOŞ GELDİN`,
        subtitle: `Bu oyun geliştirme aşamasında. Bug bulursan veya önerin varsa ayarlardan "Geri Bildirim Gönder" butonunu kullanabilirsin. İyi eğlenceler!`,
        type: 'gold',
      });
      localStorage.setItem('futbolcum_test_welcomed', '1');
    }, 800);
  }

  // Hiç slot var mı kontrol et
  let hasAnySlot = false;
  try { hasAnySlot = !!(getSlotInfo(1) || getSlotInfo(2) || getSlotInfo(3)); } catch(e){}

  try {
    if (hasAnySlot) {
      drawCharacter(document.getElementById('player'),
                    '#8b4513', '#1a4c8c', false, 'normal', 'light');
      rollWeather();
      initLeague();
      updateUI();
      if (state.introSeen || hasAnySlot) {
        state.introSeen = true;
        showSlotsScreen();
      } else {
        document.getElementById('intro-modal').classList.add('active');
      }
    } else {
      // Tek bir slot bile yok — intro göster
      document.getElementById('intro-modal').classList.add('active');
      drawCharacter(document.getElementById('player'),
                    '#8b4513', '#1a4c8c', false, 'normal', 'light');
      rollWeather();
      initLeague();
      updateUI();
    }
  } catch(e) {
    console.error('init render err:', e);
    // En kötü senaryoda intro'yu yine de göster
    const intro = document.getElementById('intro-modal');
    if (intro) intro.classList.add('active');
  }
}


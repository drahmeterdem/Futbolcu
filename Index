function maybeTriggerSponsorOffer() {
  if (state.fame < 45) return;
  if (!state.activeSponsors) state.activeSponsors = [];
  if (state.activeSponsors.length >= 3) return;
  if (!state.sponsorOffersThisSeason) state.sponsorOffersThisSeason = 0;
  if (state.sponsorOffersThisSeason >= 4) return;

  if (Math.random() < 0.025) {
    const eligible = SPONSORS.filter(s =>
      s.minFame <= state.fame &&
      !state.activeSponsors.some(a => a.id === s.id)
    );
    if (eligible.length === 0) return;
    const sponsor = eligible[Math.floor(Math.random() * eligible.length)];
    state.sponsorOffersThisSeason++;
    showSponsorOffer(sponsor);
  }
}

function showSponsorOffer(sponsor) {
  showConfirm(
    `${sponsor.name} TEKLİF`,
    `${sponsor.type} markası seninle anlaşmak istiyor. Haftalık $${sponsor.weekly}, ${sponsor.duration} sezon. Şart: ${sponsor.requirement.label}`,
    () => acceptSponsor(sponsor),
    'primary'
  );
}

function acceptSponsor(sponsor) {
  if (!state.activeSponsors) state.activeSponsors = [];
  state.activeSponsors.push({
    id: sponsor.id,
    name: sponsor.name,
    logo: sponsor.logo,
    color: sponsor.color,
    weekly: sponsor.weekly,
    durationLeft: sponsor.duration,
    requirement: sponsor.requirement,
    startSeason: state.season,
    earnedTotal: 0,
    weeksActive: 0,
  });
  showCinematicNews({
    tag: 'YENİ SPONSOR',
    icon: '🤝',
    title: `<span>${sponsor.name}</span> İLE ANLAŞMA`,
    subtitle: `${sponsor.type} markası ${state.name.split(' ')[0]} ile haftalık $${sponsor.weekly} sözleşmesi imzaladı.`,
    type: 'gold',
  });
  state.fame = clamp(state.fame + 3);
  save();
  updateUI();
}

function processSponsorPayments() {
  if (!state.activeSponsors || state.activeSponsors.length === 0) return;
  state.activeSponsors.forEach(sp => {
    sp.weeksActive++;
    state.money += sp.weekly;
    sp.earnedTotal += sp.weekly;
  });
  const totalWeekly = state.activeSponsors.reduce((sum, s) => sum + s.weekly, 0);
  if (totalWeekly > 0) {
    showFloat(`+$${totalWeekly} sponsor`, false, true);
    flashCurrency('money');
  }
}

function evaluateSponsors() {
  if (!state.activeSponsors || state.activeSponsors.length === 0) return;
  const seasonStartGoals = state.seasonStartGoals || 0;
  const seasonGoals = state.goals - seasonStartGoals;

  const survivors = [];
  const broken = [];

  state.activeSponsors.forEach(sp => {
    let satisfied = true;
    const req = sp.requirement;
    if (req.type === 'goals_per_season') satisfied = seasonGoals >= req.target;
    else if (req.type === 'matches_per_season') satisfied = state.matches >= req.target;
    else if (req.type === 'public_image_min') satisfied = state.publicImage >= req.target;
    else if (req.type === 'fame_min') satisfied = state.fame >= req.target;
    else if (req.type === 'wins_per_season') satisfied = state.wins >= req.target;
    else satisfied = true;

    sp.durationLeft--;
    if (!satisfied) broken.push(sp);
    else if (sp.durationLeft > 0) survivors.push(sp);
    else broken.push({ ...sp, completed: true });
  });

  state.activeSponsors = survivors;
  broken.forEach(sp => {
    if (sp.completed) {
      showCinematicNews({
        tag: 'SPONSORLUK TAMAMLANDI',
        icon: '✅',
        title: `<span>${sp.name}</span> Sözleşmesi Bitti`,
        subtitle: `Toplam kazanç: $${sp.earnedTotal.toLocaleString()}.`,
        type: 'gold',
      });
    } else {
      showCinematicNews({
        tag: 'SPONSORLUK İPTAL',
        icon: '❌',
        title: `<span>${sp.name}</span> Çekildi`,
        subtitle: `Şart yerine getirilmedi: ${sp.requirement.label}. İmaj -8.`,
        type: 'urgent',
      });
      state.publicImage = clamp(state.publicImage - 8);
    }
  });
  state.sponsorOffersThisSeason = 0;
}

function maybeTriggerBigShoot() {
  if (!state.activeSponsors || state.activeSponsors.length === 0) return;
  if (state.injured || state.energy < 50) return;
  if (!state.lastBigShoot) state.lastBigShoot = 0;
  if (state.day - state.lastBigShoot < 14) return;

  if (Math.random() < 0.05) {
    const sp = state.activeSponsors[Math.floor(Math.random() * state.activeSponsors.length)];
    const fee = sp.weekly * 8;
    showConfirm(
      `${sp.name} BÜYÜK ÇEKİM`,
      `${sp.name} büyük bir TV reklamı çekmek istiyor. Ödeme: $${fee.toLocaleString()}. -25 enerji, +5 şöhret.`,
      () => {
        state.money += fee;
        state.energy = clamp(state.energy - 25);
        state.fame = clamp(state.fame + 5);
        state.lastBigShoot = state.day;
        showFloat(`+$${fee}`, false, true);
        flashCurrency('money');
        showCinematicNews({
          tag: 'BÜYÜK ÇEKİM',
          icon: '📷',
          title: `${state.name.split(' ')[0]} <span>${sp.name}</span> REKLAMINDA`,
          subtitle: `Yıldız oyuncu, ${sp.name} reklam filminde başrolde. Ödeme: $${fee.toLocaleString()}.`,
          type: 'gold',
        });
        save();
        updateUI();
      },
      'primary'
    );
  }
}


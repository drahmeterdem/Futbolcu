let currentHubTab = 'quests';

function openClubHub(initialTab){
  const modal = document.getElementById('modal-club-hub');
  if(!modal){ console.warn('modal-club-hub not found'); return; }
  modal.classList.add('active');
  selectHubTab(initialTab || currentHubTab || 'quests');
}

function closeClubHub(){
  const modal = document.getElementById('modal-club-hub');
  if(modal) modal.classList.remove('active');
}

function selectHubTab(tab){
  currentHubTab = tab;
  const ids = ['quests','tactic','card','manager'];
  ids.forEach(id => {
    const pill = document.getElementById('tab-hub-' + id);
    if(pill) pill.classList.toggle('active', id === tab);
  });
  const container = document.getElementById('club-hub-dynamic-content');
  if(!container) return;
  if(tab === 'quests')        renderHubQuests(container);
  else if(tab === 'tactic')   renderHubTactic(container);
  else if(tab === 'card')     renderHubCard(container);
  else if(tab === 'manager')  renderHubManager(container);
}


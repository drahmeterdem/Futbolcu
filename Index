function playSpecialShotCinematic(shot, callback) {
  const modal = document.getElementById('special-shot-cinematic');
  const bg = document.getElementById('ssc-bg');
  const title = document.getElementById('ssc-title');
  const icon = document.getElementById('ssc-icon');
  const subtitle = document.getElementById('ssc-subtitle');
  const spirit = document.getElementById('ssc-spirit');

  // Şut rengini tüm öğelere uygula
  bg.style.background = `radial-gradient(ellipse at center, ${shot.color}80, rgba(0,0,0,0.97) 80%)`;
  icon.style.color = shot.color;
  icon.textContent = shot.emoji;
  title.textContent = shot.name;
  title.style.color = 'white';
  title.style.textShadow = `4px 4px 0 var(--bg-0), -2px -2px 0 var(--bg-0), 0 0 24px ${shot.color}, 0 0 48px ${shot.color}`;
  subtitle.textContent = shot.desc.toUpperCase();

  // v12: Hayvan ruhu — şut tipine göre değişir
  spirit.className = 'ssc-spirit ' + shot.id;
  spirit.textContent = SPECIAL_SHOT_SPIRITS[shot.id] || shot.emoji;

  modal.classList.remove('zooming-out');
  modal.classList.add('active');
  SFX.levelup();

  // v12: Ekran sallaması (cinematic başlangıcında)
  shakeScreen();

  // v12: Top yangın izi - 8 ghost top arkada bırak
  const trail = document.getElementById('ssc-fireball-trail');
  for (let i = 0; i < 8; i++) {
    setTimeout(() => {
      const ghost = document.createElement('div');
      ghost.className = 'ssc-fireball-ghost';
      ghost.style.background = `radial-gradient(circle, ${shot.color}, transparent 70%)`;
      // Top'un yolu boyunca yerleştir
      const progress = i / 8;
      ghost.style.left = (5 + progress * 70) + 'vw';
      ghost.style.top = (35 + Math.sin(progress * Math.PI) * -5) + '%';
      modal.appendChild(ghost);
      setTimeout(() => ghost.remove(), 600);
    }, 700 + i * 50);
  }

  // Partikül patlaması (zenginleştirildi - 24 partikül 3 dalga)
  const totalParticles = 24;
  for (let wave = 0; wave < 3; wave++) {
    for (let i = 0; i < totalParticles; i++) {
      setTimeout(() => {
        const p = document.createElement('div');
        p.className = 'ssc-particle';
        p.style.color = shot.color;
        p.style.left = '50%';
        p.style.top = '50%';
        const angle = (Math.PI * 2 * i) / totalParticles + (wave * 0.2);
        const dist = 180 + Math.random() * 150 + wave * 50;
        p.style.setProperty('--dx', `${Math.cos(angle) * dist}px`);
        p.style.setProperty('--dy', `${Math.sin(angle) * dist}px`);
        modal.appendChild(p);
        setTimeout(() => p.remove(), 1400);
      }, 600 + wave * 200 + i * 20);
    }
  }

  // 2.8 saniye sonra zoom out animasyonu başlat
  setTimeout(() => {
    modal.classList.add('zooming-out');
  }, 2400);

  // 3.2 saniye sonra modal kapat, callback çağır
  setTimeout(() => {
    modal.classList.remove('active', 'zooming-out');
    // Tüm dinamik öğeleri temizle
    modal.querySelectorAll('.ssc-particle, .ssc-fireball-ghost').forEach(e => e.remove());
    if (callback) callback();
  }, 3000);
}


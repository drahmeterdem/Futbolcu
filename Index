function processPassResult(teammate) {
  const eventEl = document.getElementById('match-event');
  const decisionDiv = document.getElementById('match-decisions');

  // Pas isabet şansı — pas stat + arkadaşın durumu
  const pasStat = state.pas || state.skill;
  let baseAccuracy = (pasStat / 100) * 0.9;

  if (teammate.status === 'free') baseAccuracy *= 1.1;
  else if (teammate.status === 'pressed') baseAccuracy *= 0.85;
  else baseAccuracy *= 0.6; // tehlikede — top kaybetme şansı yüksek

  const passSuccess = Math.random() < baseAccuracy;

  if (!passSuccess) {
    eventEl.className = 'match-event fail';
    eventEl.textContent = `❌ Pas kesildi! Rakip kapı önünde...`;
    matchCtx.oppPressure = Math.min(1.0, matchCtx.oppPressure + 0.15);
    // Rakibe gol şansı
    setTimeout(() => simulateOppMove(0.4), 1500);
  } else {
    // İyi pas — arkadaşın gol şansı
    const teamGoalChance = (teammate.skill / 100) * teammate.pos.goalMod * 0.4;
    const adjustedChance = teamGoalChance * (teammate.status === 'free' ? 1.3 : 0.8);

    if (Math.random() < adjustedChance) {
      matchCtx.myGoals++;
      showGoalFlash();
      addTsubasaBar(1); // v11: asist = +1 bar
      setTimeout(() => {
        const scoreEl = document.getElementById('match-my-score');
        scoreEl.textContent = matchCtx.myGoals;
        scoreEl.classList.remove('scored');
        void scoreEl.offsetWidth;
        scoreEl.classList.add('scored');
        eventEl.className = 'match-event gol';
        eventEl.textContent = `⚽ ${matchCtx.minute}' ${teammate.name.toUpperCase()} GOL! Asist senden!`;
      }, 400);
      // Asist sayılır — şöhret artar
      state.fame = clamp(state.fame + 2);
    } else {
      eventEl.className = 'match-event';
      eventEl.textContent = `${teammate.name} aldı, hücum sürüyor...`;
      matchCtx.oppPressure = Math.max(0.2, matchCtx.oppPressure - 0.05);
    }
  }

  setTimeout(() => {
    decisionDiv.style.display = 'none';
    triggerNextEvent();
  }, 2400);
}


// 17-20 hızlı, 21-26 plato, 27-30 zirve, 31+ düşüş
function getAgeStatMod(statName){
  const age = state.age || 17;
  if(age <= 20) return 1.0; // Genç dönemde stat zaten düşük, eğri etkilemez
  if(age <= 26) return 1.0;
  if(age <= 30) return 1.03; // zirve
  if(age <= 33) return 0.95;
  if(age <= 35) return 0.88;
  return 0.80;
}

// Sezon sonu yaş bazlı stat değişimi
function applyAgeProgression(){
  const age = state.age;
  let delta = 0;
  if(age <= 20)      delta = 3 + Math.floor(Math.random()*3); // +3 to +5
  else if(age <= 26) delta = 1 + Math.floor(Math.random()*2); // +1 to +2
  else if(age <= 30) delta = Math.random() < 0.5 ? 1 : 0;
  else if(age <= 33) delta = -(1 + Math.floor(Math.random()*2));
  else               delta = -(2 + Math.floor(Math.random()*2));

  if(delta !== 0){
    ['sut','pas','defans','hiz'].forEach(s => {
      if(state[s] !== undefined){
        state[s] = Math.max(20, Math.min(99, state[s] + delta));
      }
    });
    // skill toplamı da güncellenir
    if(state.skill !== undefined){
      state.skill = Math.max(20, Math.min(99, state.skill + delta));
    }
    return delta;
  }
  return 0;
}


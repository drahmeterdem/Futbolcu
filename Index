function showSkillTree() {
  document.getElementById('skill-points-value').textContent = state.skillPoints;
  const tree = document.getElementById('skill-tree');
  tree.innerHTML = '';
  SKILLS_TREE.forEach(s => {
    const node = document.createElement('div');
    const unlocked = state.unlockedSkills.includes(s.id);
    const depsOk = s.deps.every(d => state.unlockedSkills.includes(d));
    const canUnlock = depsOk && state.skillPoints >= s.cost && !unlocked;
    let cls = 'skill-node';
    if (unlocked) cls += ' unlocked';
    else if (canUnlock) cls += ' available';
    else cls += ' locked';
    node.className = cls;
    node.innerHTML = `
      <div class="skill-node-icon">${s.icon}</div>
      <div class="skill-node-name">${s.name}</div>
      <div class="skill-node-cost">${unlocked ? '✓ AÇILDI' : `${s.cost} PUAN`}</div>
    `;
    if (canUnlock) {
      node.addEventListener('click', () => {
        if (actionLock) return;
        lock();
        state.unlockedSkills.push(s.id);
        state.skillPoints -= s.cost;
        SFX.levelup();
        showSkillTree();
        updateUI();
      });
    }
    tree.appendChild(node);
  });
}

function getSkillBonus(type) {
  let bonus = 0;
  if (type === 'goal' && state.unlockedSkills.includes('shooter1')) bonus += 5;
  if (type === 'goal' && state.unlockedSkills.includes('shooter2')) bonus += 10;
  if (type === 'fame' && state.unlockedSkills.includes('magnet')) bonus += 50;
  if (type === 'ad' && state.unlockedSkills.includes('businessman')) bonus += 100;
  if (type === 'all' && state.unlockedSkills.includes('legend1')) bonus += 10;
  if (type === 'all' && state.unlockedSkills.includes('leader')) bonus += 10;
  if (type === 'injury' && state.unlockedSkills.includes('iron')) bonus += 50;
  return bonus;
}


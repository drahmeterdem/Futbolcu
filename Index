// Sezon sonu butonuna basınca yeni sezon hazırlanır.
// Bu mantığı endSeason'dan ayırdık çünkü oyuncu modal'ı incelerken
// yeni sezonun tetiklenmesini istemiyoruz — kontrol kullanıcıda olmalı.
function startNewSeason() {
  document.getElementById('season-end-modal').classList.remove('active');

  // ── V13: TERFİ / DÜŞME ─────────────────────────────────────
  try {
    if (typeof V13 !== 'undefined' && state.leagueStats && state.leagueStats.length > 0) {
      const sortedTable = [...state.leagueStats].sort((a, b) => b.pts - a.pts || (b.gf - b.ga) - (a.gf - a.ga));
      const myRank = sortedTable.findIndex(t => t.isMe) + 1;
      const totalTeams = sortedTable.length;
      const me = V13.ALL_TEAMS[state.teamIndex];
      if (me) {
        const myTier = me.tier;
        // 1. sıra ve tier > 1 → bir üst lige terfi
        if (myRank === 1 && myTier > 1) {
          const upperTier = myTier - 1;
          const sameCountryUpper = V13.ALL_TEAMS
            .map((t, i) => ({t, i}))
            .filter(x => x.t.country === me.country && x.t.tier === upperTier);
          if (sameCountryUpper.length > 0) {
            // Üst lig sonuncusunu bul ve sen onun yerine geç (1-1 mübadele yok, sadece basit terfi)
            // Basit: ilk üst lig takımına geç ve onun country+tier'ını koru
            const newSpot = sameCountryUpper[Math.floor(Math.random()*sameCountryUpper.length)];
            V13.ALL_TEAMS[state.teamIndex] = {...me, tier: upperTier};
            addNews(`📈 TERFİ! ${me.name} ${V13.TIER_NAMES[upperTier].name}'ne yükseldi`);
            setTimeout(() => {
              try { showCinematicNews({
                tag: 'TARİHİ BAŞARI',
                icon: '📈',
                title: `<span>${me.name}</span> TERFİ ETTİ`,
                subtitle: `${V13.TIER_NAMES[upperTier].name}'nde mücadele edeceksin.`,
                type: 'gold',
              }); } catch(e) {}
            }, 800);
          }
        }
        // Son 3 sıra ve tier < 3 → bir alt lige düş
        else if (myRank >= totalTeams - 2 && myTier < 3) {
          const lowerTier = myTier + 1;
          V13.ALL_TEAMS[state.teamIndex] = {...me, tier: lowerTier};
          addNews(`📉 DÜŞME! ${me.name} ${V13.TIER_NAMES[lowerTier].name}'ne düştü`);
          setTimeout(() => {
            try { showCinematicNews({
              tag: 'HAYAL KIRIKLIĞI',
              icon: '📉',
              title: `<span>${me.name}</span> DÜŞTÜ`,
              subtitle: `Sonraki sezon ${V13.TIER_NAMES[lowerTier].name}'nde.`,
              type: 'red',
            }); } catch(e) {}
          }, 800);
        }
        // Tier 1 şampiyon → Avrupa
        else if (myRank === 1 && myTier === 1) {
          state.europeanCupYear = (state.europeanCupYear||0) + 1;
          addNews(`🏆 ${me.name} AVRUPA KUPASI'na gidiyor!`);
        }
      }
    }
  } catch(e){ console.warn('v13 promotion err', e); }
  // ───────────────────────────────────────────────────────────

  state.week = 1;
  state.season++;
  state.age++;
  state.day = 1;
  state.seasonStartGoals = state.goals;
  // v9: tarih sonraki sezon başlangıcına (1 Ağustos) sıfırlanır
  const newSeasonYear = 2025 + (state.season - 1);
  state.gameDate = `${newSeasonYear}-08-01`;

  // v9: pending transfer (gizli görüşme onayı) varsa şimdi gerçekleşir
  if (state.pendingTransferTeam) {
    let newIdx = TEAMS.findIndex(t => t === state.pendingTransferTeam);
    if (newIdx === -1) {
      TEAMS.push(state.pendingTransferTeam);
      newIdx = TEAMS.length - 1;
    }
    const oldTeam = TEAMS[state.teamIndex];
    state.teamIndex = newIdx;
    state.transfers++;
    state.chemistry = 35;
    addNews(`✈️ ${state.name} transfer oldu: ${oldTeam} → ${state.pendingTransferTeam}`);
    setTimeout(() => showCinematicNews({
      tag: 'TRANSFER GERÇEKLEŞTİ',
      icon: '✈️',
      title: `${state.name.split(' ')[0]} <span>${state.pendingTransferTeam}</span>'A`,
      subtitle: `Gizli görüşmedeki anlaşma resmiyet kazandı.`,
      type: 'gold',
    }), 600);
    state.pendingTransferTeam = null;
    initLeague();
    save();
    return; // pending varsa diğer transfer teklifini sun ma
  }

  // Transfer teklifi şansı (normal akış)
  if (state.fame > 60 && Math.random() < 0.4) {
    setTimeout(() => offerTransfer(), 600);
  }

  initLeague();
  if (state.age >= 35) checkRetirement();
  updateUI();
  save();
}

function offerTransfer() {
  const newTeamIdx = (state.teamIndex + 1 + Math.floor(Math.random() * 5)) % TEAMS.length;
  const newTeam = TEAMS[newTeamIdx];
  const fee = 5000 + state.skill * 100;
  showConfirm(
    'Transfer Teklifi',
    `${newTeam} sana $${fee.toLocaleString()} teklif verdi. Kabul edesin mi?`,
    () => {
      state.teamIndex = newTeamIdx;
      state.transfers++;
      state.money += fee;
      state.fame = clamp(state.fame + 15);
      state.chemistry = 30;
      addNews(`💸 ${state.name} → ${newTeam}!`);
      showMessage(`Yeni takım: ${newTeam}`, 'event');
      initLeague();
      updateUI();
    }
  );
}


// ────────────────────────────────────────────────────────────────────
// MAÇ MOTORU INTEGRATION: monkey-patch wrappers
// ────────────────────────────────────────────────────────────────────
function patchExisting(){
 try {
  // 1) playMatch sarmalı — taktik + hava değiştiriciler matchCtx'e eklensin
  if(typeof window.playMatch === 'function' && !window.playMatch.__v13){
    const orig = window.playMatch;
    window.playMatch = function(){
      try {
        // Hava değişimi her hafta - daha gerçekçi
        const r = orig.apply(this, arguments);
        // matchCtx oluşturulduktan sonra v13 mod'larını ekle
        if(typeof matchCtx !== 'undefined' && matchCtx){
          const form = getFormation();
          matchCtx.v13_formationGoalBoost  = form.goalBoost || 1.0;
          matchCtx.v13_formationDefBoost   = form.defenseBoost || 1.0;
          matchCtx.v13_overallRating       = getOverallRating();
          // Hava açıklama olarak match event'e küçük not
          const w = WEATHER_EFFECTS[state.weather];
          if(w && state.weather !== 'sun' && state.weather !== 'cloud'){
            setTimeout(()=>{
              const evEl = document.getElementById('match-event');
              if(evEl){
                const note = document.createElement('div');
                note.style.cssText = 'font-size:11px;color:#aab;margin-top:4px;';
                note.textContent = w.label;
                if(!evEl.querySelector('.v13-weather-note')){
                  note.className = 'v13-weather-note';
                  evEl.appendChild(note);
                }
              }
            }, 80);
          }
        }
        return r;
      } catch(e){ console.warn('v13 playMatch patch err:', e); return orig.apply(this, arguments); }
    };
    window.playMatch.__v13 = true;
  }

  // 2) endMatch sarmalı — gazete manşeti + görev takibi + win streak + manager komisyonu
  if(typeof window.endMatch === 'function' && !window.endMatch.__v13){
    const orig = window.endMatch;
    window.endMatch = function(){
      let r;
      try {
        const myG = (typeof matchCtx!=='undefined') ? matchCtx.myGoals : 0;
        const oppG = (typeof matchCtx!=='undefined') ? matchCtx.oppGoals : 0;
        const myTeam = (typeof matchCtx!=='undefined' && matchCtx.myTeam) ? matchCtx.myTeam : '—';
        const oppTeam = (typeof matchCtx!=='undefined' && matchCtx.oppTeam) ? matchCtx.oppTeam : '—';

        // Win streak
        if(myG > oppG){ state.currentWinStreak = (state.currentWinStreak||0) + 1; }
        else { state.currentWinStreak = 0; }

        // Orig çalıştır (state.matches vb. güncelliyor)
        r = orig.apply(this, arguments);

        // Gazete manşeti — maçtan 2sn sonra
        setTimeout(()=>{
          try{
            const headline = generateHeadline(myG, oppG, myTeam, oppTeam);
            showNewspaperHeadline(headline, myG, oppG, myTeam, oppTeam);
          }catch(e){ console.warn('v13 headline error', e); }
        }, 2200);

        // Görev güncellemesi
        try { trackQuestProgress(); } catch(e){}
        return r;
      } catch(e){
        console.warn('v13 endMatch patch err:', e);
        return r !== undefined ? r : orig.apply(this, arguments);
      }
    };
    window.endMatch.__v13 = true;
  }

  // 3) train sarmalı — mini-oyun + görev sayacı
  if(typeof window.train === 'function' && !window.train.__v13){
    const orig = window.train;
    window.train = function(type){
      try {
        // Mini-oyun yalnızca cardio/technique/tactic'te
        const miniTypes = ['cardio','technique','tactic'];
        if(miniTypes.includes(type) && state && !state.injured && state.energy >= 15){
          showMiniGame(type, (bonus, score, accuracy)=>{
            try {
              if(bonus > 0){
                const target = type==='cardio' ? 'hiz' : type==='technique' ? 'sut' : 'pas';
                if(state[target] !== undefined){
                  state[target] = Math.min(99, state[target] + bonus);
                  if(typeof showFloat==='function') showFloat(`+${bonus} ${target.toUpperCase()} (mini-oyun)`, false);
                }
              }
              state.questTrainCount = (state.questTrainCount||0) + 1;
              trackQuestProgress();
            } catch(e){ console.warn('v13 mini-game cb err:', e); }
            orig.call(this, type);
          });
          return;
        }
        // Normal akış
        const r = orig.apply(this, arguments);
        if(state){ state.questTrainCount = (state.questTrainCount||0) + 1; }
        try { trackQuestProgress(); } catch(e){}
        return r;
      } catch(e){ console.warn('v13 train patch err:', e); return orig.apply(this, arguments); }
    };
    window.train.__v13 = true;
  }

  // 4) startNewSeason sarmalı — yaş eğrisi + menajer yenileme
  if(typeof window.startNewSeason === 'function' && !window.startNewSeason.__v13){
    const orig = window.startNewSeason;
    window.startNewSeason = function(){
      let r;
      try {
        r = orig.apply(this, arguments);
        try{
          const delta = applyAgeProgression();
          if(delta !== 0 && typeof showMessage==='function'){
            if(delta > 0) showMessage(`📈 Yaş ${state.age}: statlar +${delta} (gelişim dönemi)`, 'event');
            else          showMessage(`📉 Yaş ${state.age}: statlar ${delta} (yaş düşüşü)`, 'warn');
          }
        }catch(e){ console.warn('age curve err', e); }
        if(state && state.managerChangeSeasonsLeft > 0) state.managerChangeSeasonsLeft--;
        if(state){ state.weeklyQuestsWeek = null; ensureWeeklyQuests(); }
        return r;
      } catch(e){ console.warn('v13 startNewSeason patch err:', e); return r; }
    };
    window.startNewSeason.__v13 = true;
  }

  // 5) updateUI sarmalı — quick panel garanti
  if(typeof window.updateUI === 'function' && !window.updateUI.__v13){
    const orig = window.updateUI;
    window.updateUI = function(){
      let r;
      try { r = orig.apply(this, arguments); }
      catch(e){ console.warn('orig updateUI err:', e); }
      try {
        if(typeof state !== 'undefined' && state && state.name && state.name.length > 0){
          injectV13QuickPanel();
        }
      } catch(e) { console.warn('v13 panel inject err:', e); }
      return r;
    };
    window.updateUI.__v13 = true;
  }
 } catch(e){ console.error('v13 patchExisting top-level err:', e); }
}


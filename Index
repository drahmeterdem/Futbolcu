    SFX.fail();
  }

  state.energy = clamp(state.energy - 30);
  state.fitness = clamp(state.fitness - 10);

  if (Math.random() < 0.06 - getSkillBonus('injury')/200) {
    setTimeout(triggerInjury, 1000);
  }

  updateMyLeagueStats(matchCtx.myGoals, matchCtx.oppGoals, matchCtx.oppIdx);
  simulateOtherMatches();

  if (matchCtx.myGoals >= 3) {
    addNews(`🔥 HAT-TRICK! ${state.name} 3 gol attı!`);

        type: 'gold',
      }), 3000);
    } else {
      setTimeout(() => showMessage(`🇹🇷 Milli takım maçı! +$1.500`, 'event'), 3000);
    }
  }

  state.week++;
  updateUI();
  checkAchievements();

  document.getElementById('match-final').style.display = 'block';

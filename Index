function ensureWeeklyQuests(){
  if(!state.weeklyQuests || !state.weeklyQuestsWeek || state.weeklyQuestsWeek !== state.week){
    // 3 yeni görev seç
    const shuffled = [...QUEST_TEMPLATES].sort(()=>Math.random()-0.5).slice(0,3);
    state.weeklyQuests = shuffled.map(q => ({...q, progress:0, done:false}));
    state.weeklyQuestsWeek = state.week;
    state.weeklyQuestSnapshot = {
      goals: state.goals, matches: state.matches, wins: state.wins,
    };
  }
}

function trackQuestProgress(){
  if(!state.weeklyQuests) return;
  state.weeklyQuests.forEach(q => {
    if(q.done) return;
    let cur = 0;
    const snap = state.weeklyQuestSnapshot || {};
    if(q.type === 'goals')        cur = state.goals - (snap.goals||0);
    else if(q.type === 'matches') cur = state.matches - (snap.matches||0);
    else if(q.type === 'winStreak') cur = state.currentWinStreak || 0;
    else if(q.type === 'trains')  cur = state.questTrainCount || 0;
    else if(q.type === 'assists') cur = state.questAssists || 0;
    else if(q.type === 'moodAtLeast') cur = state.mood;
    q.progress = cur;
    if(cur >= q.target){
      q.done = true;
      if(q.reward.coins) state.coins = (state.coins||0) + q.reward.coins;
      if(q.reward.money) state.money += q.reward.money;
      if(typeof showMessage==='function') showMessage(`✅ Görev tamam: ${q.name} +${q.reward.coins}🪙 +$${q.reward.money}`, 'event');
    }
  });
}


function watchAd(reward) {
  showMessage('📺 Reklam izleniyor (3sn)...', 'event');
  setTimeout(() => {
    const rewards = {
      energy: () => { state.energy = clamp(state.energy + 20); return '+20 ENERJİ'; },
      money: () => { state.money += 300; flashCurrency('money'); return '+$300'; },
      mood: () => { state.mood = clamp(state.mood + 20); return '+20 MORAL'; },
      heal: () => {
        if (state.injured) { state.injured = false; state.injuryDaysLeft = 0; return 'SAKATLIK GEÇTİ'; }

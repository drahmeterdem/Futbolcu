function endSeason() {
  // Önce sezon başında kaydedilen "snapshot"u kullanarak sezon farkını hesapla
  // Bu sayede "bu sezon" kazanılan gol/maç/para gösterilebilir.
  const sortedTable = [...state.leagueStats].sort((a, b) => b.pts - a.pts || (b.gf - b.ga) - (a.gf - a.ga));
  const myRank = sortedTable.findIndex(t => t.isMe) + 1;
  const myStats = sortedTable.find(t => t.isMe);

  // Sezon ödül parası (sıralamaya göre)
  let prize = 0;
  let isChampion = false;
  if (myRank === 1) { prize = 5000; isChampion = true; state.trophies++; }
  else if (myRank === 2) prize = 3000;
  else if (myRank === 3) prize = 2000;
  else if (myRank <= 5) prize = 1000;

  // v13: tier'a göre ödül çarpanı (Süper Lig=3x, 1. Lig=2x, 2. Lig=1x)
  try {
    const me = V13.ALL_TEAMS[state.teamIndex];
    if (me && V13.TIER_NAMES[me.tier]) {
      prize = Math.round(prize * V13.TIER_NAMES[me.tier].prizeMult);
    }
  } catch(e){}

  state.money += prize;

  // SEZON HIGHLIGHT — bu sezonun en çarpıcı anısı
  // Birden fazla aday varsa en güçlüsü seçilir.
  const seasonStartGoals = state.seasonStartGoals || 0;
  const goalsThisSeason = state.goals - seasonStartGoals;
  let highlight = `${state.matches} maçta ${goalsThisSeason} gol attın`;

  if (isChampion) highlight = `${TEAMS[state.teamIndex]} ile şampiyon oldun!`;
  else if (state.maxGoalsInMatch >= 3) highlight = `Hat-trick yaparak adını duyurdun`;
  else if (myRank <= 3) highlight = `Lig sıralamasında podyuma çıktın`;
  else if (state.nationalCaps > 0) highlight = `Milli formayı ${state.nationalCaps} kez giydin`;
  else if (goalsThisSeason >= 15) highlight = `${goalsThisSeason} gollük müthiş bir sezon`;
  else if (state.fame > 80) highlight = `Şöhretin tavan yaptı`;

  // Modal başlığı ve emoji sıraya göre değişir
  let icon = '⚽', title = 'SEZON BİTTİ', rankClass = '';

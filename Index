function injectV13QuickPanel(){
  const topbarRight = document.querySelector('.topbar-right');
  if(topbarRight && !document.getElementById('v13-btn-hub')){
    const hBtn = document.createElement('button');
    hBtn.className = 'icon-btn';
    hBtn.id = 'v13-btn-hub';
    hBtn.title = 'Kulüp & Strateji';
    hBtn.innerHTML = '⚡<span class="dot" id="v13-hub-dot" style="display:none;"></span>';
    hBtn.addEventListener('click', () => {
      if(typeof SFX!=='undefined' && SFX.click) SFX.click();
      openClubHub('quests');
    });
    // En başa koy (📰 öncesi)
    topbarRight.insertBefore(hBtn, topbarRight.firstChild);
  }

  // Tab pill event listener'larını bağla (bir kez)
  if(!window.__v13_tabsWired){
    const tabMap = { 'tab-hub-quests':'quests', 'tab-hub-tactic':'tactic', 'tab-hub-card':'card', 'tab-hub-manager':'manager' };
    Object.keys(tabMap).forEach(id => {
      const el = document.getElementById(id);
      if(el){
        el.addEventListener('click', () => {
          if(typeof SFX!=='undefined' && SFX.tick) SFX.tick();
          selectHubTab(tabMap[id]);
        });
      }
    });
    // modal-back butonu zaten data-close handler'ı ile çalışmalı; ama emniyet için
    const backBtn = document.querySelector('#modal-club-hub .modal-back');
    if(backBtn){
      backBtn.addEventListener('click', closeClubHub);
    }
    window.__v13_tabsWired = true;
  }

  // Eski FAB veya bireysel butonları temizle
  ['v13-quick-panel', 'v13-btn-quests', 'v13-btn-tactic'].forEach(id => {
    const el = document.getElementById(id);
    if(el) el.remove();
  });

  // Görev tamamlanma bildirimi
  updateQuestDot();
}

function updateQuestDot(){
  const dot = document.getElementById('v13-hub-dot');
  if(!dot) return;
  if(!state.weeklyQuests || state.weeklyQuests.length === 0){
    dot.style.display = 'none';
    return;
  }
  const hasUnclaimedDone = state.weeklyQuests.some(q => q.done && !q.claimed);
  dot.style.display = hasUnclaimedDone ? 'block' : 'none';
}


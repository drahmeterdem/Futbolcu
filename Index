function processCounterResult(technique) {
  const eventEl = document.getElementById('match-event');
  const decisionDiv = document.getElementById('match-decisions');

  const sutStat = state.sut || state.skill;
  const pasStat = state.pas || state.skill;
  const hizStat = state.hiz || state.skill;

  let goalChance, message;

  if (technique === 'solo') {
    // Solo: hız + şut
    const skill = (hizStat * 0.6 + sutStat * 0.4) / 100;
    goalChance = skill * 0.4 * matchCtx.luckyMod;
    if (Math.random() < goalChance) {
      matchCtx.myGoals++;
      message = `🏃 SOLO GOL! Tek başına filelere!`;
    } else if (Math.random() < 0.4) {
      message = `Dışarı çıktı, kaleci kapattı`;
    } else {
      message = `Defans yetişti, top kaybedildi`;
    }
  } else if (technique === 'passrun') {
    // Ver-al: pas + hız
    const skill = (pasStat * 0.5 + hizStat * 0.5) / 100;
    goalChance = skill * 0.5 * matchCtx.luckyMod;
    if (Math.random() < goalChance) {
      matchCtx.myGoals++;
      message = `🤝 VER-AL GOLU! Klasik kombinasyon!`;
    } else if (Math.random() < 0.5) {
      message = `Pas geri geldi, top sende`;
    } else {
      message = `Pas kesildi`;
    }
  } else if (technique === 'cross') {
    // Orta: pas önemli
    const skill = pasStat / 100;
    goalChance = skill * 0.35 * matchCtx.luckyMod;
    if (Math.random() < goalChance) {
      matchCtx.myGoals++;
      message = `↗️ ORTAYI KAFAYLA TAMAMLADI! Asist senden!`;
      state.fame = clamp(state.fame + 2);
    } else if (Math.random() < 0.4) {
      message = `Orta tehlikeli geldi ama vuran çıkmadı`;
    } else {
      message = `Orta uzun gitti`;
    }
  }

  // Gol olduysa skor güncelle
  const wasGoal = message.includes('GOL') || message.includes('GOLU');
  if (wasGoal) {
    showGoalFlash();
    setTimeout(() => {
      const scoreEl = document.getElementById('match-my-score');
      scoreEl.textContent = matchCtx.myGoals;
      scoreEl.classList.remove('scored');
      void scoreEl.offsetWidth;
      scoreEl.classList.add('scored');
    }, 600);
  }

  setTimeout(() => {
    eventEl.className = wasGoal ? 'match-event gol' : 'match-event';
    eventEl.textContent = message;
  }, 800);

  setTimeout(() => {
    decisionDiv.style.display = 'none';
    triggerNextEvent();
  }, 2600);
}

// ----- RAKİP HAREKETİ (her olaydan sonra rakibin gol şansı) -----
function simulateOppMove(chance = null) {
  const oppShansi = chance !== null ? chance : matchCtx.oppPressure * 0.25;
  const positionDefMod = (state.positionId === 'defans') ? 1.4 : 1.0;
  const finalChance = oppShansi / positionDefMod;

  if (Math.random() < finalChance) {
    matchCtx.oppGoals++;
    setTimeout(() => {
      const scoreEl = document.getElementById('match-opp-score');
      scoreEl.textContent = matchCtx.oppGoals;
      scoreEl.classList.remove('scored');
      void scoreEl.offsetWidth;
      scoreEl.classList.add('scored');
      // Geçici uyarı mesajı
      const eventEl = document.getElementById('match-event');
      const oldText = eventEl.textContent;
      const oldClass = eventEl.className;
      eventEl.className = 'match-event fail';
      eventEl.textContent = `⚠️ Rakipten gol! ${matchCtx.oppGoals}-${matchCtx.myGoals}`;
      setTimeout(() => {
        eventEl.className = oldClass;
        eventEl.textContent = oldText;
      }, 1800);
    }, 200);
  }
}


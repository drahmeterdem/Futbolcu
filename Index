<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="theme-color" content="#0a0e1a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>FUTBOLCUM • Pixel Career v5</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&family=Bebas+Neue&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  /* ===== RESET & BASE ===== */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
    -webkit-touch-callout: none;
  }

  :root {
    /* Layered dark theme */
    --bg-0: #050811;
    --bg-1: #0a0e1a;
    --bg-2: #141a2e;
    --bg-3: #1a2138;
    --bg-4: #232c47;
    --bg-5: #2d3858;

    /* Pitch */
    --pitch-1: #0d4d2a;
    --pitch-2: #1a6d3f;
    --pitch-light: #2d8a52;

    /* Brand colors */
    --accent: #00e5b0;
    --accent-dim: #00b88a;
    --accent-glow: rgba(0,229,176,0.4);
    --warm: #ffb800;
    --warm-glow: rgba(255,184,0,0.4);
    --danger: #ff3b5c;
    --danger-glow: rgba(255,59,92,0.4);
    --gold: #ffd700;
    --rose: #ff5e8e;
    --purple: #a78bfa;

    /* Text */
    --text: #f0f4fa;
    --text-dim: #8a93a8;
    --text-mute: #5a6378;

    /* Effects */
    --border: rgba(255,255,255,0.08);
    --border-strong: rgba(255,255,255,0.16);
    --glass: rgba(255,255,255,0.04);
    --glass-strong: rgba(255,255,255,0.08);

    /* Shadows */
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.3);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.4);
    --shadow-lg: 0 8px 32px rgba(0,0,0,0.5);
    --shadow-glow: 0 0 24px var(--accent-glow);
  }

  html, body {
    height: 100%;
    height: 100dvh; /* iOS Safari adres çubuğu için dinamik viewport */
    overflow: hidden;
    overscroll-behavior: none;
    background: var(--bg-0);
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--text);
    user-select: none;
    -webkit-user-select: none;
    position: fixed;
    inset: 0;
  }

  /* ===== BACKGROUND ANIMATION ===== */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse at top, rgba(0,229,176,0.08), transparent 60%),
      radial-gradient(ellipse at bottom, rgba(167,139,250,0.05), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ===== APP CONTAINER ===== */
  .app {
    width: 100%;
    height: 100%;
    max-width: 480px;
    margin: 0 auto;
    background: linear-gradient(180deg, var(--bg-2) 0%, var(--bg-0) 100%);
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    z-index: 1;
    min-height: 0;
  }
  /* Action-bar her zaman dipte sabit kalsın */
  .app > .action-bar { margin-top: auto; }

  @media (min-width: 600px) {
    .app {
      max-width: 420px;
      box-shadow: 0 0 80px rgba(0,0,0,0.8), 0 0 0 1px var(--border);
      border-radius: 28px;
      margin: 20px auto;
      height: calc(100% - 40px);
    }
  }

  /* ===== TOP BAR ===== */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px 6px;
    z-index: 10;
    flex-shrink: 0;
    padding-top: max(12px, env(safe-area-inset-top));
  }

  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    color: var(--accent);
    letter-spacing: 2.5px;
    line-height: 1;
    text-shadow: 0 0 12px var(--accent-glow);
  }
  .logo span { color: var(--warm); }

  .topbar-right {
    display: flex;
    gap: 4px;
    align-items: center;
    flex-wrap: nowrap;
  }

  .icon-btn {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    color: var(--text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    position: relative;
    transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }
  @media (max-width: 380px) {
    .icon-btn { width: 30px; height: 30px; font-size: 14px; }
    .topbar-right { gap: 3px; }
    .topbar { padding: 10px 10px 4px; }
    .logo { font-size: 20px; }
  }
  .icon-btn:active {
    transform: scale(0.88);
    background: var(--glass-strong);
  }
  .icon-btn .dot {
    position: absolute;
    top: 5px; right: 5px;
    width: 8px; height: 8px;
    background: var(--danger);
    border-radius: 50%;
    border: 2px solid var(--bg-1);
    box-shadow: 0 0 6px var(--danger-glow);
    animation: dotPulse 2s ease-in-out infinite;
  }
  @keyframes dotPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }

  /* ===== CURRENCY BAR ===== */
  .currency-bar {
    display: flex;
    gap: 10px;
    padding: 0 16px 10px;
  }

  .currency {
    flex: 1;
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s;
  }
  .currency::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.04) 50%, transparent 70%);
    pointer-events: none;
  }
  .currency.flash {
    animation: currencyFlash 0.5s ease-out;
  }
  @keyframes currencyFlash {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); box-shadow: 0 0 20px var(--accent-glow); }
    100% { transform: scale(1); }
  }

  .currency-icon {
    width: 26px; height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    flex-shrink: 0;
    color: white;
  }
  .currency-money .currency-icon {
    background: linear-gradient(135deg, #2dba76, #1a8c54);
    box-shadow: 0 2px 8px rgba(45,186,118,0.3);
  }
  .currency-coin .currency-icon {
    background: linear-gradient(135deg, #ffd54f, #ff9800);
    box-shadow: 0 2px 8px rgba(255,184,0,0.3);
  }
  .currency-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 0.5px;
  }

  /* ===== STAGE / PITCH ===== */
  .stage-card {
    margin: 0 16px;
    background: linear-gradient(180deg, var(--pitch-2) 0%, var(--pitch-1) 100%);
    border-radius: 24px;
    position: relative;
    overflow: hidden;
    height: 280px;
    flex-shrink: 1;
    min-height: 180px;
    box-shadow: var(--shadow-lg), inset 0 1px 0 rgba(255,255,255,0.1);
    transition: background 0.6s ease;
  }
  /* Küçük ekran: stage-card kısalsın ki action-bar görünsün */
  @media (max-height: 740px) {
    .stage-card { height: 240px; }
  }
  @media (max-height: 680px) {
    .stage-card { height: 200px; }
    .stats-panel { margin: 8px 16px; padding: 10px 12px; gap: 8px 14px; }
    .message-bar { margin: 0 16px 8px; padding: 8px 14px; font-size: 12px; }
    .action-bar { padding: 8px 12px calc(10px + env(safe-area-inset-bottom)); gap: 8px; }
    .action-btn { padding: 8px 4px; }
    .action-btn .icon { font-size: 20px; }
    .currency-bar { padding: 4px 16px 8px; }
  }
  @media (max-height: 600px) {
    .stage-card { height: 170px; min-height: 160px; }
    .stats-panel { padding: 8px 10px; gap: 6px 12px; }
    .stat-value { font-size: 15px; }
    .stat-name { font-size: 10px; }
    .message-bar { padding: 6px 12px; font-size: 11px; }
    .topbar { padding: 6px 12px 4px; }
  }

  /* v10: Daha zengin çim deseni — 6 farklı şeritle gerçekçi pitch görünümü */
  .stage-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(90deg,
        transparent 0,
        transparent 30px,
        rgba(255,255,255,0.05) 30px,
        rgba(255,255,255,0.05) 32px,
        transparent 32px,
        transparent 60px,
        rgba(0,0,0,0.08) 60px,
        rgba(0,0,0,0.08) 62px);
    pointer-events: none;
  }

  /* v10: Saha çizgileri overlay'i — ceza sahası, orta çizgi, korner çeyrekleri */
  .pitch-lines-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  .pitch-line {
    position: absolute;
    background: rgba(255,255,255,0.4);
    box-shadow: 0 0 3px rgba(255,255,255,0.3);
  }
  /* Orta çizgi (yatay, sahada ortada) */
  .pitch-line-center {
    top: 50%;
    left: 0; right: 0;
    height: 1px;
  }
  /* Ceza sahası (alt) */
  .pitch-line-box-bottom {
    bottom: 18px;
    left: 25%;
    right: 25%;
    height: 36px;
    border: 1px solid rgba(255,255,255,0.4);
    border-bottom: none;
    background: transparent;
    box-shadow: none;
  }
  /* Korner çeyrekleri (alt köşeler) */
  .pitch-line-corner {
    position: absolute;
    bottom: 12px;
    width: 12px;
    height: 12px;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 0 0 0 12px;
    background: transparent;
  }
  .pitch-line-corner.left { left: 8px; }
  .pitch-line-corner.right {
    right: 8px;
    border-radius: 0 0 12px 0;
    border-left: none;
    border-right: 1px solid rgba(255,255,255,0.4);
  }
  .pitch-line-corner.right.left-side {
    right: auto;
    left: 8px;
  }

  /* Subtle vignette */
  .stage-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center,
      transparent 30%,
      rgba(0,0,0,0.25) 95%);
    pointer-events: none;
  }

  .stage-card.weather-rain {
    background: linear-gradient(180deg, #2a4d5e 0%, #1f3d4d 100%);
  }
  .stage-card.weather-snow {
    background: linear-gradient(180deg, #6b7d8e 0%, #4a5b6b 100%);
  }
  .stage-card.weather-cloud {
    background: linear-gradient(180deg, #3a5a4a 0%, #1a4d2e 100%);
  }

  .pitch-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 110px; height: 55px;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    box-shadow: 0 0 3px rgba(255,255,255,0.2);
  }

  .stage-info {
    position: absolute;
    top: 12px;
    left: 14px;
    right: 14px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    z-index: 5;
    pointer-events: none;
    gap: 6px;
    flex-wrap: wrap;
  }

  .player-tag {
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 7px 12px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 15px;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .player-tag .age {
    color: var(--accent);
    font-weight: 600;
  }
  .player-tag .pos {
    background: var(--accent);
    color: var(--bg-0);
    padding: 2px 5px;
    border-radius: 5px;
    font-size: 11px;
    font-weight: 700;
  }

  .player-badges {
    display: flex;
    gap: 5px;
    pointer-events: none;
  }
  .player-badge {
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    width: 30px; height: 30px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    animation: badgePop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes badgePop {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  .player-badge.gold {
    background: linear-gradient(135deg, rgba(255,215,0,0.3), rgba(255,184,0,0.2));
    border-color: var(--gold);
    box-shadow: 0 0 12px rgba(255,215,0,0.3);
  }
  .player-badge.danger {
    background: rgba(255,59,92,0.25);
    border-color: var(--danger);
  }
  .player-badge.lucky {
    background: linear-gradient(135deg, rgba(0,229,176,0.3), rgba(0,184,138,0.2));
    border-color: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
    animation: luckySpin 3s linear infinite;
  }
  @keyframes luckySpin {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(360deg); }
  }

  /* Player character with shadow */
  .player-wrapper {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
  }
  .player-shadow {
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 10px;
    background: radial-gradient(ellipse, rgba(0,0,0,0.5), transparent 75%);
    pointer-events: none;
    animation: shadowPulse 1.4s ease-in-out infinite;
  }
  @keyframes shadowPulse {
    0%, 100% { transform: translateX(-50%) scaleX(1); opacity: 0.6; }
    50% { transform: translateX(-50%) scaleX(0.82); opacity: 0.8; }
  }

  .player {
    position: relative;
    width: 66px;
    height: 88px;
    animation: idle 1.4s ease-in-out infinite;
    image-rendering: pixelated;
  }
  .player.sleeping { animation: sleep 2.4s ease-in-out infinite; }
  .player.tired { animation: tired 1.8s ease-in-out infinite; opacity: 0.7; filter: saturate(0.5); }
  .player.happy { animation: happy 0.6s cubic-bezier(0.36, 0, 0.66, 1) infinite; }
  .player.training { animation: training 0.4s ease-in-out infinite; }
  .player.injured {
    animation: injured 1s ease-in-out infinite;
    filter: hue-rotate(-30deg) brightness(0.8);
  }
  .player.celebrating { animation: celebrate 0.5s cubic-bezier(0.36, 0, 0.66, 1) infinite; }

  /* MAÇ SIRASI HAREKETLERİ
     Eski v5'te oyuncu maç sırasında sadece olduğu yerde zıplıyordu.
     Şimdi 3 yeni sınıf var:
     - running-right / running-left: yatay koşma + omuz sallaması
     - charging: hücuma kalkma, ileri eğilme + hızlı koşu
     - dribble: top sürerken küçük adım adım sallama
  */
  .player.running-right { animation: runRight 0.5s ease-in-out infinite; }
  .player.running-left { animation: runLeft 0.5s ease-in-out infinite; }
  .player.charging { animation: charging 0.35s ease-in-out infinite; }
  .player.dribble { animation: dribble 0.4s ease-in-out infinite; }

  @keyframes runRight {
    0%, 100% { transform: translateX(0) translateY(0) rotate(-3deg); }
    25% { transform: translateX(10px) translateY(-3px) rotate(0deg); }
    50% { transform: translateX(20px) translateY(0) rotate(3deg); }
    75% { transform: translateX(30px) translateY(-3px) rotate(0deg); }
  }
  @keyframes runLeft {
    0%, 100% { transform: translateX(0) translateY(0) rotate(3deg); }
    25% { transform: translateX(-10px) translateY(-3px) rotate(0deg); }
    50% { transform: translateX(-20px) translateY(0) rotate(-3deg); }
    75% { transform: translateX(-30px) translateY(-3px) rotate(0deg); }
  }
  @keyframes charging {
    0%, 100% { transform: translateY(0) scale(1.05) rotate(-2deg); }
    50% { transform: translateY(-6px) scale(1.08) rotate(2deg); }
  }
  @keyframes dribble {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-2px) rotate(1deg); }
  }

  @keyframes idle {
    0%, 100% { transform: translateY(0) scale(1, 1); }
    50% { transform: translateY(-4px) scale(1, 1.02); }
  }
  @keyframes sleep {
    0%, 100% { transform: translateY(2px) rotate(-4deg); }
    50% { transform: translateY(0) rotate(4deg); }
  }
  @keyframes tired {
    0%, 100% { transform: translateY(0) scaleY(1); }
    50% { transform: translateY(-1px) scaleY(0.98); }
  }
  @keyframes happy {
    0%, 100% { transform: translateY(0) scale(1, 1); }
    50% { transform: translateY(-12px) scale(1.05, 0.95); }
  }
  @keyframes training {
    0%, 100% { transform: translateX(-3px) rotate(-2deg); }
    50% { transform: translateX(3px) rotate(2deg); }
  }
  @keyframes injured {
    0%, 100% { transform: rotate(-6deg) scale(0.95); }
    50% { transform: rotate(6deg) scale(0.95); }
  }
  @keyframes celebrate {
    0% { transform: translateY(0) rotate(0deg) scale(1); }
    25% { transform: translateY(-18px) rotate(-10deg) scale(1.15); }
    50% { transform: translateY(-4px) rotate(0deg) scale(1.1); }
    75% { transform: translateY(-22px) rotate(10deg) scale(1.15); }
    100% { transform: translateY(0) rotate(0deg) scale(1); }
  }

  .pixel-art {
    position: absolute;
    width: 4px;
    height: 4px;
  }

  .companion-wrapper {
    position: absolute;
    bottom: 24px;
    right: 22%;
    z-index: 3;
    display: none;
  }
  .companion-wrapper.show { display: block; }
  .companion {
    position: relative;
    width: 48px;
    height: 60px;
    animation: idle 1.6s ease-in-out infinite;
    animation-delay: -0.2s;
    image-rendering: pixelated;
  }
  .companion-shadow {
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 42px;
    height: 8px;
    background: radial-gradient(ellipse, rgba(0,0,0,0.3), transparent 70%);
    animation: shadowPulse 1.6s ease-in-out infinite;
    animation-delay: -0.2s;
  }

  /* Thought bubble */
  .thought {
    position: absolute;
    bottom: 110px;
    left: calc(50% + 38px);
    font-size: 24px;
    z-index: 5;
    opacity: 0;
    pointer-events: none;
    animation: thoughtFloat 2.5s ease-in-out infinite;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
  }
  .thought.show { opacity: 1; }
  @keyframes thoughtFloat {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.85; }
    50% { transform: translateY(-6px) scale(1.05); opacity: 1; }
  }

  /* Weather effects */
  .weather-fx {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    overflow: hidden;
    border-radius: 24px;
  }
  .raindrop {
    position: absolute;
    width: 1.5px; height: 14px;
    background: linear-gradient(180deg, transparent, rgba(180,200,220,0.6));
    animation: rain 0.55s linear infinite;
  }
  @keyframes rain {
    0% { transform: translateY(-20px); }
    100% { transform: translateY(300px); }
  }
  .snowflake {
    position: absolute;
    color: white;
    font-size: 11px;
    animation: snow 4s linear infinite;
    opacity: 0.85;
    text-shadow: 0 0 4px rgba(255,255,255,0.5);
  }
  @keyframes snow {
    0% { transform: translateY(-20px) translateX(0) rotate(0deg); }
    100% { transform: translateY(300px) translateX(30px) rotate(360deg); }
  }
  .sun {
    position: absolute;
    top: 18px;
    right: 70px;
    width: 28px; height: 28px;
    border-radius: 50%;
    background: radial-gradient(circle, #fff5b8, var(--gold) 50%, var(--warm));
    box-shadow: 0 0 24px var(--gold), 0 0 40px var(--warm-glow);
    animation: sunpulse 3s ease-in-out infinite;
  }
  @keyframes sunpulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }
  .cloud {
    position: absolute;
    top: 16px;
    width: 50px; height: 18px;
    background: rgba(255,255,255,0.4);
    border-radius: 20px;
    animation: cloudDrift 20s linear infinite;
  }
  .cloud::before, .cloud::after {
    content: '';
    position: absolute;
    background: rgba(255,255,255,0.4);
    border-radius: 50%;
  }
  .cloud::before {
    width: 24px; height: 24px;
    top: -8px; left: 8px;
  }
  .cloud::after {
    width: 18px; height: 18px;
    top: -6px; left: 24px;
  }
  @keyframes cloudDrift {
    0% { transform: translateX(-60px); }
    100% { transform: translateX(450px); }
  }

  /* Stadium fans */
  .stadium-fans {
    position: absolute;
    top: 56px;
    left: 0; right: 0;
    display: none;
    justify-content: space-around;
    font-size: 16px;
    z-index: 1;
    opacity: 0.9;
    pointer-events: none;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.4));
  }
  .stadium-fans.show { display: flex; }
  .stadium-fans span {
    animation: cheering 0.6s ease-in-out infinite;
  }
  .stadium-fans span:nth-child(2) { animation-delay: 0.1s; }
  .stadium-fans span:nth-child(3) { animation-delay: 0.2s; }
  .stadium-fans span:nth-child(4) { animation-delay: 0.3s; }
  .stadium-fans span:nth-child(5) { animation-delay: 0.4s; }
  @keyframes cheering {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* Floating numbers */
  .float-number {
    position: absolute;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: var(--accent);
    pointer-events: none;
    z-index: 20;
    animation: floatUp 1.6s cubic-bezier(0.32, 0, 0.67, 0) forwards;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
    letter-spacing: 0.5px;
  }
  .float-number.negative { color: var(--danger); }
  .float-number.gold { color: var(--gold); }
  @keyframes floatUp {
    0% { transform: translateY(0) scale(0.8); opacity: 0; }
    20% { transform: translateY(-12px) scale(1.1); opacity: 1; }
    80% { transform: translateY(-60px) scale(1); opacity: 1; }
    100% { transform: translateY(-90px) scale(0.9); opacity: 0; }
  }

  /* Particles (sparkle, star, confetti) */
  .particle {
    position: absolute;
    pointer-events: none;
    z-index: 18;
  }
  .particle.sparkle {
    width: 8px; height: 8px;
    background: var(--gold);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--gold);
    animation: sparkle 1s ease-out forwards;
  }
  @keyframes sparkle {
    0% { transform: scale(0); opacity: 1; }
    50% { transform: scale(1.5); opacity: 1; }
    100% { transform: scale(0); opacity: 0; }
  }
  .particle.confetti {
    width: 8px; height: 12px;
    animation: confettiFall 2s cubic-bezier(0.32, 0, 0.67, 0) forwards;
  }
  @keyframes confettiFall {
    0% { transform: translateY(0) rotate(0deg); opacity: 1; }
    100% { transform: translateY(300px) rotate(720deg); opacity: 0; }
  }

  /* News ticker */
  .news-ticker {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.7));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 8px 12px;
    overflow: hidden;
    z-index: 5;
    height: 28px;
    border-top: 1px solid var(--border);
  }
  .news-content {
    white-space: nowrap;
    animation: ticker 28s linear infinite;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--text);
    display: inline-block;
    padding-left: 100%;
  }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  /* ===== STATS PANEL ===== */
  .stats-panel {
    margin: 12px 16px;
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 14px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 16px;
    flex-shrink: 0;
    box-shadow: var(--shadow-md);
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .stat-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .stat-name {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-dim);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .stat-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: var(--text);
    letter-spacing: 0.5px;
    transition: color 0.2s, transform 0.2s;
  }
  .stat-value.changing { animation: valueChange 0.4s ease-out; }
  @keyframes valueChange {
    0% { transform: scale(1); }
    50% { transform: scale(1.2); color: var(--accent); }
    100% { transform: scale(1); }
  }
  .stat-bar-track {
    height: 7px;
    background: var(--bg-1);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.4);
  }
  .stat-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-dim), var(--accent));
    border-radius: 4px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s;
    position: relative;
  }
  .stat-bar-fill::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.2), transparent);
    border-radius: 4px;
  }
  .stat-bar-fill.warn {
    background: linear-gradient(90deg, #ff8c00, var(--warm));
    animation: pulseBar 1.2s ease-in-out infinite;
  }
  .stat-bar-fill.danger {
    background: linear-gradient(90deg, #c41a1a, var(--danger));
    animation: pulseBar 0.6s ease-in-out infinite;
  }
  @keyframes pulseBar {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 transparent; }
    50% { opacity: 0.7; box-shadow: 0 0 8px currentColor; }
  }

  .stat-item.full { grid-column: span 2; }

  /* ===== MESSAGE BAR ===== */
  .message-bar {
    margin: 0 16px 12px;
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 12px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    text-align: center;
    flex-shrink: 0;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }
  .message-bar.event {
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    font-weight: 700;
    border-color: var(--accent);
    box-shadow: 0 4px 16px var(--accent-glow);
    animation: messagePulse 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .message-bar.warn {
    background: linear-gradient(135deg, var(--danger), #d12848);
    color: white;
    border-color: var(--danger);
    box-shadow: 0 4px 16px var(--danger-glow);
  }
  @keyframes messagePulse {
    0% { transform: scale(0.96); }
    50% { transform: scale(1.02); }
    100% { transform: scale(1); }
  }

  /* ===== ACTION BAR ===== */
  .action-bar {
    margin-top: auto;
    padding: 12px 16px calc(16px + env(safe-area-inset-bottom));
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    flex-shrink: 0;
    background: linear-gradient(180deg, transparent 0%, var(--bg-0) 50%);
  }

  .action-btn {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 12px 6px;
    color: var(--text);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  .action-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.06) 50%, transparent 70%);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .action-btn:active {
    transform: scale(0.92);
    background: var(--bg-4);
  }
  .action-btn:active::before { opacity: 1; }
  .action-btn .icon {
    font-size: 24px;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  .action-btn.primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    border: none;
    font-weight: 800;
    box-shadow: 0 4px 16px var(--accent-glow);
    animation: primaryPulse 2.5s ease-in-out infinite;
  }
  @keyframes primaryPulse {
    0%, 100% { box-shadow: 0 4px 16px var(--accent-glow); }
    50% { box-shadow: 0 4px 24px var(--accent-glow), 0 0 0 6px rgba(0,229,176,0.1); }
  }
  .action-btn.primary:active {
    background: linear-gradient(135deg, var(--accent-dim), var(--accent));
    animation: none;
  }

  /* ===== MODAL BACKDROP & SHEET ===== */
  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: none;
    align-items: flex-end;
    z-index: 100;
    animation: backdropIn 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .modal-backdrop.active { display: flex; }
  @keyframes backdropIn {
    0% { opacity: 0; backdrop-filter: blur(0); }
    100% { opacity: 1; backdrop-filter: blur(8px); }
  }

  .sheet {
    width: 100%;
    background: linear-gradient(180deg, var(--bg-3), var(--bg-2));
    border-radius: 28px 28px 0 0;
    padding: 8px 16px calc(24px + env(safe-area-inset-bottom));
    max-height: 85%;
    overflow-y: auto;
    animation: sheetIn 0.4s cubic-bezier(0.32, 0.72, 0, 1);
    box-shadow: 0 -16px 48px rgba(0,0,0,0.6);
    border-top: 1px solid var(--border-strong);
  }
  @keyframes sheetIn {
    0% { transform: translateY(100%); }
    100% { transform: translateY(0); }
  }

  .sheet-handle {
    width: 44px; height: 5px;
    background: var(--text-mute);
    border-radius: 3px;
    margin: 10px auto 16px;
    opacity: 0.5;
  }

  .sheet-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 1.5px;
    margin-bottom: 16px;
    text-align: center;
  }

  /* Menu items */
  .menu-item {
    background: var(--bg-4);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    position: relative;
    overflow: hidden;
  }
  .menu-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
    transform: scaleY(0);
    transition: transform 0.2s;
  }
  .menu-item:active {
    transform: scale(0.97);
    background: var(--bg-5);
  }
  .menu-item:active::before { transform: scaleY(1); }
  .menu-item.disabled { opacity: 0.4; cursor: not-allowed; }

  .menu-item-left {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
  }
  .menu-item-icon {
    font-size: 26px;
    width: 38px;
    text-align: center;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }
  .menu-item-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .menu-item-name {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.2px;
  }
  .menu-item-desc {
    font-size: 12px;
    color: var(--text-dim);
    font-weight: 400;
  }
  .menu-item-cost {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    color: var(--accent);
    text-align: right;
    letter-spacing: 0.5px;
  }
  .menu-item-cost.coin { color: var(--warm); }
  .menu-item-cost.expensive { color: var(--danger); }
  .menu-item-cost.free {
    color: var(--text-dim);
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
  }

  /* Player select */
  .player-card {
    background: var(--bg-4);
    border: 2px solid var(--border);
    border-radius: 16px;
    padding: 14px;
    display: flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    margin-bottom: 10px;
    position: relative;
    overflow: hidden;
  }
  .player-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, var(--accent-glow), transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .player-card:active {
    transform: scale(0.98);
    border-color: var(--accent);
    box-shadow: 0 4px 16px var(--accent-glow);
  }
  .player-card:active::before { opacity: 0.3; }

  .player-card-mini {
    width: 42px; height: 56px;
    flex-shrink: 0;
    position: relative;
  }
  .player-card-info { flex: 1; }
  .player-card-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 1px;
  }
  .player-card-pos {
    font-size: 12px;
    color: var(--text-dim);
    margin-top: 2px;
    font-weight: 500;
  }
  .player-card-skill {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--accent);
    text-shadow: 0 0 12px var(--accent-glow);
  }

  /* ===== MATCH MODAL ===== */
  .match-modal {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--pitch-2) 0%, #051d10 100%);
    display: none;
    flex-direction: column;
    z-index: 200;
    padding: 16px;
    padding-top: max(16px, env(safe-area-inset-top));
    animation: matchIn 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .match-modal.active { display: flex; }
  @keyframes matchIn {
    0% { opacity: 0; transform: scale(0.95); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* Pitch lines for match */
  .match-modal::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(90deg,
        transparent 0,
        transparent 32px,
        rgba(255,255,255,0.04) 32px,
        rgba(255,255,255,0.04) 64px);
    pointer-events: none;
  }

  .match-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    z-index: 2;
  }
  .match-week-tag {
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  .match-minute {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 40px;
    color: var(--gold);
    letter-spacing: 2px;
    text-shadow: 0 0 16px rgba(255,215,0,0.5);
    line-height: 1;
  }

  .match-teams-display {
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 20px 16px;
    margin: 12px 0;
    z-index: 2;
  }

  .match-vs-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .match-team {
    flex: 1;
    text-align: center;
  }
  .match-team-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 1px;
    margin-bottom: 10px;
    color: var(--text-dim);
  }
  .match-team-name.me { color: var(--accent); text-shadow: 0 0 12px var(--accent-glow); }
  .match-team-score {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 72px;
    line-height: 1;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), color 0.2s;
  }
  .match-team-score.scored {
    animation: scorePop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    color: var(--gold);
  }
  @keyframes scorePop {
    0% { transform: scale(1); }
    50% { transform: scale(1.4); }
    100% { transform: scale(1); }
  }
  .match-vs {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--text-mute);
    letter-spacing: 2px;
  }

  .match-event {
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    margin: 12px 0;
    min-height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .match-event.gol {
    background: linear-gradient(135deg, var(--gold), var(--warm));
    color: var(--bg-0);
    font-weight: 800;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 2px;
    border-color: var(--gold);
    box-shadow: 0 0 32px rgba(255,215,0,0.5);
    animation: golEvent 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes golEvent {
    0% { transform: scale(0.8) translateY(10px); }
    100% { transform: scale(1) translateY(0); }
  }
  .match-event.fail {
    background: rgba(255,59,92,0.2);
    border-color: var(--danger);
  }

  /* MAÇ MINI-SAHNESİ
     Eski v5'te skorlar arasında boş alan vardı. Şimdi orada:
     - karakterimiz koşuyor (running-right/left animasyonları)
     - top zıplıyor ve gole giderken hareket ediyor
     - kale ağı arka planda
     Bu, maçın "yaşanan bir şey" hissi vermesini sağlıyor.

     v7 düzeltmesi: mini karakter kendi class'larını kullanıyor (.mini-runner)
     yerine .player class'ından miras almıyor — eskiden ana karakterin
     "tired" veya "injured" durumu mini sahneye yansıyordu, bu yanlıştı.
     Maçta karakter her zaman atletik görünmeli.
  */
  .match-mini-stage {
    position: relative;
    height: 110px;
    margin: 8px 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.3), rgba(0,0,0,0.5));
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .match-mini-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(90deg,
      transparent 0, transparent 16px,
      rgba(255,255,255,0.03) 16px, rgba(255,255,255,0.03) 32px);
  }
  /* Kale: sağ tarafta basit pixel ağ */
  .match-goalpost {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 60px;
    border: 3px solid rgba(255,255,255,0.6);
    border-right: none;
    border-radius: 4px 0 0 4px;
    background: repeating-linear-gradient(
      0deg,
      transparent 0, transparent 4px,
      rgba(255,255,255,0.2) 4px, rgba(255,255,255,0.2) 5px
    ), repeating-linear-gradient(
      90deg,
      transparent 0, transparent 4px,
      rgba(255,255,255,0.2) 4px, rgba(255,255,255,0.2) 5px
    );
  }
  .match-mini-player {
    position: absolute;
    left: 30px;
    top: 50%;
    transform: translateY(-50%) scale(0.7);
    transform-origin: center;
    width: 66px;
    height: 88px;
    transition: left 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    /* v7: kendi animasyonu var, .player class'ı yok — izole çalışır */
    animation: miniDribble 0.45s ease-in-out infinite;
  }
  .match-mini-player.charging-pos { left: calc(100% - 130px); }
  .match-mini-player.mini-running { animation: miniRunning 0.4s ease-in-out infinite; }
  .match-mini-player.mini-charging { animation: miniCharging 0.32s ease-in-out infinite; }
  .match-mini-player.mini-celebrating { animation: miniCelebrate 0.5s cubic-bezier(0.36, 0, 0.66, 1) infinite; }

  @keyframes miniDribble {
    0%, 100% { transform: translateY(-50%) scale(0.7) rotate(-1deg); }
    50% { transform: translateY(calc(-50% - 3px)) scale(0.7) rotate(1deg); }
  }
  @keyframes miniRunning {
    0%, 100% { transform: translateY(-50%) scale(0.7) rotate(-3deg); }
    50% { transform: translateY(calc(-50% - 4px)) scale(0.73) rotate(3deg); }
  }
  @keyframes miniCharging {
    0%, 100% { transform: translateY(-50%) scale(0.75) rotate(-2deg); }
    50% { transform: translateY(calc(-50% - 5px)) scale(0.77) rotate(2deg); }
  }
  @keyframes miniCelebrate {
    0% { transform: translateY(-50%) scale(0.7) rotate(0deg); }
    25% { transform: translateY(calc(-50% - 14px)) scale(0.82) rotate(-12deg); }
    50% { transform: translateY(-50%) scale(0.75) rotate(0deg); }
    75% { transform: translateY(calc(-50% - 16px)) scale(0.82) rotate(12deg); }
    100% { transform: translateY(-50%) scale(0.7) rotate(0deg); }
  }
  .match-mini-ball {
    position: absolute;
    left: 90px;
    top: 60%;
    width: 14px;
    height: 14px;
    background: radial-gradient(circle at 35% 35%, white 30%, #ddd 60%, #888);
    border-radius: 50%;
    box-shadow: 0 4px 8px rgba(0,0,0,0.4);
    transition: left 0.5s cubic-bezier(0.45, 0, 0.55, 1), top 0.5s cubic-bezier(0.45, 0, 0.55, 1);
    animation: ballSpin 0.4s linear infinite;
    z-index: 4;
  }
  .match-mini-ball.shot {
    left: calc(100% - 30px);
    top: 35%;
    animation: ballSpin 0.15s linear infinite, ballArc 0.5s cubic-bezier(0.4,0,0.6,1) forwards;
  }
  @keyframes ballSpin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  @keyframes ballArc {
    0% { top: 60%; }
    50% { top: 20%; }
    100% { top: 35%; }
  }

  /* v10: Top'un yer gölgesi - top zıpladıkça gölge küçülür/büyür */
  .match-mini-ball-shadow {
    position: absolute;
    left: 90px;
    bottom: 12px;
    width: 14px;
    height: 4px;
    background: radial-gradient(ellipse, rgba(0,0,0,0.4), transparent 70%);
    transition: left 0.5s cubic-bezier(0.45, 0, 0.55, 1), transform 0.5s cubic-bezier(0.45, 0, 0.55, 1), opacity 0.5s;
    z-index: 2;
    pointer-events: none;
  }
  .match-mini-ball-shadow.shot {
    left: calc(100% - 30px);
    transform: scale(1.4);
    opacity: 0.6;
  }

  .match-decisions {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
    z-index: 2;
    animation: decisionsIn 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }
  @keyframes decisionsIn {
    0% { transform: translateY(40px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  .decision-prompt {
    text-align: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    color: var(--gold);
    margin-bottom: 8px;
    letter-spacing: 1.5px;
    text-shadow: 0 0 12px rgba(255,215,0,0.4);
  }
  .decision-btn {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    padding: 16px;
    color: var(--text);
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    text-align: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--shadow-sm);
  }
  .decision-btn:active {
    transform: scale(0.97);
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    box-shadow: 0 4px 16px var(--accent-glow);
  }
  .decision-btn .risk-tag {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 6px;
    letter-spacing: 0.5px;
  }
  .risk-low { background: rgba(0,229,176,0.2); color: var(--accent); }
  .risk-mid { background: rgba(255,184,0,0.2); color: var(--warm); }
  .risk-high { background: rgba(255,59,92,0.2); color: var(--danger); }

  .match-final-actions {
    margin-top: auto;
    z-index: 2;
  }

  /* ========================================
     V8 GELİŞMİŞ MAÇ MEKANİKLERİ
     ========================================
     Kale grid'i: 3x3 = 9 nokta. Köşeler riskli ama yüksek gol şansı,
     merkez kolay ama kaleci yakalar.

     Pas seçimi: 2-3 takım arkadaşı kart olarak gösterilir,
     her birinin durumu (serbest/baskı altında) ve pozisyonu farklı.

     Set-piece (penaltı/frikik): kale grid'i + kaleci animasyonu
  */

  .match-decision-scene {
    background: linear-gradient(180deg, var(--pitch-2), var(--pitch-1));
    border-radius: 18px;
    padding: 18px;
    margin: 12px 0;
    border: 1px solid var(--border);
    z-index: 2;
    animation: decisionsIn 0.4s cubic-bezier(0.32, 0.72, 0, 1);
    position: relative;
    overflow: hidden;
  }
  .match-decision-scene::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(90deg,
      transparent 0, transparent 24px,
      rgba(255,255,255,0.04) 24px, rgba(255,255,255,0.04) 48px);
    pointer-events: none;
  }

  .scene-prompt {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: var(--gold);
    text-align: center;
    letter-spacing: 1.5px;
    margin-bottom: 12px;
    text-shadow: 0 0 12px rgba(255,215,0,0.4);
    position: relative;
    z-index: 2;
  }

  /* KALE GRID */
  .goal-frame {
    position: relative;
    width: 100%;
    max-width: 260px;
    margin: 0 auto;
    aspect-ratio: 5/3;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.4), rgba(0,0,0,0.6)),
      repeating-linear-gradient(
        0deg,
        transparent 0, transparent 6px,
        rgba(255,255,255,0.18) 6px, rgba(255,255,255,0.18) 7px
      ),
      repeating-linear-gradient(
        90deg,
        transparent 0, transparent 6px,
        rgba(255,255,255,0.18) 6px, rgba(255,255,255,0.18) 7px
      );
    border: 4px solid white;
    border-bottom: none;
    border-radius: 6px 6px 0 0;
    z-index: 2;
  }

  .goal-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr 1fr;
    gap: 2px;
    padding: 4px;
  }

  .goal-cell {
    background: rgba(0,0,0,0.15);
    border-radius: 4px;
    cursor: pointer;
    position: relative;
    transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: rgba(255,255,255,0.6);
    font-weight: 700;
  }
  .goal-cell:active {
    transform: scale(0.92);
    background: var(--gold);
    color: var(--bg-0);
  }
  /* Risk göstergeleri */
  .goal-cell.risk-low { background: rgba(0,229,176,0.15); }
  .goal-cell.risk-mid { background: rgba(255,184,0,0.15); }
  .goal-cell.risk-high { background: rgba(255,59,92,0.18); }

  .goal-cell::after {
    content: '';
    position: absolute;
    inset: 4px;
    border: 2px dashed rgba(255,255,255,0.2);
    border-radius: 3px;
    pointer-events: none;
    transition: border-color 0.2s;
  }
  .goal-cell:active::after {
    border-color: var(--bg-0);
  }

  /* Kaleci pozisyonu (kale grid'inde dolaşır) */
  .goalkeeper {
    position: absolute;
    width: 22%;
    height: 90%;
    background:
      radial-gradient(circle at 50% 30%, #f4d4a8 8%, transparent 18%),
      linear-gradient(180deg, #ffd54f 18%, #ff9800 18% 60%, #1a1a1a 60%);
    border-radius: 6px 6px 2px 2px;
    bottom: 0;
    left: 39%;
    transition: left 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 3;
    box-shadow: 0 4px 8px rgba(0,0,0,0.4);
    pointer-events: none;
  }
  .goalkeeper.dive-left { left: 8%; transform: rotate(-15deg); }
  .goalkeeper.dive-right { left: 70%; transform: rotate(15deg); }

  /* Çim çizgisi */
  .goal-grass {
    position: relative;
    height: 30px;
    background: linear-gradient(180deg, var(--pitch-light), var(--pitch-2));
    margin-top: 2px;
    border-radius: 0 0 8px 8px;
    z-index: 1;
  }
  .goal-grass::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(90deg,
        transparent 0, transparent 12px,
        rgba(255,255,255,0.08) 12px, rgba(255,255,255,0.08) 24px);
  }

  /* Risk legend */
  .goal-legend {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 10px;
    font-size: 10px;
    font-weight: 600;
    color: var(--text-dim);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    position: relative;
    z-index: 2;
  }
  .goal-legend-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .goal-legend-swatch {
    width: 12px; height: 12px;
    border-radius: 3px;
  }

  /* PAS SEÇİMİ — takım arkadaşı kartları */
  .teammates-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    position: relative;
    z-index: 2;
  }
  .teammate-card {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 2px solid var(--border);
    border-radius: 14px;
    padding: 10px 8px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .teammate-card:active {
    transform: scale(0.94);
    border-color: var(--accent);
    box-shadow: 0 4px 12px var(--accent-glow);
  }
  .teammate-card.free { border-color: rgba(0,229,176,0.4); }
  .teammate-card.pressed { border-color: rgba(255,184,0,0.4); }
  .teammate-card.danger { border-color: rgba(255,59,92,0.4); }

  .teammate-icon {
    font-size: 32px;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
    line-height: 1;
  }
  .teammate-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 0.5px;
    line-height: 1;
  }
  .teammate-pos-tag {
    font-size: 9px;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .teammate-status {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .teammate-card.free .teammate-status { color: var(--accent); }
  .teammate-card.pressed .teammate-status { color: var(--warm); }
  .teammate-card.danger .teammate-status { color: var(--danger); }

  /* SET-PIECE STİLLERİ */
  .set-piece-info {
    display: flex;
    justify-content: space-around;
    align-items: center;
    margin-bottom: 12px;
    padding: 10px;
    background: rgba(0,0,0,0.4);
    border-radius: 12px;
    position: relative;
    z-index: 2;
  }
  .set-piece-stat {
    text-align: center;
  }
  .set-piece-stat-label {
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }
  .set-piece-stat-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: var(--accent);
    margin-top: 2px;
  }

  /* Frikik teknik seçenekleri */
  .technique-options {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    margin-top: 12px;
    position: relative;
    z-index: 2;
  }
  .technique-btn {
    background: var(--bg-3);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    padding: 10px 6px;
    color: var(--text);
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
  }
  .technique-btn:active {
    transform: scale(0.94);
    background: var(--accent);
    color: var(--bg-0);
  }
  .technique-icon {
    font-size: 22px;
    margin-bottom: 2px;
  }
  .technique-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 12px;
    letter-spacing: 0.5px;
    line-height: 1;
  }
  .technique-desc {
    font-size: 9px;
    color: var(--text-dim);
    margin-top: 2px;
    line-height: 1.2;
  }

  /* Top hareketinin trail efekti */
  .ball-trail {
    position: absolute;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, white 30%, #ddd 60%, #888);
    box-shadow: 0 0 12px rgba(255,255,255,0.6);
    pointer-events: none;
    z-index: 5;
    animation: ballFly 0.7s cubic-bezier(0.45, 0, 0.55, 1) forwards;
  }
  @keyframes ballFly {
    0% { transform: scale(0.6); opacity: 1; }
    50% { transform: scale(1.2) translateY(-10px); opacity: 1; }
    100% { transform: scale(0.4); opacity: 0; }
  }

  /* Save (kurtarış) animasyonu — kalecinin atlama efekti */
  .save-flash {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle, rgba(255,184,0,0.4), transparent 60%);
    pointer-events: none;
    animation: saveFlashAnim 0.6s ease-out;
  }
  @keyframes saveFlashAnim {
    0% { opacity: 0; }
    30% { opacity: 1; }
    100% { opacity: 0; }
  }

  /* Maç bilgi paneli — alt statları gösterir */
  .match-stats-row {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    margin: 8px 0;
    padding: 8px 12px;
    background: rgba(0,0,0,0.4);
    border-radius: 12px;
    border: 1px solid var(--border);
    z-index: 2;
    position: relative;
  }
  .match-stat-mini {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex: 1;
  }
  .match-stat-mini-label {
    font-size: 9px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }
  .match-stat-mini-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    color: var(--accent);
    line-height: 1;
  }
  .match-final-btn {
    width: 100%;
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    border: none;
    border-radius: 14px;
    padding: 16px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 1.5px;
    cursor: pointer;
    box-shadow: 0 4px 16px var(--accent-glow);
    transition: transform 0.15s;
  }
  .match-final-btn:active { transform: scale(0.96); }

  /* Goal flash */
  .goal-flash {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle, var(--gold), var(--warm) 50%, var(--accent-dim));
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 250;
    animation: goalFlashAnim 2.4s cubic-bezier(0.32, 0, 0.67, 0) forwards;
  }
  .goal-flash.active { display: flex; }
  .goal-flash-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 110px;
    color: var(--bg-0);
    letter-spacing: 8px;
    text-shadow:
      6px 6px 0 var(--bg-0),
      -3px -3px 0 var(--bg-0),
      0 0 32px white;
    animation: goalScaleV2 1.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes goalFlashAnim {
    0% { opacity: 0; }
    8% { opacity: 1; }
    70% { opacity: 1; }
    100% { opacity: 0; }
  }
  @keyframes goalScaleV2 {
    0% { transform: scale(0) rotate(-25deg); }
    25% { transform: scale(1.8) rotate(8deg); }
    40% { transform: scale(1.2) rotate(-3deg); }
    55% { transform: scale(1.5) rotate(2deg); }
    70% { transform: scale(1.3) rotate(0deg); }
    100% { transform: scale(1.4) rotate(0); }
  }

  /* Goal flash içinde dönen yıldız efekti */
  .goal-flash::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      conic-gradient(from 0deg at 50% 50%,
        transparent 0deg,
        rgba(255,255,255,0.4) 10deg,
        transparent 25deg,
        rgba(255,255,255,0.4) 35deg,
        transparent 50deg,
        rgba(255,255,255,0.4) 60deg,
        transparent 75deg,
        rgba(255,255,255,0.4) 85deg,
        transparent 360deg);
    animation: starburstSpin 1.2s linear infinite;
    pointer-events: none;
  }
  @keyframes starburstSpin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* ===== FULLSCREEN MODALS ===== */
  .fullscreen-modal {
    position: absolute;
    inset: 0;
    background: var(--bg-1);
    display: none;
    flex-direction: column;
    z-index: 300;
    animation: fadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .fullscreen-modal.active { display: flex; }
  @keyframes fadeIn {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .modal-topbar {
    display: flex;
    align-items: center;
    padding: 14px 16px;
    padding-top: max(14px, env(safe-area-inset-top));
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    background: var(--bg-2);
  }
  .modal-back {
    background: var(--bg-4);
    border: 1px solid var(--border);
    color: var(--text);
    width: 36px; height: 36px;
    border-radius: 11px;
    font-size: 18px;
    cursor: pointer;
    margin-right: 14px;
    transition: all 0.15s;
  }
  .modal-back:active { transform: scale(0.9); background: var(--bg-5); }
  .modal-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    flex: 1;
  }
  .modal-content {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    padding-bottom: calc(16px + env(safe-area-inset-bottom));
  }

  /* Tab pills */
  .tab-pills {
    display: flex;
    gap: 4px;
    margin-bottom: 14px;
    background: var(--bg-3);
    border-radius: 14px;
    padding: 4px;
    border: 1px solid var(--border);
  }
  .tab-pill {
    flex: 1;
    padding: 10px;
    text-align: center;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    color: var(--text-dim);
  }
  .tab-pill.active {
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    box-shadow: 0 2px 8px var(--accent-glow);
  }

  /* Premium banner */
  .premium-banner {
    background: linear-gradient(135deg, #fdd835 0%, #ff9800 100%);
    color: #1a1a1a;
    padding: 18px;
    border-radius: 18px;
    margin-bottom: 14px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(255,184,0,0.3);
  }
  .premium-banner::before {
    content: '';
    position: absolute;
    top: -50%; right: -20%;
    width: 240px; height: 240px;
    background: radial-gradient(circle, rgba(255,255,255,0.4), transparent);
    pointer-events: none;
    animation: premiumShine 4s ease-in-out infinite;
  }
  @keyframes premiumShine {
    0%, 100% { transform: translateX(0) translateY(0); opacity: 0.4; }
    50% { transform: translateX(-30px) translateY(20px); opacity: 0.7; }
  }
  .premium-banner.active {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    color: var(--gold);
    border: 1px solid var(--gold);
    box-shadow: 0 0 24px rgba(255,215,0,0.2);
  }
  .premium-banner.active::before { display: none; }
  .premium-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 2px;
    margin-bottom: 4px;
  }
  .premium-desc {
    font-size: 13px;
    opacity: 0.9;
    font-weight: 500;
  }
  .premium-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    margin-top: 8px;
    letter-spacing: 1px;
  }

  /* Career stat cards */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 18px;
  }
  .stat-card {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .stat-card-label {
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    font-weight: 600;
  }
  .stat-card-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--accent);
    margin-top: 4px;
    line-height: 1;
  }
  .stat-card.gold .stat-card-value {
    color: var(--gold);
    text-shadow: 0 0 12px rgba(255,215,0,0.4);
  }

  /* League */
  .league-row {
    display: grid;
    grid-template-columns: 26px 1fr 30px 30px 30px 36px;
    gap: 6px;
    padding: 12px;
    background: var(--bg-3);
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    font-weight: 500;
    align-items: center;
    transition: background 0.2s;
  }
  .league-row:first-child { border-radius: 14px 14px 0 0; }
  .league-row:last-child { border-radius: 0 0 14px 14px; border-bottom: none; }
  .league-row.header {
    background: var(--bg-2);
    color: var(--text-dim);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }
  .league-row.me {
    background: linear-gradient(90deg, rgba(0,229,176,0.15), transparent);
    border-left: 3px solid var(--accent);
    font-weight: 700;
  }
  .league-row.first {
    border-left: 3px solid var(--gold);
    background: linear-gradient(90deg, rgba(255,215,0,0.08), transparent);
  }
  .league-pts {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    color: var(--accent);
    text-align: right;
  }
  .league-row.first .league-pts { color: var(--gold); }

  /* Achievements */
  .achievement-item {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px;
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 10px;
    transition: all 0.2s;
  }
  .achievement-item.locked { opacity: 0.4; }
  .achievement-item.unlocked {
    border-color: var(--gold);
    background: linear-gradient(135deg, rgba(255,215,0,0.08), var(--bg-3));
  }
  .achievement-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    background: var(--bg-4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    flex-shrink: 0;
  }
  .achievement-item.unlocked .achievement-icon {
    background: linear-gradient(135deg, var(--gold), var(--warm));
    box-shadow: 0 4px 16px rgba(255,215,0,0.3);
  }
  .achievement-info {
    flex: 1;
  }
  .achievement-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 1px;
  }
  .achievement-desc {
    font-size: 12px;
    color: var(--text-dim);
    margin-top: 2px;
  }

  /* Skill tree */
  .skill-tree-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }
  .skill-node {
    background: var(--bg-3);
    border: 2px solid var(--border);
    border-radius: 16px;
    padding: 12px 8px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    position: relative;
    overflow: hidden;
  }
  .skill-node.unlocked {
    background: linear-gradient(135deg, var(--gold), var(--warm));
    color: var(--bg-0);
    border-color: var(--gold);
    box-shadow: 0 4px 16px rgba(255,215,0,0.3);
  }
  .skill-node.available {
    border-color: var(--accent);
    animation: skillGlow 2s ease-in-out infinite;
  }
  @keyframes skillGlow {
    0%, 100% { box-shadow: 0 0 0 transparent; }
    50% { box-shadow: 0 0 16px var(--accent-glow); }
  }
  .skill-node.locked { opacity: 0.4; cursor: not-allowed; }
  .skill-node:active:not(.locked):not(.unlocked) { transform: scale(0.94); }
  .skill-node-icon {
    font-size: 26px;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }
  .skill-node-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 12px;
    letter-spacing: 0.5px;
  }
  .skill-node-cost {
    font-size: 10px;
    color: var(--text-dim);
    font-weight: 600;
  }
  .skill-node.unlocked .skill-node-cost { color: var(--bg-0); }

  /* Color picker */
  .color-section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: var(--text-dim);
    margin-bottom: 10px;
    letter-spacing: 1px;
  }
  .color-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 10px;
    margin-bottom: 20px;
  }
  .color-swatch {
    aspect-ratio: 1;
    border-radius: 14px;
    cursor: pointer;
    border: 3px solid transparent;
    transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    box-shadow: inset 0 -2px 4px rgba(0,0,0,0.3),
                inset 0 2px 4px rgba(255,255,255,0.1);
  }
  .color-swatch:active { transform: scale(0.88); }
  .color-swatch.selected {
    border-color: var(--accent);
    transform: scale(1.1);
    box-shadow: 0 0 16px var(--accent-glow),
                inset 0 -2px 4px rgba(0,0,0,0.3);
  }
  .color-swatch.selected::after {
    content: '✓';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 18px;
    font-weight: bold;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }

  /* Daily reward */
  .daily-modal {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 400;
    padding: 24px;
    animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .daily-modal.active { display: flex; }
  .daily-icon {
    font-size: 88px;
    animation: bounceIcon 1.2s ease-in-out infinite;
    filter: drop-shadow(0 8px 16px rgba(0,0,0,0.4));
  }
  @keyframes bounceIcon {
    0%, 100% { transform: translateY(0) rotate(-8deg); }
    50% { transform: translateY(-12px) rotate(8deg); }
  }
  .daily-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: var(--gold);
    letter-spacing: 3px;
    margin-top: 20px;
    text-shadow: 0 0 24px rgba(255,215,0,0.5);
  }
  .daily-streak-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: var(--accent);
    margin-top: 10px;
  }
  .daily-rewards-row {
    display: flex;
    gap: 6px;
    margin: 20px 0;
    overflow-x: auto;
    width: 100%;
    padding: 6px;
    scrollbar-width: none;
  }
  .daily-rewards-row::-webkit-scrollbar { display: none; }
  .daily-reward-cell {
    flex-shrink: 0;
    width: 64px;
    background: var(--bg-3);
    border: 2px solid var(--border);
    border-radius: 14px;
    padding: 10px 4px;
    text-align: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 12px;
  }
  .daily-reward-cell.claimed {
    background: linear-gradient(135deg, var(--accent-dim), var(--bg-3));
    color: var(--text);
    border-color: var(--accent);
    opacity: 0.6;
  }
  .daily-reward-cell.today {
    border-color: var(--gold);
    box-shadow: 0 0 16px rgba(255,215,0,0.4);
    animation: skillGlow 1.5s ease-in-out infinite;
    transform: scale(1.1);
  }
  .daily-claim-btn {
    background: linear-gradient(135deg, var(--gold), var(--warm));
    color: var(--bg-0);
    border: none;
    border-radius: 16px;
    padding: 16px 40px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 1.5px;
    cursor: pointer;
    margin-top: 20px;
    box-shadow: 0 8px 24px rgba(255,184,0,0.4);
    transition: transform 0.15s;
  }
  .daily-claim-btn:active { transform: scale(0.96); }

  /* Game over */
  .gameover-modal {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--bg-0), #1a0a0a);
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 500;
    padding: 24px;
    text-align: center;
  }
  .gameover-modal.active { display: flex; animation: fadeIn 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
  .gameover-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 56px;
    color: var(--gold);
    letter-spacing: 5px;
    margin-bottom: 12px;
    text-shadow: 0 0 32px rgba(255,215,0,0.5);
  }
  .gameover-reason {
    font-size: 14px;
    color: var(--text-dim);
    margin-bottom: 28px;
    line-height: 1.5;
  }
  .gameover-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    width: 100%;
    margin-bottom: 28px;
  }
  .gameover-restart {
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    border: none;
    border-radius: 16px;
    padding: 16px 40px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 1.5px;
    cursor: pointer;
    box-shadow: 0 4px 16px var(--accent-glow);
    transition: transform 0.15s;
  }
  .gameover-restart:active { transform: scale(0.96); }

  /* News */
  .news-item {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px;
    margin-bottom: 10px;
    border-left: 3px solid var(--accent);
  }
  .news-meta {
    font-size: 11px;
    color: var(--text-dim);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }
  .news-text {
    font-size: 14px;
    color: var(--text);
    font-weight: 500;
    line-height: 1.4;
  }

  /* Achievement toast */
  .achievement-toast {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%) translateY(-200px);
    background: linear-gradient(135deg, var(--gold), var(--warm));
    color: var(--bg-0);
    padding: 14px 18px;
    border-radius: 16px;
    z-index: 600;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 12px 32px rgba(0,0,0,0.5),
                0 0 24px rgba(255,215,0,0.4);
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: 90%;
  }
  .achievement-toast.show {
    transform: translateX(-50%) translateY(0);
  }
  .achievement-toast-icon {
    font-size: 32px;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }
  .achievement-toast-content { display: flex; flex-direction: column; }
  .achievement-toast-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 1px;
  }
  .achievement-toast-desc {
    font-size: 12px;
    font-weight: 500;
  }

  /* Confirm modal */
  .confirm-modal {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(8px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 700;
    padding: 24px;
  }
  .confirm-modal.active { display: flex; animation: fadeIn 0.2s; }
  .confirm-card {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 1px solid var(--border-strong);
    border-radius: 22px;
    padding: 24px;
    max-width: 320px;
    width: 100%;
    text-align: center;
    box-shadow: var(--shadow-lg);
    animation: confirmIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes confirmIn {
    0% { transform: scale(0.9); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  .confirm-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    margin-bottom: 10px;
    letter-spacing: 1px;
  }
  .confirm-message {
    font-size: 14px;
    color: var(--text-dim);
    margin-bottom: 20px;
    line-height: 1.5;
    font-weight: 500;
  }
  .confirm-actions {
    display: flex;
    gap: 10px;
  }
  .confirm-btn {
    flex: 1;
    border: none;
    border-radius: 12px;
    padding: 14px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    letter-spacing: 1px;
    cursor: pointer;
    transition: transform 0.15s;
  }
  .confirm-btn:active { transform: scale(0.96); }
  .confirm-btn.primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
  }
  .confirm-btn.secondary {
    background: var(--bg-4);
    color: var(--text);
  }
  .confirm-btn.danger {
    background: linear-gradient(135deg, var(--danger), #d12848);
    color: white;
  }

  /* Intro */
  .intro-modal {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at top, rgba(0,229,176,0.15), transparent 60%),
      linear-gradient(180deg, var(--pitch-1), var(--bg-0));
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 800;
    padding: 32px;
    text-align: center;
  }
  .intro-modal.active { display: flex; }
  .intro-logo-wrap {
    margin-bottom: 8px;
    animation: introLogoIn 1s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes introLogoIn {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  .intro-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 64px;
    color: var(--accent);
    letter-spacing: 5px;
    line-height: 1;
    text-shadow: 0 0 32px var(--accent-glow);
  }
  .intro-title span { color: var(--warm); }
  .intro-subtitle {
    font-size: 14px;
    color: var(--text-dim);
    margin: 12px 0 36px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .intro-tagline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    margin-top: 28px;
    line-height: 1.5;
    letter-spacing: 1.5px;
    animation: fadeIn 1s 0.3s both;
  }
  .intro-tagline span {
    color: var(--accent);
    text-shadow: 0 0 12px var(--accent-glow);
  }
  .intro-cta {
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    border: none;
    border-radius: 18px;
    padding: 18px 56px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 2.5px;
    cursor: pointer;
    margin-top: 36px;
    box-shadow: 0 8px 32px var(--accent-glow);
    animation: ctaIn 1s 0.6s both, ctaPulse 2s 1.6s infinite;
    transition: transform 0.15s;
  }
  .intro-cta:active { transform: scale(0.96); animation: none; }
  @keyframes ctaIn {
    0% { transform: translateY(40px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }
  @keyframes ctaPulse {
    0%, 100% { box-shadow: 0 8px 32px var(--accent-glow); }
    50% { box-shadow: 0 8px 48px var(--accent-glow), 0 0 0 8px rgba(0,229,176,0.1); }
  }

  /* SEZON SONU ÖZETİ
     Eski v5'te sezon biti tek satır mesajla geçiyordu, çok yetersizdi.
     Yeni sezon-sonu modalı: dramatik açılış, kazanılan kupa varsa
     altın halka efekti, tüm istatistiklerin özeti, en büyük başarı vurgusu.
     Bu, oyuncunun "bu sezonu hak ettim" hissini yaşamasını sağlıyor.
  */
  .season-end-modal {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at top, rgba(255,215,0,0.15), transparent 60%),
      linear-gradient(180deg, var(--bg-1), var(--bg-0));
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    z-index: 450;
    padding: 32px 24px calc(32px + env(safe-area-inset-bottom));
    padding-top: max(32px, env(safe-area-inset-top));
    overflow-y: auto;
  }
  .season-end-modal.active { display: flex; animation: fadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1); }

  .season-end-icon {
    font-size: 96px;
    animation: trophyEntrance 1.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    filter: drop-shadow(0 8px 24px rgba(255,215,0,0.5));
    margin-bottom: 12px;
  }
  @keyframes trophyEntrance {
    0% { transform: scale(0) rotate(-20deg); opacity: 0; }
    50% { transform: scale(1.3) rotate(10deg); opacity: 1; }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
  }

  .season-end-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 44px;
    color: var(--gold);
    letter-spacing: 4px;
    line-height: 1;
    text-shadow: 0 0 24px rgba(255,215,0,0.4);
    text-align: center;
    animation: fadeIn 0.6s 0.3s both;
  }
  .season-end-subtitle {
    font-size: 14px;
    color: var(--text-dim);
    margin-top: 8px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    animation: fadeIn 0.6s 0.5s both;
  }

  .season-end-rank {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 64px;
    margin: 20px 0 8px;
    line-height: 1;
    animation: rankIn 0.8s 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .season-end-rank.gold { color: var(--gold); text-shadow: 0 0 24px rgba(255,215,0,0.5); }
  .season-end-rank.silver { color: #c0c0c0; }
  .season-end-rank.bronze { color: #cd7f32; }
  @keyframes rankIn {
    0% { transform: scale(0) translateY(40px); opacity: 0; }
    100% { transform: scale(1) translateY(0); opacity: 1; }
  }

  .season-end-rank-text {
    font-size: 13px;
    color: var(--text-dim);
    margin-bottom: 24px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .season-end-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    width: 100%;
    margin-bottom: 20px;
    animation: fadeIn 0.6s 0.9s both;
  }

  .season-end-highlight {
    background: linear-gradient(135deg, rgba(255,215,0,0.15), rgba(255,184,0,0.08));
    border: 1px solid var(--gold);
    border-radius: 14px;
    padding: 14px;
    margin-bottom: 20px;
    text-align: center;
    width: 100%;
    animation: fadeIn 0.6s 1.1s both;
  }
  .season-end-highlight-label {
    font-size: 11px;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    font-weight: 700;
  }
  .season-end-highlight-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: var(--text);
    margin-top: 4px;
    letter-spacing: 0.5px;
  }

  .season-end-continue {
    width: 100%;
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    border: none;
    border-radius: 16px;
    padding: 18px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    cursor: pointer;
    box-shadow: 0 4px 16px var(--accent-glow);
    transition: transform 0.15s;
    animation: fadeIn 0.6s 1.3s both;
    margin-top: auto;
  }
  .season-end-continue:active { transform: scale(0.96); }

  /* Modal kapanma animasyonu — eski v5'te sadece açılma vardı */
  .modal-closing {
    animation: fadeOut 0.25s cubic-bezier(0.4, 0, 0.2, 1) forwards !important;
  }
  @keyframes fadeOut {
    0% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(20px); }
  }

  /* EKRAN KENARI FLASH
     Olumsuz kritik olaylar (skandal, sakatlık) için kullanılır.
     Tüm ekran etrafında kısa süreli kırmızı parıltı belirir.
     Oyuncu mesajı kaçırsa bile bir şey olduğunu hisseder.
  */
  .screen-flash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 999;
    opacity: 0;
    box-shadow: inset 0 0 80px var(--danger);
    animation: screenFlashAnim 0.8s ease-out;
  }
  .screen-flash.success {
    box-shadow: inset 0 0 80px var(--accent);
  }
  @keyframes screenFlashAnim {
    0% { opacity: 0; }
    20% { opacity: 1; }
    100% { opacity: 0; }
  }

  /* OYUNCU YARATMA EKRANI (v7 yenisi)
     4 adımlı wizard:
     1. İsim
     2. Pozisyon (4 kart)
     3. Görünüm (saç/ten/forma)
     4. Stat dağılımı (200 puan)
     Sonra ön izleme + onay
  */
  .creator-modal {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--bg-1) 0%, var(--bg-0) 100%);
    display: none;
    flex-direction: column;
    z-index: 850;
    padding-top: max(0px, env(safe-area-inset-top));
  }
  .creator-modal.active { display: flex; animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1); }

  .creator-header {
    padding: 16px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-2);
    flex-shrink: 0;
  }
  .creator-header-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .creator-back {
    background: var(--bg-4);
    border: 1px solid var(--border);
    color: var(--text);
    width: 36px; height: 36px;
    border-radius: 11px;
    font-size: 18px;
    cursor: pointer;
    transition: transform 0.15s;
  }
  .creator-back:active { transform: scale(0.9); }
  .creator-step-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    color: var(--text-dim);
    letter-spacing: 1px;
    flex: 1;
  }
  .creator-step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: var(--accent);
    letter-spacing: 1px;
  }

  .creator-progress-track {
    height: 5px;
    background: var(--bg-1);
    border-radius: 3px;
    overflow: hidden;
  }
  .creator-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-dim), var(--accent));
    border-radius: 3px;
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .creator-content {
    flex: 1;
    overflow-y: auto;
    padding: 24px 20px;
    padding-bottom: calc(120px + env(safe-area-inset-bottom));
  }
  .creator-content::-webkit-scrollbar { width: 6px; }
  .creator-content::-webkit-scrollbar-thumb { background: var(--bg-5); border-radius: 3px; }

  .creator-step-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    text-align: center;
    margin-bottom: 6px;
    letter-spacing: 1.5px;
    line-height: 1.1;
  }
  .creator-step-hint {
    text-align: center;
    color: var(--text-dim);
    font-size: 13px;
    margin-bottom: 28px;
    font-weight: 500;
    line-height: 1.4;
  }

  /* Adım 1: isim girişi */
  .creator-name-input {
    width: 100%;
    background: var(--bg-3);
    border: 2px solid var(--border-strong);
    border-radius: 16px;
    padding: 16px 20px;
    color: var(--text);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 1.5px;
    text-align: center;
    outline: none;
    transition: all 0.2s;
  }
  .creator-name-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(0,229,176,0.15);
  }
  .creator-name-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
    justify-content: center;
  }
  .creator-name-chip {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 22px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--text-dim);
  }
  .creator-name-chip:active {
    transform: scale(0.95);
    background: var(--accent);
    color: var(--bg-0);
    border-color: var(--accent);
  }

  /* Adım 2: pozisyon kartları */
  .creator-position-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .creator-position-card {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 2px solid var(--border);
    border-radius: 18px;
    padding: 18px 14px;
    cursor: pointer;
    text-align: center;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  .creator-position-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top, var(--accent-glow), transparent 70%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .creator-position-card:active { transform: scale(0.96); }
  .creator-position-card.selected {
    border-color: var(--accent);
    box-shadow: 0 8px 24px var(--accent-glow);
    transform: scale(1.02);
  }
  .creator-position-card.selected::before { opacity: 0.5; }
  .creator-position-icon {
    font-size: 44px;
    margin-bottom: 8px;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
  }
  .creator-position-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    line-height: 1;
  }
  .creator-position-tag {
    font-size: 11px;
    color: var(--accent);
    margin-top: 4px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .creator-position-desc {
    font-size: 11px;
    color: var(--text-dim);
    margin-top: 8px;
    line-height: 1.4;
    font-weight: 500;
  }

  /* Adım 3: görünüm — preview + renkler */
  .creator-preview {
    background: linear-gradient(180deg, var(--pitch-2), var(--pitch-1));
    border-radius: 22px;
    padding: 20px;
    margin-bottom: 20px;
    height: 180px;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .creator-preview::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(90deg,
      transparent 0, transparent 24px,
      rgba(255,255,255,0.04) 24px, rgba(255,255,255,0.04) 48px);
  }
  .creator-preview-char {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 96px;
    animation: idle 1.4s ease-in-out infinite;
  }
  .creator-preview-shadow {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 70px;
    height: 12px;
    background: radial-gradient(ellipse, rgba(0,0,0,0.4), transparent 70%);
    animation: shadowPulse 1.2s ease-in-out infinite;
  }

  .creator-color-section {
    margin-bottom: 22px;
  }
  .creator-color-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    color: var(--text-dim);
    margin-bottom: 10px;
    letter-spacing: 1px;
  }
  .creator-color-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }

  /* Adım 4: stat dağılımı */
  .creator-stat-pool {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    padding: 14px 18px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .creator-stat-pool-label {
    font-size: 12px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }
  .creator-stat-pool-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--accent);
    text-shadow: 0 0 16px var(--accent-glow);
    line-height: 1;
  }
  .creator-stat-pool-value.empty { color: var(--text-mute); text-shadow: none; }

  .creator-stat-row {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .creator-stat-icon {
    font-size: 28px;
    width: 36px;
    text-align: center;
  }
  .creator-stat-info {
    flex: 1;
  }
  .creator-stat-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 17px;
    letter-spacing: 0.5px;
  }
  .creator-stat-bar {
    height: 6px;
    background: var(--bg-1);
    border-radius: 3px;
    margin-top: 6px;
    overflow: hidden;
  }
  .creator-stat-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-dim), var(--accent));
    border-radius: 3px;
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .creator-stat-controls {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .creator-stat-btn {
    width: 32px; height: 32px;
    border-radius: 10px;
    background: var(--bg-4);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }
  .creator-stat-btn:active { transform: scale(0.85); background: var(--accent); color: var(--bg-0); }
  .creator-stat-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }
  .creator-stat-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: var(--accent);
    width: 32px;
    text-align: center;
  }

  /* Sabit alt buton barı */
  .creator-footer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 14px 20px calc(14px + env(safe-area-inset-bottom));
    background: linear-gradient(180deg, transparent, var(--bg-1) 30%);
    z-index: 10;
  }
  .creator-next-btn {
    width: 100%;
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    border: none;
    border-radius: 16px;
    padding: 16px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    cursor: pointer;
    box-shadow: 0 4px 16px var(--accent-glow);
    transition: all 0.2s;
  }
  .creator-next-btn:active { transform: scale(0.97); }
  .creator-next-btn:disabled {
    background: var(--bg-4);
    color: var(--text-mute);
    cursor: not-allowed;
    box-shadow: none;
  }

  /* v10: Saç stili butonları */
  .hairstyle-btn {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 2px solid var(--border);
    border-radius: 14px;
    padding: 12px 6px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    color: var(--text);
  }
  .hairstyle-btn:active { transform: scale(0.92); }
  .hairstyle-btn.selected {
    border-color: var(--accent);
    background: linear-gradient(135deg, rgba(0,229,176,0.15), var(--bg-2));
    box-shadow: 0 4px 16px var(--accent-glow);
  }

  /* ============================================
     TSUBASA BAR (v11)
     ============================================ */
  .tsubasa-bar-container {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 8px 0;
    padding: 8px 12px;
    background: rgba(0,0,0,0.4);
    border: 1px solid var(--border);
    border-radius: 12px;
    z-index: 2;
    position: relative;
  }
  .tsubasa-bar-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 12px;
    letter-spacing: 1px;
    color: var(--warm);
    text-shadow: 0 0 6px var(--warm-glow);
    white-space: nowrap;
  }
  .tsubasa-bar-track {
    flex: 1;
    height: 14px;
    background: var(--bg-1);
    border-radius: 7px;
    overflow: hidden;
    position: relative;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.6);
  }
  .tsubasa-bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--warm), #ff6b35 50%, var(--danger));
    border-radius: 7px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    box-shadow: 0 0 8px var(--warm-glow);
  }
  .tsubasa-bar-fill.mega {
    background: linear-gradient(90deg, var(--gold), #ff6b35, var(--danger), var(--purple));
    animation: megaPulse 0.8s ease-in-out infinite;
    box-shadow: 0 0 16px var(--gold), 0 0 24px var(--warm);
  }
  @keyframes megaPulse {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.4) saturate(1.3); }
  }
  .tsubasa-bar-fill::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.3), transparent);
    border-radius: 7px;
  }
  .tsubasa-bar-segments {
    position: absolute;
    inset: 0;
    display: flex;
    pointer-events: none;
  }
  .tsubasa-bar-segments span {
    flex: 1;
    border-right: 1px solid rgba(0,0,0,0.3);
  }
  .tsubasa-bar-segments span:last-child { border-right: none; }
  .tsubasa-bar-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    color: var(--text);
    letter-spacing: 1px;
    min-width: 36px;
    text-align: right;
  }

  /* Özel şut seçim kartları */
  .special-shots-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 12px;
  }
  .special-shot-btn {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 2px solid var(--border-strong);
    border-radius: 14px;
    padding: 12px 8px;
    cursor: pointer;
    text-align: center;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  .special-shot-btn:active { transform: scale(0.94); }
  .special-shot-icon {
    font-size: 36px;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4));
    margin-bottom: 4px;
    line-height: 1;
  }
  .special-shot-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    letter-spacing: 1px;
    line-height: 1;
  }
  .special-shot-desc {
    font-size: 9px;
    color: var(--text-dim);
    margin-top: 4px;
    line-height: 1.2;
  }
  .special-shot-cost {
    background: var(--warm);
    color: var(--bg-0);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 6px;
    display: inline-block;
    margin-top: 4px;
    letter-spacing: 0.5px;
  }
  .normal-shot-section {
    border: 1px dashed var(--border-strong);
    border-radius: 12px;
    padding: 8px;
    margin-bottom: 10px;
    text-align: center;
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 700;
    cursor: pointer;
  }
  .normal-shot-section:active { background: var(--bg-3); }

  /* ============================================
     ÖZEL ŞUT CINEMATIC v12 — Tsubasa Tarzı
     Çok katmanlı: hayvan ruhu, top kuyruğu,
     file patlama, time-stop, zoom-out finali
     ============================================ */
  .special-shot-cinematic {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 350;
    overflow: hidden;
    pointer-events: none;
  }
  .special-shot-cinematic.active { display: flex; }

  /* Karanlık arka plan + zoom-in */
  .special-shot-cinematic .ssc-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center,
      rgba(255,69,0,0.5), rgba(0,0,0,0.97) 80%);
    animation: sscBgZoomIn 1.2s cubic-bezier(0.34, 0.05, 0.34, 1) forwards;
  }
  @keyframes sscBgZoomIn {
    0% { opacity: 0; transform: scale(2); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* Speed lines — yön bazlı, soldan sağa akış */
  .special-shot-cinematic .ssc-speed-lines {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        90deg,
        transparent 0,
        transparent 8px,
        rgba(255,255,255,0.18) 8px,
        rgba(255,255,255,0.18) 9px,
        transparent 9px,
        transparent 25px
      );
    animation: speedLinesFlow 0.4s linear infinite;
    opacity: 0;
    animation-fill-mode: forwards;
    animation-name: speedLinesFlow, speedLinesFadeIn;
    animation-duration: 0.4s, 0.4s;
    animation-iteration-count: infinite, 1;
    mix-blend-mode: screen;
  }
  @keyframes speedLinesFlow {
    0% { background-position: 0 0; }
    100% { background-position: -50px 0; }
  }
  @keyframes speedLinesFadeIn {
    0% { opacity: 0; }
    100% { opacity: 1; }
  }

  /* Dikey speed lines için ek katman */
  .special-shot-cinematic .ssc-radial-lines {
    position: absolute;
    inset: -10%;
    background-image:
      repeating-radial-gradient(
        circle at 50% 50%,
        transparent 0,
        transparent 4px,
        rgba(255,255,255,0.12) 4px,
        rgba(255,255,255,0.12) 5px
      );
    animation: radialPulse 2s ease-in-out infinite;
    opacity: 0.6;
    mix-blend-mode: screen;
  }
  @keyframes radialPulse {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.15); opacity: 0.7; }
  }

  /* Time-stop overlay — cinematic ortasında zaman durmuş hissi */
  .special-shot-cinematic .ssc-time-stop {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center,
      rgba(255,255,255,0.4),
      transparent 60%);
    opacity: 0;
    animation: timeStopFlash 0.5s 0.9s ease-in-out;
  }
  @keyframes timeStopFlash {
    0% { opacity: 0; }
    30% { opacity: 1; }
    100% { opacity: 0; }
  }

  /* HAYVAN RUHU — yarı saydam dev hayvan oyuncunun arkasında */
  .special-shot-cinematic .ssc-spirit {
    position: absolute;
    font-size: 280px;
    opacity: 0;
    z-index: 1;
    filter: drop-shadow(0 0 40px currentColor) blur(0.5px);
    animation: spiritRise 1.4s cubic-bezier(0.4, 0, 0.2, 1) both,
               spiritFade 1.4s ease-out both;
    mix-blend-mode: screen;
  }
  @keyframes spiritRise {
    0% { transform: translateY(150px) scale(0.4) rotate(-20deg); }
    40% { transform: translateY(0) scale(1.1) rotate(0deg); }
    70% { transform: translateY(-20px) scale(1.05) rotate(2deg); }
    100% { transform: translateY(-40px) scale(1) rotate(0deg); }
  }
  @keyframes spiritFade {
    0% { opacity: 0; }
    20% { opacity: 0.45; }
    70% { opacity: 0.55; }
    100% { opacity: 0; }
  }

  /* Şut atan karakter — havaya zıplayıp donar */
  .special-shot-cinematic .ssc-player {
    position: absolute;
    bottom: 18%;
    left: 18%;
    z-index: 3;
    transform-origin: bottom center;
    animation: ssPlayerLeap 1.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    filter: drop-shadow(0 0 20px currentColor);
  }
  @keyframes ssPlayerLeap {
    0% { transform: translate(-30px, 40px) scale(0.7) rotate(-15deg); opacity: 0; }
    30% { transform: translate(0, -40px) scale(1.1) rotate(-5deg); opacity: 1; }
    60% { transform: translate(0, -60px) scale(1) rotate(-3deg); opacity: 1; }
    100% { transform: translate(0, -60px) scale(1) rotate(-3deg); opacity: 1; }
  }

  /* Top'un yangınlı yolculuğu */
  .ssc-fireball-trail {
    position: absolute;
    bottom: 35%;
    left: 30%;
    z-index: 4;
    pointer-events: none;
    animation: fireballFlight 1.2s 0.6s cubic-bezier(0.4, 0, 0.6, 1) both;
  }
  @keyframes fireballFlight {
    0% { transform: translateX(0) translateY(0) scale(0.5); opacity: 0; }
    20% { transform: translateX(0) translateY(0) scale(1); opacity: 1; }
    100% { transform: translateX(70vw) translateY(-30px) scale(1.4); opacity: 1; }
  }

  .ssc-fireball-main {
    width: 40px;
    height: 40px;
    background: radial-gradient(circle at 30% 30%, #fff8d4, #ff6b00 50%, #cc0000);
    border-radius: 50%;
    box-shadow:
      0 0 24px #ff6b00,
      0 0 48px #ff4500,
      inset -4px -4px 8px rgba(0,0,0,0.4);
    animation: fireballSpin 0.15s linear infinite;
    position: relative;
  }
  @keyframes fireballSpin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Ateş kuyruğu izleyenler */
  .ssc-flame-tail {
    position: absolute;
    top: 50%;
    right: 100%;
    width: 80px;
    height: 50px;
    transform: translateY(-50%);
    background:
      radial-gradient(ellipse at 100% 50%, rgba(255,180,0,0.9), transparent 70%),
      radial-gradient(ellipse at 80% 50%, rgba(255,100,0,0.7), transparent 60%);
    filter: blur(1px);
    animation: flameTailFlicker 0.1s ease-in-out infinite alternate;
  }
  @keyframes flameTailFlicker {
    0% { transform: translateY(-50%) scaleX(1) scaleY(1); }
    100% { transform: translateY(-50%) scaleX(1.1) scaleY(0.9); }
  }

  /* Ateş izi parçaları — kalan top yansımaları */
  .ssc-fireball-ghost {
    position: absolute;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,140,0,0.7), transparent 70%);
    pointer-events: none;
    animation: ghostFade 0.6s ease-out forwards;
  }
  @keyframes ghostFade {
    0% { opacity: 0.8; transform: scale(1); }
    100% { opacity: 0; transform: scale(0.3); }
  }

  /* İkon ortada — devleşmiş, time-stop sırasında */
  .special-shot-cinematic .ssc-icon {
    font-size: 180px;
    z-index: 5;
    filter: drop-shadow(0 0 48px currentColor)
            drop-shadow(0 0 96px currentColor);
    animation: sscIconMega 1.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    position: relative;
  }
  @keyframes sscIconMega {
    0% { transform: scale(0) rotate(-360deg); opacity: 0; }
    30% { transform: scale(1.6) rotate(30deg); opacity: 1; }
    50% { transform: scale(1.3) rotate(-10deg); opacity: 1; }
    65% { transform: scale(1.45) rotate(5deg); opacity: 1; }
    100% { transform: scale(0.5) rotate(0deg); opacity: 0; }
  }

  /* Başlık — anime tarzı slam */
  .special-shot-cinematic .ssc-title {
    position: absolute;
    top: 16%;
    left: 0; right: 0;
    text-align: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 56px;
    color: white;
    letter-spacing: 6px;
    text-shadow:
      4px 4px 0 var(--bg-0),
      -2px -2px 0 var(--bg-0),
      0 0 24px currentColor,
      0 0 48px currentColor;
    z-index: 6;
    animation: sscTitleSlamV2 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
               sscTitleShake 0.4s 0.6s ease-in-out;
    line-height: 1;
  }
  @keyframes sscTitleSlamV2 {
    0% { transform: translateY(-200px) scale(3) rotate(-15deg); opacity: 0; }
    50% { transform: translateY(20px) scale(1.3) rotate(5deg); opacity: 1; }
    80% { transform: translateY(0) scale(0.95) rotate(-2deg); opacity: 1; }
    100% { transform: translateY(0) scale(1) rotate(0); opacity: 1; }
  }
  @keyframes sscTitleShake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  .special-shot-cinematic .ssc-subtitle {
    position: absolute;
    bottom: 18%;
    left: 0; right: 0;
    text-align: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: var(--gold);
    letter-spacing: 4px;
    z-index: 6;
    text-shadow: 0 0 16px rgba(255,215,0,0.6);
    animation: sscSubInV2 0.6s 0.7s cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  @keyframes sscSubInV2 {
    0% { transform: translateY(30px); opacity: 0; letter-spacing: 12px; }
    100% { transform: translateY(0); opacity: 1; letter-spacing: 4px; }
  }

  /* Partikül uçuşları — radial patlamadan */
  .ssc-particle {
    position: absolute;
    width: 8px; height: 8px;
    background: currentColor;
    border-radius: 50%;
    box-shadow: 0 0 12px currentColor, 0 0 24px currentColor;
    animation: sscParticleFlyV2 1.4s cubic-bezier(0.4, 0, 0.6, 1) forwards;
    z-index: 4;
  }
  @keyframes sscParticleFlyV2 {
    0% { transform: translate(0, 0) scale(0); opacity: 1; }
    20% { transform: translate(calc(var(--dx) * 0.4), calc(var(--dy) * 0.4)) scale(1.5); opacity: 1; }
    100% { transform: translate(var(--dx), var(--dy)) scale(0); opacity: 0; }
  }

  /* Kale + file patlaması (cinematic'in son sahnesi) */
  .ssc-goal-impact {
    position: absolute;
    right: 8%;
    top: 35%;
    width: 120px;
    height: 90px;
    opacity: 0;
    z-index: 4;
    animation: goalImpactIn 0.5s 1.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  @keyframes goalImpactIn {
    0% { opacity: 0; transform: scale(0.3); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* File - şutla deforme olur */
  .ssc-net {
    position: absolute;
    inset: 0;
    border: 4px solid white;
    border-right: none;
    border-radius: 4px 0 0 4px;
    background:
      repeating-linear-gradient(
        0deg, transparent 0, transparent 6px,
        rgba(255,255,255,0.3) 6px, rgba(255,255,255,0.3) 7px
      ),
      repeating-linear-gradient(
        90deg, transparent 0, transparent 6px,
        rgba(255,255,255,0.3) 6px, rgba(255,255,255,0.3) 7px
      );
    animation: netRipple 0.4s 1.7s cubic-bezier(0.36, 0.07, 0.19, 0.97);
  }
  @keyframes netRipple {
    0% { transform: skewX(0) scaleX(1); }
    30% { transform: skewX(-12deg) scaleX(0.85); }
    60% { transform: skewX(8deg) scaleX(1.05); }
    100% { transform: skewX(0) scaleX(1); }
  }

  /* Final zoom — cinematic kapatma */
  .special-shot-cinematic.zooming-out .ssc-icon,
  .special-shot-cinematic.zooming-out .ssc-title,
  .special-shot-cinematic.zooming-out .ssc-subtitle {
    animation: ssZoomOut 0.4s cubic-bezier(0.4, 0, 0.6, 1) forwards;
  }
  @keyframes ssZoomOut {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(0.5); opacity: 0; }
  }

  /* ============================================
     SPIRIT ANIMAL renkleri (her şut için farklı) */
  .ssc-spirit.kaplan { color: #ff4500; }
  .ssc-spirit.kartal { color: #4a90e2; }
  .ssc-spirit.yildirim { color: #ffd700; }
  .ssc-spirit.tayfun { color: #7ec8e3; }
  .ssc-spirit.gokkusagi { color: #a78bfa; }
  .ssc-spirit.ejderha { color: #dc143c; }

  /* Çizgi roman karesi */
  .comic-strip {
    position: absolute;
    inset: 0;
    display: none;
    z-index: 360;
    background: rgba(0,0,0,0.9);
    overflow: hidden;
    pointer-events: none;
  }
  .comic-strip.active { display: block; }
  .comic-panel {
    position: absolute;
    background: var(--bg-3);
    border: 4px solid var(--bg-0);
    box-shadow: 0 8px 24px rgba(0,0,0,0.8);
    overflow: hidden;
  }
  .comic-panel-1 {
    top: 5%; left: 5%;
    width: 45%; height: 32%;
    animation: comicPanel1In 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .comic-panel-2 {
    top: 7%; right: 5%;
    width: 45%; height: 32%;
    animation: comicPanel2In 0.4s 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .comic-panel-3 {
    bottom: 6%; left: 50%;
    transform: translateX(-50%);
    width: 80%; height: 50%;
    animation: comicPanel3In 0.4s 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes comicPanel1In {
    0% { transform: scale(0.5) rotate(-15deg); opacity: 0; }
    100% { transform: scale(1) rotate(-2deg); opacity: 1; }
  }
  @keyframes comicPanel2In {
    0% { transform: scale(0.5) rotate(15deg); opacity: 0; }
    100% { transform: scale(1) rotate(2deg); opacity: 1; }
  }
  @keyframes comicPanel3In {
    0% { transform: translateX(-50%) scale(0.3); opacity: 0; }
    100% { transform: translateX(-50%) scale(1); opacity: 1; }
  }
  .comic-panel-content {
    width: 100%;
    height: 100%;
    background:
      repeating-linear-gradient(
        from 45deg at 50% 50%,
        rgba(255,255,255,0.05) 0deg,
        transparent 8deg,
        transparent 20deg
      ),
      radial-gradient(ellipse at center, var(--pitch-2), var(--pitch-1));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .comic-emoji {
    font-size: 72px;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.6));
    animation: comicEmojiPulse 0.6s ease-out;
  }
  @keyframes comicEmojiPulse {
    0% { transform: scale(0); }
    100% { transform: scale(1); }
  }
  .comic-balloon {
    position: absolute;
    background: var(--gold);
    color: var(--bg-0);
    padding: 8px 16px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 2px;
    border: 3px solid var(--bg-0);
    border-radius: 50% 30% 50% 30% / 40% 50% 40% 50%;
    transform: rotate(-5deg);
    box-shadow: 4px 4px 0 var(--bg-0);
    animation: comicBalloonPop 0.4s 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes comicBalloonPop {
    0% { transform: rotate(-5deg) scale(0); opacity: 0; }
    100% { transform: rotate(-5deg) scale(1); opacity: 1; }
  }
  .comic-balloon.blam { top: 12%; left: 18%; background: var(--danger); color: white; }
  .comic-balloon.kapow { top: 8%; right: 12%; background: var(--accent); transform: rotate(8deg); }
  .comic-balloon.gol { bottom: 18%; right: 15%; background: var(--gold); transform: rotate(-3deg); font-size: 32px; }
  .comic-hattrick-title {
    position: absolute;
    top: 47%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 56px;
    color: var(--gold);
    letter-spacing: 5px;
    text-shadow:
      4px 4px 0 var(--bg-0),
      -2px -2px 0 var(--bg-0),
      0 0 32px var(--gold);
    z-index: 5;
    animation: comicHattrickIn 0.8s 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    text-align: center;
    line-height: 1;
  }
  @keyframes comicHattrickIn {
    0% { transform: translate(-50%, -50%) scale(0) rotate(-30deg); opacity: 0; }
    60% { transform: translate(-50%, -50%) scale(1.3) rotate(5deg); opacity: 1; }
    100% { transform: translate(-50%, -50%) scale(1) rotate(0); opacity: 1; }
  }

  /* Süper kutlama */
  .super-celebration {
    position: absolute;
    inset: 0;
    display: none;
    z-index: 370;
    pointer-events: none;
    align-items: center;
    justify-content: center;
  }
  .super-celebration.active { display: flex; }
  .saiyan-aura {
    position: absolute;
    width: 240px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      rgba(255,215,0,0.6) 0%,
      rgba(255,184,0,0.3) 40%,
      transparent 70%);
    animation: saiyanPulse 0.4s ease-in-out infinite;
    filter: blur(8px);
  }
  @keyframes saiyanPulse {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.15); opacity: 1; }
  }

  /* Ekran sallama */
  .screen-shake {
    animation: screenShake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
  }
  @keyframes screenShake {
    10%, 90% { transform: translate3d(-2px, 0, 0); }
    20%, 80% { transform: translate3d(4px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-6px, 0, 0); }
    40%, 60% { transform: translate3d(6px, 0, 0); }
  }

  /* Başlangıç giriş ekranı: yarat / hazır seç */
  .start-options-modal {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--pitch-2), var(--bg-0));
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 820;
    padding: 32px;
  }
  .start-options-modal.active { display: flex; animation: fadeIn 0.4s; }
  .start-options-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: var(--accent);
    letter-spacing: 3px;
    margin-bottom: 8px;
    text-shadow: 0 0 16px var(--accent-glow);
    text-align: center;
  }
  .start-options-hint {
    color: var(--text-dim);
    font-size: 14px;
    margin-bottom: 36px;
    text-align: center;
    line-height: 1.5;
    letter-spacing: 0.5px;
  }
  .start-option-btn {
    width: 100%;
    max-width: 320px;
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 2px solid var(--border-strong);
    border-radius: 18px;
    padding: 20px;
    margin-bottom: 14px;
    cursor: pointer;
    text-align: left;
    transition: all 0.25s;
    display: flex;
    align-items: center;
    gap: 16px;
    color: var(--text);
  }
  .start-option-btn.primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    border-color: var(--accent);
    box-shadow: 0 8px 24px var(--accent-glow);
  }
  .start-option-btn:active { transform: scale(0.97); }
  .start-option-icon { font-size: 38px; }
  .start-option-text { flex: 1; }
  .start-option-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1.5px;
    line-height: 1;
  }
  .start-option-desc {
    font-size: 12px;
    margin-top: 4px;
    opacity: 0.8;
    font-weight: 500;
  }

  /* ============================================
     SLOT SEÇİM EKRANI (v9)
     ============================================ */
  .slots-modal {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--bg-1), var(--bg-0));
    display: none;
    flex-direction: column;
    z-index: 830;
    padding-top: max(0px, env(safe-area-inset-top));
  }
  .slots-modal.active { display: flex; animation: fadeIn 0.4s; }

  .slots-header {
    padding: 24px 20px 16px;
    text-align: center;
    flex-shrink: 0;
  }
  .slots-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--accent);
    letter-spacing: 2.5px;
    line-height: 1;
    text-shadow: 0 0 12px var(--accent-glow);
  }
  .slots-subtitle {
    color: var(--text-dim);
    font-size: 13px;
    margin-top: 6px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 500;
  }

  .slots-list {
    flex: 1;
    overflow-y: auto;
    padding: 0 16px 24px;
  }

  .save-slot-card {
    background: linear-gradient(135deg, var(--bg-3), var(--bg-2));
    border: 2px solid var(--border-strong);
    border-radius: 18px;
    padding: 18px;
    margin-bottom: 12px;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  .save-slot-card:active {
    transform: scale(0.98);
    border-color: var(--accent);
  }
  .save-slot-card.empty {
    border-style: dashed;
    background: transparent;
    padding: 28px 18px;
    text-align: center;
  }
  .save-slot-card.empty .slot-empty-icon {
    font-size: 32px;
    margin-bottom: 6px;
    opacity: 0.5;
  }
  .save-slot-card.empty .slot-empty-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 1.5px;
    color: var(--text-dim);
  }

  .slot-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .slot-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    color: var(--text-mute);
    letter-spacing: 2px;
  }
  .slot-delete-btn {
    background: var(--bg-4);
    border: 1px solid var(--border);
    color: var(--text-dim);
    width: 30px; height: 30px;
    border-radius: 9px;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .slot-delete-btn:active {
    transform: scale(0.85);
    background: var(--danger);
    color: white;
    border-color: var(--danger);
  }

  .slot-player-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    line-height: 1;
    margin-bottom: 4px;
  }
  .slot-player-meta {
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
  }
  .slot-stats-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .slot-stat {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .slot-stat-label {
    font-size: 9px;
    color: var(--text-mute);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 700;
  }
  .slot-stat-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    color: var(--text);
    line-height: 1;
  }
  .slot-retired-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    background: var(--bg-1);
    border: 1px solid var(--text-mute);
    color: var(--text-mute);
    padding: 3px 9px;
    border-radius: 6px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  /* ============================================
     CINEMATIC MANŞET HABER (v9)
     ============================================ */
  .cinematic-news {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.85), rgba(0,0,0,0.96));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 880;
    padding: 32px 24px;
  }
  .cinematic-news.active { display: flex; }

  .cinematic-news::before,
  .cinematic-news::after {
    content: '';
    position: absolute;
    left: 24px; right: 24px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    animation: cineBorderIn 0.6s 0.2s cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  .cinematic-news::before { top: 80px; }
  .cinematic-news::after { bottom: 80px; }
  .cinematic-news.gold::before,
  .cinematic-news.gold::after {
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .cinematic-news.urgent::before,
  .cinematic-news.urgent::after {
    background: linear-gradient(90deg, transparent, var(--danger), transparent);
  }
  @keyframes cineBorderIn {
    0% { transform: scaleX(0); opacity: 0; }
    100% { transform: scaleX(1); opacity: 1; }
  }

  .cinematic-header-tag {
    background: var(--accent);
    color: var(--bg-0);
    padding: 6px 16px;
    border-radius: 22px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 2px;
    margin-bottom: 28px;
    animation: cineTagIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .cinematic-header-tag.urgent {
    background: var(--danger);
    color: white;
  }
  .cinematic-header-tag.gold {
    background: var(--gold);
    color: var(--bg-0);
  }
  @keyframes cineTagIn {
    0% { transform: translateY(-30px) scale(0.5); opacity: 0; }
    100% { transform: translateY(0) scale(1); opacity: 1; }
  }

  .cinematic-icon {
    font-size: 96px;
    margin-bottom: 24px;
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.5));
    animation: cineIconIn 0.8s 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes cineIconIn {
    0% { transform: scale(0) rotate(-30deg); opacity: 0; }
    100% { transform: scale(1) rotate(0); opacity: 1; }
  }

  .cinematic-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 38px;
    color: white;
    text-align: center;
    line-height: 1.1;
    letter-spacing: 2px;
    margin-bottom: 16px;
    animation: cineTitleIn 0.7s 0.4s cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  .cinematic-title span {
    color: var(--accent);
    text-shadow: 0 0 24px var(--accent-glow);
  }
  .cinematic-news.gold .cinematic-title span {
    color: var(--gold);
    text-shadow: 0 0 24px rgba(255,215,0,0.6);
  }
  .cinematic-news.urgent .cinematic-title span {
    color: var(--danger);
    text-shadow: 0 0 24px var(--danger-glow);
  }
  @keyframes cineTitleIn {
    0% { transform: translateY(20px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  .cinematic-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: rgba(255,255,255,0.75);
    text-align: center;
    line-height: 1.5;
    max-width: 360px;
    margin-bottom: 28px;
    animation: cineSubIn 0.7s 0.7s cubic-bezier(0.4, 0, 0.2, 1) both;
    font-weight: 500;
  }
  @keyframes cineSubIn {
    0% { transform: translateY(15px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  .cinematic-date-line {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 36px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 600;
    animation: cineSubIn 0.7s 0.9s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  .cinematic-dismiss {
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    color: var(--bg-0);
    border: none;
    border-radius: 16px;
    padding: 14px 36px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    cursor: pointer;
    box-shadow: 0 4px 16px var(--accent-glow);
    transition: transform 0.15s;
    animation: cineCtaIn 0.7s 1.1s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .cinematic-dismiss:active { transform: scale(0.95); }
  @keyframes cineCtaIn {
    0% { transform: translateY(30px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* ============================================
     GIZLI GÖRÜŞME (v9)
     ============================================ */
  .secret-meeting-modal {
    position: absolute;
    inset: 0;
    background-color: #1a1410;
    background-image:
      radial-gradient(ellipse at center, rgba(80,50,20,0.4), rgba(10,5,0,0.95));
    display: none;
    flex-direction: column;
    z-index: 870;

// ============================================================
const SAVE_PREFIX = 'futbolcum_v9_slot_';
const LEGACY_SAVE_KEY = 'futbolcum_v5_save'; // eski versiyonlardan
let currentSlot = 1; // aktif slot — load ile değişir

function saveKey(slot) {
  return SAVE_PREFIX + slot;
}

function save() {
  try {
    localStorage.setItem(saveKey(currentSlot), JSON.stringify(state));
  } catch(e) {}
}

function loadSlot(slot) {
  try {
    const data = localStorage.getItem(saveKey(slot));
    if (data) {
      state = Object.assign(DEFAULT_STATE(), JSON.parse(data));
      currentSlot = slot;
      return true;
    }
  } catch(e) {}
  return false;
}

function deleteSlot(slot) {
  try { localStorage.removeItem(saveKey(slot)); } catch(e) {}
}

// Bir slot'un meta bilgisini döndür (slot seçim ekranında gösterilir)
function getSlotInfo(slot) {
  try {
    const data = localStorage.getItem(saveKey(slot));
    if (!data) return null;
    const s = JSON.parse(data);
    if (!s.name) return null;
    return {
      name: s.name,
      season: s.season || 1,
      week: s.week || 1,
      age: s.age || 17,
      pos: s.pos || '—',
      money: s.money || 0,
      goals: s.goals || 0,
      matches: s.matches || 0,
      date: s.gameDate || '2025-08-01',
      retired: s.retired || false,
    };
  } catch(e) { return null; }
}


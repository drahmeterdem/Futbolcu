function selectPlayer(idx) {
  if (actionLock) return;
  lock();
  const p = PLAYERS[idx];
  state.selected = idx;
  state.name = p.name;
  state.pos = p.pos;
  state.skill = p.skill;
  state.hair = p.hair;
  state.jersey = p.jersey;
  state.skinTone = 'light';
  state.teamIndex = idx % TEAMS.length;

  // v7: hazır oyunculara da pozisyonId ve alt-statlar atanıyor
  // pos kısaltmasını ID'ye çevir (OOS->orta, KAN->kanat, FRV->forvet, DEF->defans)
  const posByShort = POSITIONS.find(po => po.short === p.pos);
  state.positionId = posByShort ? posByShort.id : 'orta';
  // Alt-statlar skill'e göre dağıtılıyor — hazır oyuncularda eşit
  state.sut = p.skill;
  state.pas = p.skill;
  state.defans = p.skill;
  state.hiz = p.skill;

  initLeague();
  drawCharacter(document.getElementById('player'), p.hair, p.jersey, false, 'normal', state.skinTone);
  closeAll();
  showMessage(`${p.name} seçildi!`, 'event');
  addNews(`⚽ Yeni transfer: ${state.name} → ${TEAMS[state.teamIndex]}`);
  SFX.levelup();
  showSparkles(10);
  save();
  updateUI();
}


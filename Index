      subtitle: `${TEAMS[state.teamIndex]} forması altında 3 gol — bu maç hatırlanacak.`,
      type: 'gold',
    }), 2500);
  }

  // Milli takım çağrısı: eski kodda nationalCaps === 0 koşulu vardı
  // yani sadece ilk maçta çağrı geliyordu. Gerçek hayatta milli forma
  // sürekli giyilir, dolayısıyla şöhret yüksekken her maç sonrası küçük
  // bir ihtimalle çağrı alınmalı. İlk çağrı %15, sonrakiler %8 ihtimal.
  const callChance = state.nationalCaps === 0 ? 0.15 : 0.08;
  if (state.fame > 70 && Math.random() < callChance) {
    state.nationalCaps++;
    state.fame = clamp(state.fame + 5);
    state.money += 1500; // milli maç ücreti
    addNews(`🇹🇷 ${state.name} milli takımda forma giydi (${state.nationalCaps}. kez)`);
    // v9: ilk milli çağrı cinematic
    if (state.nationalCaps === 1) {
      setTimeout(() => showCinematicNews({
        tag: 'MİLLİ DAVA',
        icon: '🇹🇷',
        title: `${state.name.split(' ')[0]} <span>MİLLİ TAKIM</span>'A`,

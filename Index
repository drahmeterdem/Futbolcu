// v11: özel şut işleme — cinematic + skor hesaplama
function processSpecialShot(shot) {
  // Tsubasa barını tüket
  tsubasaBarValue = Math.max(0, tsubasaBarValue - shot.requiredBar);
  updateTsubasaBar();

  // Lifetime unlock
  unlockSpecialShot(shot.id);

  // Cinematic, sonra sonuç hesapla
  playSpecialShotCinematic(shot, () => {
    const eventEl = document.getElementById('match-event');
    const sutStat = state.sut || state.skill;
    // Özel şutlar yüksek isabet + güç çarpanlı
    const baseAccuracy = 0.85;
    const accuracyBoost = (sutStat - 50) / 250;
    const finalAccuracy = Math.min(0.97, baseAccuracy + accuracyBoost);
    const isAccurate = Math.random() < finalAccuracy;

    // Kaleci kurtarma şansı düşük (saveReduction)
    const baseSaveChance = 0.25;
    const saveChance = baseSaveChance * shot.saveReduction;
    const saved = isAccurate && (Math.random() < saveChance);

    let result;
    if (!isAccurate) result = 'miss';
    else if (saved) result = 'save';
    else result = 'goal';

    const miniPlayer = document.getElementById('match-mini-player');
    const miniBall = document.getElementById('match-mini-ball');
    const miniBallShadow = document.getElementById('match-mini-ball-shadow');
    if (miniPlayer) {
      miniPlayer.className = 'match-mini-player mini-charging';
      setTimeout(() => {
        miniPlayer.className = 'match-mini-player mini-running charging-pos';
        if (miniBall) miniBall.classList.add('shot');
        if (miniBallShadow) miniBallShadow.classList.add('shot');
      }, 200);
    }

    setTimeout(() => {
      if (result === 'goal') {
        matchCtx.myGoals++;
        showGoalFlash();
        shakeScreen();
        setTimeout(() => {
          const scoreEl = document.getElementById('match-my-score');
          scoreEl.textContent = matchCtx.myGoals;
          scoreEl.classList.remove('scored');
          void scoreEl.offsetWidth;
          scoreEl.classList.add('scored');
          eventEl.className = 'match-event gol';
          eventEl.textContent = `⚡ ${shot.name} GOL!`;
          if (miniPlayer) miniPlayer.className = 'match-mini-player mini-celebrating charging-pos';
        }, 600);
        // Hat-trick kontrolü
        if (matchCtx.myGoals === 3) {
          setTimeout(() => playComicStrip(), 1400);
        } else {
          setTimeout(() => playSuperCelebration(), 1400);
        }
        // Bar yine dolsun (özel şut gol = bonus)
        addTsubasaBar(2);
      } else if (result === 'save') {
        eventEl.className = 'match-event fail';
        eventEl.textContent = `🧤 Kaleci ${shot.name}'yi kurtardı!`;
      } else {
        eventEl.className = 'match-event fail';
        eventEl.textContent = `${shot.name} az farkla kaçtı!`;
      }
    }, 1100);

    // Bir sonraki olaya geç
    setTimeout(() => {
      document.getElementById('match-decisions').style.display = 'none';
      if (miniBall) {
        miniBall.classList.remove('shot');
        miniBall.style.left = '90px';
      }
      if (miniBallShadow) {
        miniBallShadow.classList.remove('shot');
        miniBallShadow.style.left = '90px';
      }
      setTimeout(() => {
        if (miniPlayer) miniPlayer.className = 'match-mini-player';
        triggerNextEvent();
      }, 600);
    }, 3000);
  });
}

function processShotResult(zone) {
  const eventEl = document.getElementById('match-event');
  const goalkeeper = document.getElementById('goalkeeper');
  const decisionDiv = document.getElementById('match-decisions');

  // Önce isabet kontrolü — şut stat'ına göre
  const sutStat = state.sut || state.skill;
  const accuracyBoost = (sutStat - 50) / 200; // -0.25 ile +0.25
  const finalAccuracy = Math.min(0.95, zone.accuracy + accuracyBoost) * matchCtx.luckyMod;

  // Kaleci atlama yönü — biz nereye attıysak ona doğru tahmin etmeye çalışıyor
  // 1/3 olasılıkla doğru tahmin
  let keeperDive = 'center';
  const keeperGuess = Math.random();
  if (zone.id === 0 || zone.id === 3 || zone.id === 6) {
    if (keeperGuess < 0.4) keeperDive = 'left';
    else if (keeperGuess < 0.7) keeperDive = 'center';
    else keeperDive = 'right';
  } else if (zone.id === 2 || zone.id === 5 || zone.id === 8) {
    if (keeperGuess < 0.4) keeperDive = 'right';
    else if (keeperGuess < 0.7) keeperDive = 'center';
    else keeperDive = 'left';
  } else {
    keeperDive = ['left', 'center', 'right'][Math.floor(Math.random() * 3)];
  }

  goalkeeper.classList.remove('dive-left', 'dive-right');
  if (keeperDive === 'left') goalkeeper.classList.add('dive-left');
  else if (keeperDive === 'right') goalkeeper.classList.add('dive-right');

  // İsabet eden + kaleci yanlış yönde + zone goalMult'a göre gol
  const isAccurate = Math.random() < finalAccuracy;

  let result;
  if (!isAccurate) {
    result = 'miss';
  } else {
    // Kaleci doğru yöne mi atladı?
    const correctDive =
      (zone.id === 0 || zone.id === 3 || zone.id === 6) && keeperDive === 'left' ||
      (zone.id === 2 || zone.id === 5 || zone.id === 8) && keeperDive === 'right' ||
      (zone.id === 1 || zone.id === 4 || zone.id === 7) && keeperDive === 'center';

    if (correctDive && Math.random() < zone.saveChance) {
      result = 'save';
    } else {
      result = 'goal';
    }
  }

  const miniPlayer = document.getElementById('match-mini-player');
  const miniBall = document.getElementById('match-mini-ball');
  const miniBallShadow = document.getElementById('match-mini-ball-shadow');
  miniPlayer.className = 'match-mini-player mini-charging';
  setTimeout(() => {
    miniPlayer.className = 'match-mini-player mini-running charging-pos';
    miniBall.classList.add('shot');
    if (miniBallShadow) miniBallShadow.classList.add('shot');
  }, 200);

  setTimeout(() => {
    if (result === 'goal') {
      matchCtx.myGoals++;
      showGoalFlash();
      // v11: gol = +2 Tsubasa bar, ekran sallaması
      addTsubasaBar(2);
      shakeScreen();
      setTimeout(() => {
        const scoreEl = document.getElementById('match-my-score');
        scoreEl.textContent = matchCtx.myGoals;
        scoreEl.classList.remove('scored');
        void scoreEl.offsetWidth;
        scoreEl.classList.add('scored');
        eventEl.className = 'match-event gol';
        eventEl.textContent = `⚽ ${matchCtx.minute}' GOOOL!`;
        miniPlayer.className = 'match-mini-player mini-celebrating charging-pos';
      }, 600);
      // v11: Hat-trick = çizgi roman karesi
      if (matchCtx.myGoals === 3) {
        setTimeout(() => playComicStrip(), 1400);
      }
      matchCtx.oppPressure = Math.max(0.2, matchCtx.oppPressure - 0.1);
    } else if (result === 'save') {
      const flash = document.createElement('div');
      flash.className = 'save-flash';
      document.getElementById('goal-frame').appendChild(flash);
      setTimeout(() => flash.remove(), 600);
      eventEl.className = 'match-event fail';
      eventEl.textContent = `🧤 KALECI KURTARDI!`;
    } else {
      eventEl.className = 'match-event fail';
      eventEl.textContent = Math.random() < 0.5 ? 'Direkten döndü!' : 'Auta gitti...';
    }
  }, 1100);

  // Rakibin kontra atak şansı
  setTimeout(() => simulateOppMove(), 2000);

  // Sonraki olaya geç
  setTimeout(() => {
    decisionDiv.style.display = 'none';
    miniBall.classList.remove('shot');
    miniBall.style.left = '90px';
    if (miniBallShadow) {
      miniBallShadow.classList.remove('shot');
      miniBallShadow.style.left = '90px';
    }
    if (!miniPlayer.classList.contains('mini-celebrating')) {
      miniPlayer.className = 'match-mini-player';
    }
    setTimeout(() => {
      miniPlayer.className = 'match-mini-player';
      triggerNextEvent();
    }, 600);
  }, 2800);
}


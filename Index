function renderStatsStep(content) {
  // Kalan puan hesabı: pool - dağıtılmış toplam
  const distributed = Object.values(creatorState.stats).reduce((a, b) => a + b, 0);
  creatorState.remainingPoints = TOTAL_STAT_POOL - distributed;

  const pos = POSITIONS.find(p => p.id === creatorState.positionId);
  const bonusText = Object.entries(pos.bonus)
    .map(([k, v]) => `+${v} ${k.toUpperCase()}`)
    .join(' · ');

  content.innerHTML = `
    <div class="creator-step-title">YETENEKLERİN</div>
    <div class="creator-step-hint">
      ${TOTAL_STAT_POOL} puanı 4 yeteneğe dağıt<br>
      <span style="color:var(--accent);font-weight:600;">Pozisyon bonusu: ${bonusText}</span>
    </div>
    <div class="creator-stat-pool">
      <div>
        <div class="creator-stat-pool-label">KALAN PUAN</div>
      </div>
      <div class="creator-stat-pool-value ${creatorState.remainingPoints === 0 ? 'empty' : ''}"
           id="creator-pool-value">${creatorState.remainingPoints}</div>
    </div>
    <div id="creator-stats-list"></div>
  `;

  const statsList = document.getElementById('creator-stats-list');
  const statDefs = [
    { key: 'sut', name: 'ŞUT', icon: '⚽' },
    { key: 'pas', name: 'PAS', icon: '🎯' },
    { key: 'defans', name: 'DEFANS', icon: '🛡️' },
    { key: 'hiz', name: 'HIZ', icon: '💨' },
  ];

  statDefs.forEach(s => {
    const row = document.createElement('div');
    row.className = 'creator-stat-row';
    row.innerHTML = `
      <div class="creator-stat-icon">${s.icon}</div>
      <div class="creator-stat-info">
        <div class="creator-stat-name">${s.name}</div>
        <div class="creator-stat-bar">
          <div class="creator-stat-bar-fill" id="bar-${s.key}"
               style="width:${(creatorState.stats[s.key] / MAX_STAT) * 100}%;"></div>
        </div>
      </div>
      <div class="creator-stat-controls">
        <button class="creator-stat-btn" data-action="dec" data-stat="${s.key}">−</button>
        <div class="creator-stat-value" id="val-${s.key}">${creatorState.stats[s.key]}</div>
        <button class="creator-stat-btn" data-action="inc" data-stat="${s.key}">+</button>
      </div>
    `;
    statsList.appendChild(row);
  });

  // +/- butonları
  statsList.addEventListener('click', (e) => {
    const btn = e.target.closest('.creator-stat-btn');
    if (!btn) return;
    const action = btn.dataset.action;
    const stat = btn.dataset.stat;
    const current = creatorState.stats[stat];

    if (action === 'inc') {
      if (creatorState.remainingPoints <= 0 || current >= MAX_STAT) return;
      creatorState.stats[stat] = current + 5;
      creatorState.remainingPoints -= 5;
      SFX.tick();
    } else if (action === 'dec') {
      if (current <= MIN_STAT) return;
      creatorState.stats[stat] = current - 5;
      creatorState.remainingPoints += 5;
      SFX.tick();
    }

    // UI güncelle
    document.getElementById(`val-${stat}`).textContent = creatorState.stats[stat];
    document.getElementById(`bar-${stat}`).style.width =
      (creatorState.stats[stat] / MAX_STAT) * 100 + '%';
    const poolEl = document.getElementById('creator-pool-value');
    poolEl.textContent = creatorState.remainingPoints;
    poolEl.classList.toggle('empty', creatorState.remainingPoints === 0);
    validateStep();
  });
}

function validateStep() {
  const nextBtn = document.getElementById('creator-next-btn');
  let valid = false;

  if (creatorState.step === 1) {
    valid = creatorState.name.length >= 2 && creatorState.name.length <= 20;
  } else if (creatorState.step === 2) {
    valid = creatorState.backstory !== null;
  } else if (creatorState.step === 3) {
    valid = creatorState.positionId !== null;
  } else if (creatorState.step === 4) {
    valid = true;
  } else if (creatorState.step === 5) {
    valid = creatorState.remainingPoints === 0;
  }

  nextBtn.disabled = !valid;
}

function nextCreatorStep() {
  if (creatorState.step < CREATOR_TOTAL_STEPS) {
    creatorState.step++;
    SFX.click();
    renderCreatorStep();
  } else {
    finalizeCreator();
  }
}

function prevCreatorStep() {
  if (creatorState.step > 1) {
    creatorState.step--;
    SFX.click();
    renderCreatorStep();
  } else {
    // İlk adımda geri = preset ekranına dön
    closeCreator();
  }
}

function finalizeCreator() {
  // Hangi slot'a kaydedileceğini bul (en küçük boş slot)
  let targetSlot = 1;
  for (let i = 1; i <= 3; i++) {
    if (!getSlotInfo(i)) { targetSlot = i; break; }
  }
  currentSlot = targetSlot;

  // Pozisyon bonuslarını ekle
  const pos = POSITIONS.find(p => p.id === creatorState.positionId);
  const finalStats = { ...creatorState.stats };
  Object.entries(pos.bonus).forEach(([k, v]) => {
    finalStats[k] = (finalStats[k] || 0) + v;
  });

  // State temel ayarları
  state = DEFAULT_STATE();
  state.selected = -1;
  state.name = creatorState.name;
  state.pos = pos.short;
  state.positionId = pos.id;
  state.hair = creatorState.hair;
  state.jersey = creatorState.jersey;
  state.skinTone = creatorState.skinTone;
  state.sut = finalStats.sut;
  state.pas = finalStats.pas;
  state.defans = finalStats.defans;
  state.hiz = finalStats.hiz;
  state.skill = Math.round((finalStats.sut + finalStats.pas + finalStats.defans + finalStats.hiz) / 4);
  state.teamIndex = Math.floor(Math.random() * TEAMS.length);
  state.gameDate = '2025-08-01';
  state.introSeen = true;
  state.chapter = 1;

  // Backstory uygula — bonusları state'e ekler
  state.backstory = creatorState.backstory;
  const bs = BACKSTORIES.find(b => b.id === creatorState.backstory);
  if (bs && bs.apply) bs.apply();

  initLeague();

  // Modal'ları kapat
  document.getElementById('creator-modal').classList.remove('active');
  document.getElementById('start-options-modal').classList.remove('active');
  document.getElementById('slots-modal').classList.remove('active');

  // v9: ilk açılışta cinematic giriş haberi
  setTimeout(() => {
    showCinematicNews({
      tag: 'TRANSFER HABERİ',
      icon: '⚽',
      title: `${state.name.split(' ')[0]} <span>${TEAMS[state.teamIndex]}</span>'A İMZA ATTI`,
      subtitle: `${state.age} yaşındaki ${state.pos} pozisyonundaki genç yetenek, ${TEAMS[state.teamIndex]} kulübüyle anlaştı.`,
      type: 'gold',
    });
  }, 400);

  addNews(`⚽ Yeni transfer: ${state.name} → ${TEAMS[state.teamIndex]}`);
  SFX.levelup();
  showSparkles(14);

  save();
  updateUI();
  updateChapterBanner();
}

function showSlotsScreen() {
  const list = document.getElementById('slots-list');
  list.innerHTML = '';

  for (let slot = 1; slot <= 3; slot++) {
    const info = getSlotInfo(slot);
    const card = document.createElement('div');

    if (!info) {
      card.className = 'save-slot-card empty';
      card.innerHTML = `
        <div class="slot-empty-icon">+</div>
        <div class="slot-empty-text">SLOT ${slot} · YENİ KARİYER</div>
      `;
      card.addEventListener('click', () => {
        SFX.click();
        currentSlot = slot;
        document.getElementById('slots-modal').classList.remove('active');
        document.getElementById('start-options-modal').classList.add('active');
      });
    } else {
      card.className = 'save-slot-card';
      const dateStr = info.date ?
        formatDateShort(new Date(info.date + 'T12:00:00')) :
        '—';
      card.innerHTML = `
        <div class="slot-header-row">
          <div class="slot-number">SLOT ${slot}</div>
          <button class="slot-delete-btn" data-del="${slot}">🗑️</button>
        </div>
        ${info.retired ? '<div class="slot-retired-badge">EMEKLİ</div>' : ''}
        <div class="slot-player-name">${info.name}</div>
        <div class="slot-player-meta">${info.pos} · ${info.age} yaş · Sezon ${info.season}</div>
        <div class="slot-stats-row">
          <div class="slot-stat">
            <span class="slot-stat-label">Tarih</span>
            <span class="slot-stat-value">${dateStr}</span>
          </div>
          <div class="slot-stat">
            <span class="slot-stat-label">Maç</span>
            <span class="slot-stat-value">${info.matches}</span>
          </div>
          <div class="slot-stat">
            <span class="slot-stat-label">Gol</span>
            <span class="slot-stat-value">${info.goals}</span>
          </div>
          <div class="slot-stat">
            <span class="slot-stat-label">Para</span>
            <span class="slot-stat-value">$${(info.money/1000).toFixed(0)}K</span>
          </div>
        </div>
      `;
      // Slot tıklaması — yükle
      card.addEventListener('click', (e) => {
        if (e.target.closest('.slot-delete-btn')) return;
        SFX.click();
        if (loadSlot(slot)) {
          document.getElementById('slots-modal').classList.remove('active');
          // Kayıtlı oyuncuya devam
          drawCharacter(document.getElementById('player'),
                        state.hair, state.jersey, false, 'normal', state.skinTone);
          if (!state.leagueStats || state.leagueStats.length === 0) initLeague();
          updateWeather();
          updateUI();
          updateChapterBanner();
          checkDailyReward();
          if (state.retired) gameOver('EMEKLİLİK', 'Önceki kariyerin sona ermişti.');
        }
      });
      // Silme butonu
      card.querySelector('.slot-delete-btn').addEventListener('click', (e) => {
        e.stopPropagation();
        SFX.click();
        showConfirm(`Slot ${slot} sil?`, `${info.name} kariyerini silmek üzeresin. Geri alınamaz.`, () => {
          deleteSlot(slot);
          showSlotsScreen(); // yeniden render
        }, 'danger');
      });
    }

    list.appendChild(card);
  }

  document.getElementById('slots-modal').classList.add('active');
}



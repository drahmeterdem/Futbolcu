      if(typeof state !== 'undefined' && state.name){
        V13.assignInitialManager();
      }

      // Quick panel'i geç yüklemeyle dene (oyuncu oluşturulmadan önce göstermeyelim)
      setTimeout(()=>{
        if(state && state.name) V13.injectV13QuickPanel();

  document.getElementById('creator-progress').style.width = ((step / CREATOR_TOTAL_STEPS) * 100) + '%';

  const labels = {
    1: 'ADIM 1 · KIMLIK',
    2: 'ADIM 2 · GEÇMİŞ',
    3: 'ADIM 3 · POZISYON',
    4: 'ADIM 4 · GÖRÜNÜM',
    5: 'ADIM 5 · STATLAR',
  };
  document.getElementById('creator-step-label').textContent = labels[step];

  const nextBtn = document.getElementById('creator-next-btn');
  nextBtn.textContent = step === CREATOR_TOTAL_STEPS ? 'FUTBOLCUMU YARAT' : 'DEVAM ET';

  const content = document.getElementById('creator-content');

  if (step === 1) renderNameStep(content);
  else if (step === 2) renderBackstoryStep(content);
  else if (step === 3) renderPositionStep(content);
  else if (step === 4) renderAppearanceStep(content);
  else if (step === 5) renderStatsStep(content);

  validateStep();
}


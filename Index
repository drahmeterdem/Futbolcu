function showMiniGame(trainType, onComplete){
  let modal = document.getElementById('v13-mini-modal');
  if(!modal){
    modal = document.createElement('div');
    modal.id = 'v13-mini-modal';
    modal.style.cssText = `position:fixed;inset:0;z-index:9992;background:rgba(0,0,0,0.92);
      display:flex;align-items:center;justify-content:center;padding:20px;
      opacity:0;transition:opacity 0.3s;pointer-events:none;`;
    modal.innerHTML = `
      <div style="background:#0a3a1a;color:#fff;width:100%;max-width:360px;
                  border-radius:14px;padding:16px;border:2px solid #2ecc71;
                  font-family:'Inter',system-ui,sans-serif;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
          <div id="v13-mini-title" style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;">—</div>
          <div id="v13-mini-timer" style="font-weight:900;font-size:22px;color:#ffd700;">5</div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:12px;">
          <span>SKOR: <b id="v13-mini-score">0</b></span>
          <span>TIKLAMA: <b id="v13-mini-clicks">0</b></span>
        </div>
        <div id="v13-mini-arena" style="position:relative;width:100%;height:280px;
              background:repeating-linear-gradient(90deg,#0d4a22,#0d4a22 30px,#0c4520 30px,#0c4520 60px);
              border-radius:10px;overflow:hidden;cursor:crosshair;"></div>
        <div id="v13-mini-result" style="text-align:center;margin-top:10px;font-size:14px;min-height:20px;"></div>
      </div>`;
    document.body.appendChild(modal);
  }
  const titles = { cardio:'💨 HIZ ANTRENMANI', technique:'⚽ ŞUT ANTRENMANI', tactic:'🎯 PAS ANTRENMANI' };
  document.getElementById('v13-mini-title').textContent = titles[trainType] || '⚡ ANTRENMAN';
  const arena = document.getElementById('v13-mini-arena');
  arena.innerHTML = '';
  document.getElementById('v13-mini-score').textContent = '0';
  document.getElementById('v13-mini-clicks').textContent = '0';
  document.getElementById('v13-mini-result').textContent = '';
  document.getElementById('v13-mini-timer').textContent = '5';
  modal.style.opacity = '1';
  modal.style.pointerEvents = 'auto';

  let score = 0, clicks = 0, timeLeft = 5, active = true;
  const targets = [];

  function spawnTarget(){
    if(!active) return;
    const t = document.createElement('div');
    const size = 36 + Math.floor(Math.random()*14);
    const x = Math.random() * (arena.clientWidth - size);
    const y = Math.random() * (arena.clientHeight - size);
    t.style.cssText = `position:absolute;left:${x}px;top:${y}px;width:${size}px;height:${size}px;
      background:radial-gradient(circle,#ffd700,#ff8c00);border-radius:50%;
      box-shadow:0 0 12px #ffd700;cursor:pointer;
      animation:v13pulse 0.6s ease-in-out infinite alternate;`;
    t.textContent = trainType==='technique' ? '🥅' : trainType==='tactic' ? '👟' : '⚡';
    t.style.display = 'flex';
    t.style.alignItems = 'center';
    t.style.justifyContent = 'center';
    t.style.fontSize = (size*0.6)+'px';
    t.addEventListener('pointerdown', (e)=>{
      e.preventDefault();
      if(!active) return;
      score++;
      document.getElementById('v13-mini-score').textContent = score;
      t.style.transform = 'scale(1.4)';
      t.style.opacity = '0';
      setTimeout(()=>{ if(t.parentNode) t.parentNode.removeChild(t); }, 200);
    });
    arena.appendChild(t);
    targets.push(t);
    setTimeout(()=>{ if(t.parentNode) t.parentNode.removeChild(t); }, 900);
  }

  arena.addEventListener('pointerdown', ()=>{ if(active) clicks++; document.getElementById('v13-mini-clicks').textContent = clicks; });

  const spawnInterval = setInterval(spawnTarget, 450);
  spawnTarget();

  const tickInterval = setInterval(()=>{
    timeLeft--;
    document.getElementById('v13-mini-timer').textContent = timeLeft;
    if(timeLeft <= 0){
      active = false;
      clearInterval(tickInterval);
      clearInterval(spawnInterval);
      const accuracy = clicks > 0 ? Math.round((score / clicks) * 100) : 0;
      const bonus = Math.min(8, Math.floor(score * 0.8));
      let rating = '';
      if(score >= 10)      rating = '🔥 MÜTHİŞ!';
      else if(score >= 6)  rating = '👍 İYİ';
      else if(score >= 3)  rating = '🙂 İDARE EDER';
      else                 rating = '😅 DAHA İYİSİNİ YAPABİLİRSİN';
      document.getElementById('v13-mini-result').innerHTML =
        `${rating} · İsabet: ${accuracy}% · Bonus: +${bonus} stat`;
      setTimeout(()=>{
        modal.style.opacity = '0';
        modal.style.pointerEvents = 'none';
        if(onComplete) onComplete(bonus, score, accuracy);
      }, 1800);
    }
  }, 1000);

  // CSS animasyonu (bir kez)
  if(!document.getElementById('v13-mini-styles')){
    const st = document.createElement('style');
    st.id = 'v13-mini-styles';
    st.textContent = `@keyframes v13pulse { from{transform:scale(0.9);} to{transform:scale(1.15);} }`;
    document.head.appendChild(st);
  }
}


function eat(type) {
  if (actionLock) return;
  lock();
  if (state.injured && type !== 'supplement' && type !== 'chef') {
    showMessage('Sakatsın, dinlen!', 'warn'); return;
  }
  const opts = {
    healthy: { cost: 50, mood: 5, fitness: 8, energy: 5, msg: 'Sağlıklı yemek 🥗' },
    protein: { cost: 80, mood: 3, fitness: 12, energy: 8, msg: 'Protein bombası 💪' },
    fastfood: { cost: 20, mood: 15, fitness: -10, energy: 5, msg: 'Hamburger! 😋' },
    supplement: { cost: 120, mood: 8, fitness: 15, energy: 15, msg: 'Vitamin 💊' },
    chef: { coinCost: 50, mood: 25, fitness: 25, energy: 25, msg: 'Özel şef yemeği 👨‍🍳' },
  };
  const o = opts[type];
  if (o.coinCost && state.coins < o.coinCost) { showMessage('Coin yetersiz!', 'warn'); return; }
  if (o.cost && state.money < o.cost) { showMessage('Yeterli paran yok!', 'warn'); return; }
  if (o.coinCost) { state.coins -= o.coinCost; showFloat(`-${o.coinCost} 💎`, true); flashCurrency('coin'); }
  if (o.cost) { state.money -= o.cost; showFloat(`-$${o.cost}`, true); flashCurrency('money'); }
  state.mood = clamp(state.mood + (o.mood || 0));
  state.fitness = clamp(state.fitness + (o.fitness || 0));
  state.energy = clamp(state.energy + (o.energy || 0));
  showMessage(o.msg, 'event');
  advanceTime();
}

function train(type) {
  if (actionLock) return;
  lock();
  if (state.injured) { showMessage('Sakatsın, antrenman yapamazsın!', 'warn'); return; }
  const mult = state.trainBoostDays > 0 ? 2 : 1;
  const opts = {
    cardio: { energy: -15, fitness: 10, skill: 2, msg: 'Koştun, koştun! 🏃' },
    technique: { energy: -10, skill: 4, mood: -2, msg: 'Top tekniği ⚽' },
    tactic: { energy: -5, skill: 3, mood: -3, msg: 'Taktik tahtası 🧠' },
    private: { energy: -10, skill: 8, fitness: 5, cost: 300, msg: 'Özel hoca! ⭐' },
    team: { energy: -8, skill: 2, chemistry: 8, mood: 5, msg: 'Takımla antrenman 👥' },
  };
  const o = opts[type];
  if (o.cost && state.money < o.cost) { showMessage('Yeterli paran yok!', 'warn'); return; }
  if (state.energy < Math.abs(o.energy || 0)) { showMessage('Çok yorgunsun, dinlen!', 'warn'); return; }
  if (o.cost) { state.money -= o.cost; showFloat(`-$${o.cost}`, true); flashCurrency('money'); }
  state.energy = clamp(state.energy + (o.energy || 0));
  state.fitness = clamp(state.fitness + (o.fitness || 0));
  const skillGain = (o.skill || 0) * mult;
  state.skill = Math.min(99, state.skill + skillGain);
  // v7: alt statlara da küçük bir artış — antrenman tipine göre öncelikli alan büyür
  // cardio -> hiz, technique -> sut, tactic -> pas, private -> tüm, team -> pas
  if (skillGain > 0 && state.sut !== undefined) {
    const subGain = Math.max(1, Math.floor(skillGain / 2));
    if (type === 'cardio') state.hiz = Math.min(99, state.hiz + subGain);
    else if (type === 'technique') state.sut = Math.min(99, state.sut + subGain);
    else if (type === 'tactic') state.pas = Math.min(99, state.pas + subGain);
    else if (type === 'team') state.pas = Math.min(99, state.pas + Math.max(1, Math.floor(subGain/2)));
    else if (type === 'private') {
      // Özel hoca tüm alt statları biraz arttırır
      state.sut = Math.min(99, state.sut + 1);
      state.pas = Math.min(99, state.pas + 1);
      state.defans = Math.min(99, state.defans + 1);
      state.hiz = Math.min(99, state.hiz + 1);
    }
  }
  state.mood = clamp(state.mood + (o.mood || 0));
  state.chemistry = clamp(state.chemistry + (o.chemistry || 0));

  if (type === 'cardio' && state.fitness < 30 && Math.random() < (0.15 - getSkillBonus('injury')/100)) {
    triggerInjury();
    return;
  }

  if (skillGain > 0) showFloat(`+${skillGain} SKILL`, false);
  showMessage(o.msg + (mult > 1 ? ' (2x aktif)' : ''), 'event');
  document.getElementById('player').classList.add('training');
  setTimeout(() => document.getElementById('player').classList.remove('training'), 800);
  advanceTime();
}

function life(type) {
  if (actionLock) return;
  lock();
  const opts = {
    sleep: { energy: 40, mood: 5, msg: 'Mışıl mışıl uyudun 😴', healing: true },
    shop: { cost: 200, fame: 8, mood: 10, msg: 'Yeni saat! 📸' },
    interview: { cost: -300, fame: 5, energy: -10, msg: 'Röportaj! 🎤', image: 5 },
    ad: { cost: -800, fame: 10, energy: -15, mood: -5, msg: 'Reklam çekimi! 📺' },
    vacation: { cost: 500, mood: 25, energy: 20, msg: 'Tatil! ☀️' },
    social: { fame: 12, mood: -3, msg: 'Sosyal medya 📱', riskCheck: true },
    date: { cost: 400, mood: 20, fame: 5, msg: 'Romantik akşam 💕', dating: true },
    charity: { cost: 1000, image: 20, fame: 5, mood: 10, msg: 'Hayır işi ❤️' },
  };
  const o = opts[type];
  const cost = o.cost || 0;
  if (cost > 0 && state.money < cost) { showMessage('Yeterli paran yok!', 'warn'); return; }

  if (type === 'sleep' && state.injured && o.healing) {
    state.injuryDaysLeft = Math.max(0, state.injuryDaysLeft - 1);
    if (state.injuryDaysLeft === 0) {
      state.injured = false;
      setTimeout(() => showMessage('Sakatlığın iyileşti! 💪', 'event'), 600);
    }
    document.getElementById('player').classList.add('sleeping');
    setTimeout(() => document.getElementById('player').classList.remove('sleeping'), 1500);
  } else if (type === 'sleep') {
    document.getElementById('player').classList.add('sleeping');
    setTimeout(() => document.getElementById('player').classList.remove('sleeping'), 1500);
  }

  if (o.riskCheck && Math.random() < 0.15) {
    showMessage('Sosyal medya skandalı! İmajın düştü 😱', 'warn');
    state.publicImage = clamp(state.publicImage - 15);
    state.fame = clamp(state.fame + 5);
    showFloat('-15 İMAJ', true);
    screenFlash(); // skandal — ekran kenarı kırmızı
    advanceTime(); return;
  }

  let adBonus = 0;
  if (type === 'ad') adBonus = -getSkillBonus('ad') * 8;

  if (o.dating && !state.relationship) {
    const partner = FIRST_NAMES_F[Math.floor(Math.random() * FIRST_NAMES_F.length)];
    state.relationship = 1;
    state.partnerName = partner;
    setTimeout(() => showMessage(`${partner} ile ilişkiye başladın 💕`, 'event'), 600);
  }

  if (cost > 0) { state.money -= cost; showFloat(`-$${cost}`, true); flashCurrency('money'); }
  if (cost < 0) { state.money += -cost; showFloat(`+$${-cost}`, false); flashCurrency('money'); }
  if (adBonus) { state.money -= adBonus; showFloat(`+$${-adBonus}`, false, true); flashCurrency('money'); }

  state.fame = clamp(state.fame + (o.fame || 0) + (type === 'social' ? getSkillBonus('fame') / 10 : 0));
  state.mood = clamp(state.mood + (o.mood || 0));
  state.energy = clamp(state.energy + (o.energy || 0));
  state.publicImage = clamp(state.publicImage + (o.image || 0));
  showMessage(o.msg, 'event');
  advanceTime();
}

function triggerInjury() {
  state.injured = true;
  state.injuryDaysLeft = 3 + Math.floor(Math.random() * 5);
  showMessage(`SAKATLIK! ${state.injuryDaysLeft} gün dinlenme.`, 'warn');
  addNews(`💉 ${state.name} sakatlandı!`);
  SFX.fail();
  screenFlash(); // kırmızı parıltı
  updateUI();
}

// ============================================================
// MAÇ MOTORU v8 — Gelişmiş etkileşimli sistem
// ============================================================
// Eski v7'de 3 sabit dakikada (20/60/85) basit ikili karar vardı.
// v8'de:
// - Her maçta 4-6 farklı kritik an dinamik tetiklenir
// - Şut için 3x3 kale grid'i (köşe = riskli ama yatkın)
// - Pas için 3 takım arkadaşı arasında seçim
// - Penaltı: 9-noktalı kale, kaleci yöne atlar
// - Frikik: mesafe/teknik seçimi
// - Savunma anları: forvet pozisyonunda olmayanlar için
// ============================================================

let matchCtx = null;
let matchDecisionLock = false;

// Maçtaki şu anki olayı belirleyen olası senaryolar
// Olasılıklar pozisyona göre değişir (forvet daha çok şut, defans daha çok savunma)
const MATCH_EVENT_TYPES = {
  forvet:  { shot: 0.40, pass: 0.20, penalty: 0.10, freekick: 0.10, defend: 0.05, counter: 0.15 },
  orta:    { shot: 0.25, pass: 0.30, penalty: 0.05, freekick: 0.15, defend: 0.10, counter: 0.15 },
  kanat:   { shot: 0.25, pass: 0.25, penalty: 0.05, freekick: 0.10, defend: 0.10, counter: 0.25 },
  defans:  { shot: 0.10, pass: 0.20, penalty: 0.02, freekick: 0.08, defend: 0.45, counter: 0.15 },
};

// Takım arkadaşı havuzu — pas seçeneklerinde rastgele 3 oluşur
const TEAMMATE_NAMES = ['Mert', 'Kaan', 'Burak', 'Onur', 'Ali', 'Cem', 'Eren', 'Selim', 'Tolga', 'Hakan'];
const TEAMMATE_POSITIONS = [
  { id: 'fwd',  name: 'F', icon: '🎯', goalMod: 1.4, free_w: 0.3 },
  { id: 'mid',  name: 'O', icon: '⚡', goalMod: 1.0, free_w: 0.5 },
  { id: 'wing', name: 'K', icon: '💨', goalMod: 1.1, free_w: 0.4 },
  { id: 'def',  name: 'D', icon: '🛡️', goalMod: 0.5, free_w: 0.6 },
];

function generateTeammates(count = 3) {
  const used = new Set();
  const list = [];
  for (let i = 0; i < count; i++) {
    let name, pos, status;
    do { name = TEAMMATE_NAMES[Math.floor(Math.random() * TEAMMATE_NAMES.length)]; }
    while (used.has(name));
    used.add(name);
    pos = TEAMMATE_POSITIONS[Math.floor(Math.random() * TEAMMATE_POSITIONS.length)];
    // Statü: serbest / baskı altında / tehlikede
    const r = Math.random();
    if (r < pos.free_w) status = 'free';
    else if (r < pos.free_w + 0.4) status = 'pressed';
    else status = 'danger';
    list.push({
      name, pos, status,
      // Skill rastgele (40-80) ama statüye göre etkilenir
      skill: 50 + Math.floor(Math.random() * 30),
    });
  }
  return list;
}

function playMatch() {
  if (actionLock) return;
  lock(500);
  if (state.injured) { showMessage('Sakatsın, oynayamazsın!', 'warn'); return; }
  if (state.energy < 30) { showMessage('Maç için çok yorgunsun!', 'warn'); return; }

  // v13: rakip aynı ligden seçilir (aynı ülke + aynı tier)
  const myTeamIdx = state.teamIndex;
  let oppIdx;
  try {
    const leaguePool = (typeof V13 !== 'undefined') ? V13.getCurrentLeagueIndices() : [];
    const others = leaguePool.filter(i => i !== myTeamIdx);
    if (others.length > 0) {
      oppIdx = others[state.week % others.length];
    } else {
      oppIdx = (myTeamIdx + state.week) % TEAMS.length;
      if (oppIdx === myTeamIdx) oppIdx = (oppIdx + 1) % TEAMS.length;
    }
  } catch(e) {
    oppIdx = (myTeamIdx + state.week) % TEAMS.length;
    if (oppIdx === myTeamIdx) oppIdx = (oppIdx + 1) % TEAMS.length;
  }

  const myTeam = TEAMS[myTeamIdx];
  const oppTeam = TEAMS[oppIdx];

  const weatherMod = WEATHERS.find(w => w.id === state.weather)?.mod || 1.0;
  const ageMod = state.age <= 30 ? 1.0 : Math.max(0.7, 1.0 - (state.age - 30) * 0.04);
  const luckyMod = state.luckyDays > 0 ? 1.15 : 1.0;

  // v8: gelişmiş context — olay sayacı, dakika, kullanılan eylemler
  matchCtx = {
    myGoals: 0, oppGoals: 0, oppIdx, myTeam, oppTeam,
    weatherMod, ageMod, luckyMod,
    minute: 0,
    eventCount: 0,
    maxEvents: 5 + Math.floor(Math.random() * 2), // 5-6 olay
    // Rakip takımın baskısı; biz iyi oynarsak düşer
    oppPressure: 0.5,
    // Karakter mevcut bölgede — şut/pas için faydalı
    zone: 'midfield',
  };

  document.getElementById('match-week-tag').textContent =
    `Hafta ${state.week} · ${WEATHERS.find(w=>w.id===state.weather).name}`;
  document.getElementById('match-my-team').textContent = myTeam;
  document.getElementById('match-opp-team').textContent = oppTeam;
  document.getElementById('match-my-score').textContent = '0';
  document.getElementById('match-opp-score').textContent = '0';
  document.getElementById('match-my-score').classList.remove('scored');
  document.getElementById('match-opp-score').classList.remove('scored');
  document.getElementById('match-event').textContent = 'Maç başlıyor...';
  document.getElementById('match-event').className = 'match-event';
  document.getElementById('match-decisions').style.display = 'none';
  document.getElementById('match-final').style.display = 'none';
  document.getElementById('match-minute').textContent = "0'";

  const miniPlayer = document.getElementById('match-mini-player');
  drawCharacter(miniPlayer, state.hair, state.jersey, false, 'normal', state.skinTone,
                state.hairStyle || 'short', state.jerseyNumber || 10);
  miniPlayer.className = 'match-mini-player';
  const ball = document.getElementById('match-mini-ball');
  const ballShadow = document.getElementById('match-mini-ball-shadow');
  ball.classList.remove('shot');
  ball.style.left = '90px';
  if (ballShadow) {
    ballShadow.classList.remove('shot');
    ballShadow.style.left = '90px';
  }
  ball.style.top = '60%';

  document.getElementById('match-modal').classList.add('active');
  SFX.whistle();

  // v11: Tsubasa bar maç başında 1 ile başlar (ilk şut için yeterli bir miktar)
  tsubasaBarValue = 1;
  updateTsubasaBar();

  setTimeout(() => triggerNextEvent(), 1600);
}

// Bir sonraki olayı seç ve çağır — pozisyona göre dağılım
function triggerNextEvent() {
  matchCtx.eventCount++;

  // Maç süresini ileriye taşı (her olay 12-18 dakika gerçekleşiyor)
  const advance = 12 + Math.floor(Math.random() * 8);
  matchCtx.minute = Math.min(90, matchCtx.minute + advance);
  document.getElementById('match-minute').textContent = matchCtx.minute + "'";

  // Maç bitti mi?
  if (matchCtx.eventCount > matchCtx.maxEvents || matchCtx.minute >= 90) {
    return endMatch();
  }

  matchDecisionLock = false;
  SFX.tick();

  // Pozisyona göre olay tipi seç
  const posKey = state.positionId || 'orta';
  const dist = MATCH_EVENT_TYPES[posKey] || MATCH_EVENT_TYPES.orta;
  const r = Math.random();
  let cumulative = 0;
  let chosenType = 'shot';
  for (const [type, prob] of Object.entries(dist)) {
    cumulative += prob;
    if (r < cumulative) { chosenType = type; break; }
  }

  // İlk olay her zaman ısınma — daha basit pas
  if (matchCtx.eventCount === 1) chosenType = 'pass';

  // İlgili karar fonksiyonunu çağır
  switch (chosenType) {
    case 'shot':     return renderShotDecision();
    case 'pass':     return renderPassDecision();
    case 'penalty':  return renderPenaltyDecision();
    case 'freekick': return renderFreeKickDecision();
    case 'defend':   return renderDefendDecision();
    case 'counter':  return renderCounterDecision();
    default:         return renderShotDecision();
  }
}


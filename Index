function clamp(v, max = 100) { return Math.max(0, Math.min(max, v)); }

function updateBar(barId, valId, val) {
  const bar = document.getElementById(barId);
  const valEl = document.getElementById(valId);
  bar.style.width = val + '%';

  // Animate value if changed
  const oldVal = parseInt(valEl.textContent);
  const newVal = Math.round(val);
  if (oldVal !== newVal) {
    valEl.textContent = newVal;
    valEl.classList.remove('changing');
    void valEl.offsetWidth; // reflow trick
    valEl.classList.add('changing');
  }

  bar.classList.remove('warn', 'danger');
  if (val < 15) bar.classList.add('danger');
  else if (val < 30) bar.classList.add('warn');
}

function flashCurrency(which) {
  const el = document.getElementById(which === 'money' ? 'currency-money' : 'currency-coin');
  el.classList.remove('flash');

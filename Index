function initLeague() {
  state.leagueStats = TEAMS.map((t, i) => ({
    name: t, p: 0, w: 0, d: 0, l: 0, gf: 0, ga: 0, pts: 0,
    isMe: i === state.teamIndex
  }));
}

function simulateOtherMatches() {
  // v13: artık aynı lig (aynı ülke + aynı tier) içinden takımlar simüle edilir
  let pool = [];
  try {
    if (typeof V13 !== 'undefined' && V13.getCurrentLeagueIndices) {
      pool = V13.getCurrentLeagueIndices();
    }
  } catch(e) {}
  if (!pool || pool.length < 2) {
    // Fallback: ilk 10 takım
    pool = state.leagueStats ? state.leagueStats.map(s => s.idx ?? state.leagueStats.indexOf(s)) : [];
  }
  // Lig içinde gerçek bir simülasyon — her diğer takım çifti için
  const filtered = pool.filter(idx => idx !== state.teamIndex);
  const pairs = Math.min(4, Math.floor(filtered.length / 2));
  const shuffled = [...filtered].sort(() => Math.random() - 0.5);

  for (let i = 0; i < pairs; i++) {
    const a = shuffled[i*2];
    const b = shuffled[i*2 + 1];
    if (a === undefined || b === undefined) continue;
    // Lig stats içindeki kayıtları bul
    const statA = state.leagueStats.find(s => (s.idx ?? s.name) === a || s.name === TEAMS[a]);
    const statB = state.leagueStats.find(s => (s.idx ?? s.name) === b || s.name === TEAMS[b]);
    if (!statA || !statB) continue;
    const ga = Math.floor(Math.random() * 4);
    const gb = Math.floor(Math.random() * 4);
    statA.gf += ga; statA.ga += gb;
    statB.gf += gb; statB.ga += ga;
    statA.p++; statB.p++;
    if (ga > gb) { statA.w++; statA.pts += 3; statB.l++; }
    else if (ga < gb) { statB.w++; statB.pts += 3; statA.l++; }
    else { statA.d++; statB.d++; statA.pts++; statB.pts++; }
  }
}

function updateMyLeagueStats(myGoals, oppGoals, oppIdx) {
  if (!state.leagueStats || state.leagueStats.length === 0) initLeague();
  const me = state.leagueStats[state.teamIndex];
  const opp = state.leagueStats[oppIdx];
  me.p++; opp.p++;
  me.gf += myGoals; me.ga += oppGoals;
  opp.gf += oppGoals; opp.ga += myGoals;
  if (myGoals > oppGoals) { me.w++; me.pts += 3; opp.l++; }
  else if (myGoals < oppGoals) { opp.w++; opp.pts += 3; me.l++; }
  else { me.d++; opp.d++; me.pts++; opp.pts++; }
}

function showLeagueTable() {
  const div = document.getElementById('league-content');
  if (!state.leagueStats || state.leagueStats.length === 0) initLeague();
  const sorted = [...state.leagueStats].sort((a, b) => b.pts - a.pts || (b.gf - b.ga) - (a.gf - a.ga));

  div.innerHTML = '';
  const wrapper = document.createElement('div');
  wrapper.style.borderRadius = '14px';
  wrapper.style.overflow = 'hidden';
  wrapper.style.border = '1px solid var(--border)';
  div.appendChild(wrapper);

  const header = document.createElement('div');
  header.className = 'league-row header';
  header.innerHTML = '<span>#</span><span>TAKIM</span><span>O</span><span>G</span><span>M</span><span>P</span>';
  wrapper.appendChild(header);

  sorted.forEach((t, i) => {
    const row = document.createElement('div');
    let cls = 'league-row';
    if (t.isMe) cls += ' me';
    if (i === 0) cls += ' first';
    row.className = cls;
    row.innerHTML = `
      <span>${i+1}</span>
      <span style="font-size:13px;font-weight:600;">${t.name}</span>
      <span>${t.p}</span>
      <span>${t.w}</span>
      <span>${t.l}</span>
      <span class="league-pts">${t.pts}</span>
    `;
    wrapper.appendChild(row);
  });
}


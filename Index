const EVENTS = [
  { msg: 'Reklam teklifi! +$500 💰', effect: () => state.money += 500 },
  { msg: 'Sosyal medya skandalı! -İmaj', effect: () => state.publicImage = clamp(state.publicImage - 10) },
  { msg: 'Taraftar mektubu 💌 +Moral', effect: () => state.mood = clamp(state.mood + 10) },
  { msg: 'Antrenörle tartışma -Moral', effect: () => state.mood = clamp(state.mood - 8) },
  { msg: 'İmza günü +Şöhret', effect: () => state.fame = clamp(state.fame + 7) },
  { msg: 'Dergi kapağı! +İmaj +Şöhret', effect: () => { state.publicImage = clamp(state.publicImage + 10); state.fame = clamp(state.fame + 8); }},
  { msg: 'Aile ziyareti +Moral', effect: () => state.mood = clamp(state.mood + 12) },
];

function advanceTime() {
  state.day++;
  advanceDate(1); // v9: gerçek tarihi de 1 gün ilerlet
  state.energy = clamp(state.energy - 5);
  state.mood = clamp(state.mood - 3);
  state.fitness = clamp(state.fitness - 2);

  if (state.premium && state.premiumDaysLeft > 0) {
    state.premiumDaysLeft--;
    state.coins += 7;
    if (state.premiumDaysLeft === 0) {
      state.premium = false;
      setTimeout(() => showMessage('Premium pas süresi doldu', 'warn'), 800);
    }
  }

  if (state.trainBoostDays > 0) state.trainBoostDays--;
  if (state.luckyDays > 0) state.luckyDays--;

  if (state.injured && state.injuryDaysLeft > 0) {
    state.injuryDaysLeft--;
    if (state.injuryDaysLeft <= 0) {
      state.injured = false;
      setTimeout(() => showMessage('Sakatlığın iyileşti! 💪', 'event'), 600);
    }
  }

  if (state.day % 3 === 0) rollWeather();
  if (state.day % 5 === 0) addNews(generateRandomNews());

  // v9: hikaye chapter ilerleme kontrolü
  checkChapterProgress();

  // v9: gizli görüşme tetikleyici
  if (state.selected !== null && !state.injured) {
    maybeTriggerSecretMeeting();
  }

  // v10: sponsor sistemleri
  if (state.selected !== null && !state.injured) {
    maybeTriggerSponsorOffer();
    maybeTriggerBigShoot();
  }
  // Her 7 günde bir sponsor ödemesi (haftalık)
  if (state.day % 7 === 0) {
    processSponsorPayments();
  }

  if (Math.random() < 0.18) {
    const ev = EVENTS[Math.floor(Math.random() * EVENTS.length)];
    ev.effect();
    setTimeout(() => showMessage(ev.msg, 'event'), 600);
  }

  if (state.relationship && Math.random() < 0.05) {
    state.mood = clamp(state.mood - 5);
    setTimeout(() => showMessage(`${state.partnerName} darıldı 💔`, 'warn'), 1000);
  }

  updateUI();
  checkAchievements();
  checkGameOver();
}

function checkGameOver() {
  if (state.mood <= 0) gameOver('DEPRESYON', 'Moralin tamamen bozuldu, futbolu bıraktın.');
  else if (state.fitness <= 0) gameOver('CIDDI SAKATLIK', 'Vücudun dayanmadı.');
  else if (state.publicImage <= 0) gameOver('REZALET', 'İmajın yıkıldı, kulübünden atıldın.');
}

function checkRetirement() {
  if (state.age >= 38) gameOver('EMEKLİLİK', `${state.age} yaşında onurlu emeklilik.`);
}

function gameOver(title, reason) {
  state.retired = true;
  document.getElementById('gameover-title').textContent = title;
  document.getElementById('gameover-reason').textContent = reason;

  const stats = [
    { label: 'Maç', val: state.matches },
    { label: 'Gol', val: state.goals },
    { label: 'Galibiyet', val: state.wins },
    { label: 'Kupa', val: state.trophies },
    { label: 'Skill', val: state.skill },
    { label: 'Şöhret', val: state.fame },
    { label: 'Sezon', val: state.season },
    { label: 'Başarım', val: `${state.achievements.length}/${ACHIEVEMENTS.length}` },
  ];
  const grid = document.getElementById('gameover-stats');
  grid.innerHTML = '';
  stats.forEach(s => {
    grid.innerHTML += `
      <div class="stat-card">
        <div class="stat-card-label">${s.label}</div>
        <div class="stat-card-value">${s.val}</div>
      </div>
    `;
  });

  document.getElementById('gameover-modal').classList.add('active');
  SFX.fail();
}


}

function updateUI() {
  // V13 guard: state mevcut değilse çık
  if (typeof state === 'undefined' || !state) return;
  updateBar('bar-mood', 'val-mood', state.mood);
  updateBar('bar-energy', 'val-energy', state.energy);
  updateBar('bar-fitness', 'val-fitness', state.fitness);
  updateBar('bar-fame', 'val-fame', state.fame);
  updateBar('bar-skill', 'val-skill', state.skill);

  document.getElementById('money-value').textContent = state.money.toLocaleString('tr-TR');
  document.getElementById('coin-value').textContent = state.coins.toLocaleString('tr-TR');

  document.getElementById('player-name-display').textContent = state.name.split(' ')[0] || 'OYUNCU';
  document.getElementById('player-age').textContent = state.age;
  document.getElementById('player-pos').textContent = state.pos || 'OOS';
  // v9: tarih göstergesi
  const dateEl = document.getElementById('date-display');
  if (dateEl) dateEl.textContent = formatDateShort();

  const badgesDiv = document.getElementById('player-badges');
  badgesDiv.innerHTML = '';
  if (state.premium) badgesDiv.innerHTML += '<div class="player-badge gold">⭐</div>';
  if (state.injured) badgesDiv.innerHTML += '<div class="player-badge danger">💉</div>';
  if (state.relationship) badgesDiv.innerHTML += '<div class="player-badge">💕</div>';
  if (state.luckyDays > 0) badgesDiv.innerHTML += '<div class="player-badge lucky">🍀</div>';

  const player = document.getElementById('player');
  // v7: mood durumu ve buna göre yüz ifadesi
  // Önceliğe göre: sakatlık > yorgun > üzgün > mutlu > normal
  // Karakter sadece mood değiştiyse yeniden çizilir (performans).
  let currentMood = 'normal';
  if (state.injured) currentMood = 'sad';
  else if (state.energy < 25) currentMood = 'tired';
  else if (state.mood < 25) currentMood = 'sad';
  else if (state.mood > 80 && state.energy > 50) currentMood = 'happy';

  if (player.dataset.mood !== currentMood ||
      player.dataset.hair !== state.hair ||
      player.dataset.jersey !== state.jersey ||
      player.dataset.skin !== state.skinTone ||
      player.dataset.hairStyle !== (state.hairStyle || 'short') ||
      player.dataset.jerseyNum !== String(state.jerseyNumber || 10)) {
    drawCharacter(player, state.hair, state.jersey, false, currentMood, state.skinTone,
                  state.hairStyle || 'short', state.jerseyNumber || 10);
    player.dataset.mood = currentMood;
    player.dataset.hair = state.hair;
    player.dataset.jersey = state.jersey;
    player.dataset.skin = state.skinTone;
    player.dataset.hairStyle = state.hairStyle || 'short';
    player.dataset.jerseyNum = String(state.jerseyNumber || 10);
  }

  player.classList.remove('happy', 'sleeping', 'tired', 'training', 'injured', 'celebrating');
  if (state.injured) player.classList.add('injured');
  else if (state.energy < 25) player.classList.add('tired');
  else if (state.mood > 80) player.classList.add('happy');

  // Thought (deterministic, no flicker)
  const thought = document.getElementById('thought');
  let thoughtEmoji = null;
  if (state.injured) thoughtEmoji = '🩹';
  else if (state.energy < 20) thoughtEmoji = '💤';
  else if (state.mood < 25) thoughtEmoji = '😢';
  else if (state.fitness < 25) thoughtEmoji = '🤕';

  if (thoughtEmoji) {
    thought.textContent = thoughtEmoji;
    thought.classList.add('show');
  } else {
    thought.classList.remove('show');
  }

  const cw = document.getElementById('companion-wrapper');
  if (state.relationship) {
    cw.classList.add('show');
    drawCharacter(document.getElementById('companion'), '#dcc998', '#ff5e8e', true);
  } else {
    cw.classList.remove('show');
  }

  const fans = document.getElementById('fans');
  if (state.fame > 70 && state.mood > 60) fans.classList.add('show');
  else fans.classList.remove('show');

  document.getElementById('news-dot').style.display = state.newsUnread > 0 ? 'block' : 'none';
  document.getElementById('skill-dot').style.display = state.skillPoints > 0 ? 'block' : 'none';

  save();
}

// MESAJ KUYRUĞU
// Eski sistemde showMessage('A') ve hemen sonra showMessage('B')
// çağrılırsa A görünmeden B üstüne yazılıyordu.
// Çözüm: gelen mesajları kuyruğa atıyoruz, her mesaj en az 1.4 saniye
// ekranda kalıyor. Aynı mesaj art arda iki kez gelirse tekrar göstermiyoruz.
const messageQueue = [];
let messageBusy = false;
let lastMessageText = '';

function showMessage(text, type = 'normal') {
  if (text === lastMessageText && messageBusy) return; // tekrar engelle
  messageQueue.push({ text, type });
  if (!messageBusy) processMessageQueue();
}

function processMessageQueue() {
  if (messageQueue.length === 0) {
    messageBusy = false;
    return;
  }
  messageBusy = true;
  const { text, type } = messageQueue.shift();
  lastMessageText = text;
  const msg = document.getElementById('message');
  msg.textContent = text;
  msg.className = 'message-bar';
  if (type === 'event') { msg.classList.add('event'); SFX.success(); }
  else if (type === 'warn') { msg.classList.add('warn'); SFX.warning(); }
  // Bir sonraki mesaj için bekle — kuyruk doluysa daha hızlı geç
  const wait = messageQueue.length > 2 ? 900 : 1400;
  setTimeout(processMessageQueue, wait);
}

